	RES_NAME[RES_HOLLOWSTONE] = Db("Hollowstone");
	RES_UNIT_STRING[RES_HOLLOWSTONE] = Db("Hollowstone Fragment");
	RES_LABEL_STRING[RES_HOLLOWSTONE] = Db("Hollowstone");
	RES_HARVEST_SOUND[RES_HOLLOWSTONE] = SOUND_HARVEST_STONE;
	RES_SPAWNABLE[RES_HOLLOWSTONE] = true;
	RES_TOTAL_AMOUNT[RES_HOLLOWSTONE] = 100;
	RES_HARVESTING_TIMER[RES_HOLLOWSTONE] = 128;
