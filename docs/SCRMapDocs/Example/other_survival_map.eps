];

const CONST_AGGRO_TIMER_MAX = 24;

var Time = CONST_CYCLE_LENGTH_FRAMES/24*CONST_DAY_HOUR_START;
var Expired = false;
var Night = false;
var AM = false;
var Day = 1;
var Multiplayer = false;
var AggroTimer = 0;
var UpdatePlayerScreenDimensionsTimer = 0;
var ReplacedInitialResources = false;
var MobSpawnLimit = 5;
var MobAggroRange = CONST_MOB_AGGRO_RANGE_MIN_TILES*TILE;
var StructureControlRange = CONST_STRU_CONTROL_RANGE_MP;

function SelectAbility(playerID, abilityID);
function ReplaceUnit(unit:CUnit, unitType);
function ReplaceUnitWithOffset(unit:CUnit, unitType, yOffset);
function CreateOverlayUnit(unit:CUnit, imageID, playerID);
function UpdatePlayerTooltips(playerID);
function GetPlayerResourceAmount(playerID, resourceType);
function AddPlayerResourceAmount(playerID, resourceType, amount, display);
function CreateCUnit(unitType, playerID, location);
function SelectUnit(unit: CUnit, playerID);
function GiveUnit(unit : CUnit, playerID);
function SetupRandomizedBiomes();

function abs(n) {
	return n.AtLeast(1<<31) ? -n : n;
}

function Rand(n) {
	if (dwrand() % (100) < n) return true;
	return false;
}

function Setup() {
	SetupRandomizedBiomes();
	// Resources
	foreach(i : py_range(0, RES_COUNT)) {
		RES_SECONDARY_RES[i] = RES_COUNT;
		RES_HARVESTING_QUANTITY[i] = 1;
	}

	foreach(i : py_range(OPT_1, OPT_18+1)) {
	    wwrite(0x65FD00 + 15240 + i * 2, 0);
	    wwrite(0x65FD00 + 0 + i * 2, 0);
	    wwrite(0x65FD00 + 1832 + i * 2, 30000);
	    bwrite(0x65FD00 + 16360 + i * 1, 0);
	}

	RES_NAME[RES_LEAVES] = Db("Leaves");
	RES_UNIT_STRING[RES_LEAVES] = Db("Bush");
	RES_LABEL_STRING[RES_LEAVES] = Db("Leaves & Berries");
	RES_SPAWNABLE[RES_LEAVES] = true;
	RES_IMAGES[RES_LEAVES] = [618,620,622,618];	
	RES_TOTAL_AMOUNT[RES_LEAVES] = 25;
	RES_HARVESTING_TIMER[RES_LEAVES] = 32;
	RES_HARVESTING_QUANTITY[RES_LEAVES] = 1;
	RES_SECONDARY_RES[RES_LEAVES] = RES_BERRIES;
	RES_SECONDARY_RES_FREQUENCY[RES_LEAVES] = 3;
	RES_HARVEST_SOUND[RES_LEAVES] = SOUND_HARVEST_BUSH;

	RES_NAME[RES_WOOD] = Db("Wood");
	RES_UNIT_STRING[RES_WOOD] = Db("Tree");
	RES_LABEL_STRING[RES_WOOD] = Db("Wood & Leaves");
	RES_SPAWNABLE[RES_WOOD] = true;
	RES_IMAGES[RES_WOOD] = [632,634,636,638];
	RES_TOTAL_AMOUNT[RES_WOOD] = 50;
	RES_HARVESTING_TIMER[RES_WOOD] = 48;
	RES_HARVESTING_QUANTITY[RES_WOOD] = 1;
	RES_SECONDARY_RES[RES_WOOD] = RES_LEAVES;
	RES_SECONDARY_RES_FREQUENCY[RES_WOOD] = 4;
	RES_HARVEST_SOUND[RES_WOOD] = SOUND_HARVEST_WOOD;

	RES_NAME[RES_STONE] = Db("Stone");
	RES_UNIT_STRING[RES_STONE] = Db("Stone formation");
	RES_LABEL_STRING[RES_STONE] = Db("Stone");
	RES_SPAWNABLE[RES_STONE] = true;
	RES_IMAGES[RES_STONE] = [654,655,654,655];
	RES_TOTAL_AMOUNT[RES_STONE] = 75;
	RES_HARVESTING_TIMER[RES_STONE] = 64;
	RES_HARVEST_SOUND[RES_STONE] = SOUND_HARVEST_STONE;
	RES_SECONDARY_RES[RES_STONE] = RES_ANDESITE;
	RES_SECONDARY_RES_FREQUENCY[RES_STONE] = 15;

	RES_NAME[RES_BONE] = Db("Bone");
	RES_UNIT_STRING[RES_BONE] = Db("Bone");
	RES_LABEL_STRING[RES_BONE] = Db("Bone");
	RES_HARVEST_SOUND[RES_BONE] = SOUND_HARVEST_STONE;
	RES_SPAWNABLE[RES_BONE] = true;
	RES_TOTAL_AMOUNT[RES_BONE] = 100;
	RES_HARVESTING_TIMER[RES_BONE] = 128;
	RES_IMAGES[RES_BONE] = [601,602,603];

	RES_NAME[RES_ANDESITE] = Db("Andesite");
	RES_UNIT_STRING[RES_ANDESITE] = Db("Andesite formation");
	RES_LABEL_STRING[RES_ANDESITE] = Db("Andesite");
	RES_SPAWNABLE[RES_ANDESITE] = true;
	RES_IMAGES[RES_ANDESITE] = [604,605,606,604];
	RES_TOTAL_AMOUNT[RES_ANDESITE] = 100;
	RES_HARVESTING_TIMER[RES_ANDESITE] = 96;
