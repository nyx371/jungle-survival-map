	settbl(STRING_RESOURCE_LABEL, 0, "Resources:");

	foreach(unit : EUDLoopCUnit()) {
		if (unit.unitID == UNIT_TECH) {
			if (Rand(80)) {
				const biomeID = unit.hp/256;
				const technologyType = BIOME_ID_TECH_MAP[biomeID];
				const replacedUnit = ReplaceUnit(unit, UNIT_TECH);
				replacedUnit.hp = technologyType*256;
				replacedUnit.unknown0x106 = technologyType;
			} else {
				unit.remove();
			}
		} else if (unit.unitID == UNIT_MOB_SPAWNER) {
			ReplaceUnit(unit, UNIT_MOB_SPAWNER);
		} else if (unit.unitID == UNIT_CRITTER_SPAWNER) {
			unit.unknown0x26 = MOB_CRITTER_TYPES.length; // reset
			const mobID = unit.hp/256;
			const replacedUnit = ReplaceUnit(unit, UNIT_CRITTER_SPAWNER);			
			replacedUnit.unknown0x26 = mobID;
		}
	}	

	EUDPlayerLoop()();
	const playerID = getcurpl();
	if (playerID < $P6) {
		MobSpawnLimit++;
		SetAllianceStatus(PLAYER_SHARED_STRUCTURE, Ally);
		SetAllianceStatus(PLAYER_CRITTERS, Ally);
		AddPlayerResourceAmount(playerID, RES_BERRIES, 5, false);
		UpdatePlayerTooltips(playerID);
		PlayerEnergy[playerID] = CONST_HERO_ENERGY_MAX;
		const unit = CUnit.from_read(EPD(0x628438));
		PlayerHeroUnit[playerID] = unit;
		CreateUnit(1, UNIT_HERO, playerID+1, playerID); 
		// Auto mine
		unit.order = CONST_ORDER_MINE_NEARBY;
	}	
	EUDEndPlayerLoop();

	setcurpl($P6);
	SetAllianceStatus(PLAYER_SHARED_STRUCTURE, Enemy);
	SetAllianceStatus(PLAYER_CRITTERS, Ally);
	setcurpl($P7);
	SetAllianceStatus(PLAYER_SHARED_STRUCTURE, Enemy);	
	SetAllianceStatus(PLAYER_CRITTERS, Ally);	
	setcurpl(PLAYER_SHARED_STRUCTURE);
	SetAllianceStatus(17, Ally);
	SetAllianceStatus($P6, Enemy);
	SetAllianceStatus($P7, Enemy);
}


function GetBiomeWeighted(n) : EUDArray {
	var weightTotal = 0;
	for(var i = 0 ; i < BIOME_TYPE_WEIGHTS.length; i++) {
		weightTotal += BIOME_TYPE_WEIGHTS[i];
	}
	var weightRandom = dwrand() % weightTotal;
	for (var biomeType = 0; biomeType < BIOME_TYPES.length; biomeType++) {
		if (weightRandom < BIOME_TYPE_WEIGHTS[biomeType]) {
			if (BIOME_TYPE_SPAWN_COUNT[biomeType] >= BIOME_TYPE_MIN_SPAWN_COUNT[biomeType] && BIOME_TYPE_WEIGHTS[biomeType] > BIOME_TYPE_BOOST) {
				BIOME_TYPE_WEIGHTS[biomeType] -= BIOME_TYPE_BOOST;
			}
			BIOME_TYPE_SPAWN_COUNT[biomeType]++;
			return BIOME_TYPES[biomeType];
		}
		weightRandom -= BIOME_TYPE_WEIGHTS[biomeType];
	}
}

function SetupRandomizedBiomes() {
	// Keep HP/ID 0 for manually placed resources (BIOME_ROCKY_JUNGLE)
	for (var biomeIndex = 1; biomeIndex < BIOME_COUNT; biomeIndex++) {
		ModifyUnitHitPoints(1, UNIT_TECH, AllPlayers, BIOME_START_LOCATION_ID + biomeIndex, biomeIndex);
		ModifyUnitHitPoints(999, UNIT_RESOURCE_PLACEHOLDER1, AllPlayers, BIOME_START_LOCATION_ID + biomeIndex, biomeIndex);
	}
	BIOME_ID_TYPE_MAP[0] = BIOME_ROCKY_JUNGLE;

	if (BIOME_TEST_MODE) {
		for (var i = 0; i < BIOME_COUNT; i++) {
			BIOME_ID_TYPE_MAP[i] = BIOME_TEST_SETUP;
		}
		return;
	}
	for (var i = 1; i < BIOME_COUNT; i++) {
		BIOME_ID_TYPE_MAP[i] = GetBiomeWeighted(dwrand() % BIOME_TYPES.length+1);
	}
	// for (var i = 0; i < 1; i++) { BIOME_ID_TYPE_MAP[i] = BIOME_TEST_SETUP; }
}

function UpdatePortaitForPlayerHero(playerID) {
	if (!IsUserCP()) return;
	const portraitIndex = PlayerHeroPortraitIndex[playerID];
	wwrite(0x65FD00 + 12936 + UNIT_HERO * 2, CONST_PORTRAIT_OPTIONS[portraitIndex]);
	TalkingPortrait((177), 1);
}


function SwitchToNextHeroPortrait(playerID) {
	var portraitIndex = PlayerHeroPortraitIndex[playerID];
	if (portraitIndex >= CONST_PORTRAIT_OPTIONS.length - 1) portraitIndex = 0;
	else portraitIndex++;
	PlayerHeroPortraitIndex[playerID] = portraitIndex;
	UpdatePortaitForPlayerHero(playerID);
	PlayWAV("sound\\Misc\\Button.wav");
}

function GetLocationPoint(location) {
	const locTable = EPD(0x58DC4C);
	return dwread_epd(locTable + location * 5), dwread_epd(locTable + location * 5 + 1);
}

function SetButtonIcon(buttonSet, buttonIndex, iconID, state) {
	if (!IsUserCP()) return;
	var btnPtr = EPD(0x5187EC) + buttonSet * 3;
	dwadd_epd(btnPtr, 0);
	var btnPos = 5 * buttonIndex;
	btnPos += epdread_epd(btnPtr);

	var conditionValue;
	switch(state) {
		case BTN_HIDDEN: conditionValue = 5106496; break;
		case BTN_ENABLED: conditionValue = 4358864; break;
		case BTN_DISABLED: conditionValue = 4359904; break;
	}

	var oldCP = getcurpl();
		DoActions(list(
		SetMemory(0x6509B0, SetTo, btnPos),
		SetDeaths(CurrentPlayer, SetTo, (iconID * 65536), 0),
		SetMemory(0x6509B0, Add, 1),
		SetDeaths(CurrentPlayer, SetTo, conditionValue, 0),
		SetMemory(0x6509B0, Add, 1),
		//SetDeaths(CurrentPlayer, SetTo, actionPrefix, 0),
		SetMemory(0x6509B0, Add, 1),
		//SetDeaths(CurrentPlayer, SetTo, actionValue, 0),
		SetMemory(0x6509B0, Add, 1),
		//SetDeaths(CurrentPlayer, SetTo, stringID, 0),
		SetMemory(0x6509B0, SetTo, oldCP),
	));
}

function UnitIsStructure(unitID) {
	switch(unitID) {
		case STRU_WALL:
		case STRU_OWALL:
		case STRU_FURNACE:
		case STRU_LIGHTPOST:
		case STRU_TOWER:
		case STRU_GTRAP:
		case STRU_MTRAP:
		case STRU_WORKSTATION:
		case STRU_LAB:
		case STRU_CONVERTER:
		case STRU_GREENHOUSE:
		case STRU_MINERALDRILL:
		case STRU_GROWBED:
		case STRU_INCUBATOR:
		case STRU_STORAGE:
		case STRU_MININGBASE:
			return true;
	}
	return false;
}

function UpdateSelectedUnit(playerID) {
	const previouslySelectedUnit = CUnit.cast(PlayerSelectedUnit[playerID]);
	const unit = CUnit.from_read(EPD(SelectionAddresses[playerID]));
	if (unit != previouslySelectedUnit) {
		//Screen.printf("{}: {} --> {}: {}", previouslySelectedUnit.unitID, previouslySelectedUnit, unit.unitID, unit);
		PlayerSelectedUnit[playerID] = unit;		
		if (unit.unitID == UNIT_RESOURCE && PlayerSelectedResourceType[playerID] != unit.unknown0x106) {
			PlayerSelectedResourceType[playerID] = unit.unknown0x106;
			if (IsUserCP()) {
				settblf(STRING_RESOURCE_UNIT, 0, "{:s}", RES_UNIT_STRING[unit.unknown0x106]);
				settblf(STRING_RESOURCE_LABEL, 0, "{:s}:", RES_LABEL_STRING[unit.unknown0x106]);
			}
		} else if (unit.unitID == UNIT_HERO) {
			UpdatePortaitForPlayerHero(unit.playerID);
			if (IsUserCP()) {
				settblf(STRING_HERO_UNIT, 0, "{:n}", unit.playerID);
			}
			UpdatePlayerTooltips(playerID);
		} else if (unit.unitID == STRU_STORAGE) {
			UpdatePlayerTooltips(playerID);		
		} else if (STRU_DESCRIPTION[unit.unitID] != 0) {
			// Other units, compare unitID to structures etc
			if (IsUserCP()) {
				settblf(STRING_STRU_DESCRIPTION_LABEL, 0, "{:s}", STRU_DESCRIPTION[unit.unitID]);
			}
		}
	}
}

function SetUpgrade(playerID, upgradeID, level) {
	const rawUpgradeID = UPGR_UPGRADE[upgradeID];
	bwrite(0x58D2B0 + 0x207C * (rawUpgradeID / 46) + (playerID) * (46 - 31 * (rawUpgradeID / 46)) + (rawUpgradeID % 46), level);
}

function GetUpgrade(playerID, upgradeID) {
	const rawUpgradeID = UPGR_UPGRADE[upgradeID];
	return bread(0x58D2B0 + 0x207C * (rawUpgradeID / 46) + playerID * (46 - 31 * (rawUpgradeID / 46)) + (rawUpgradeID % 46));
}

function UpdatePlayerTooltips(playerID) {
	if (!IsUserCP()) return;

	const upgradeTooltipString = Db(512);
	//foreach(upgradeID : py_range(0, UPGR_COUNT)) { // TODO switch to this when building for release
	for (var upgradeID = 0; upgradeID < UPGR_COUNT; upgradeID++) {
		const upgradeLevel = GetUpgrade(playerID, upgradeID);
		if (UPGR_TOOLTIP[upgradeID] != 0) {
			sprintf(upgradeTooltipString, "{:s} Level {}/{}\nRequires:\n", UPGR_TOOLTIP[upgradeID], upgradeLevel + 1, UPGR_MAX_LEVEL[upgradeID]);
			for (var resourceType = 0; resourceType < RES_COUNT; resourceType++) {
				var cost = EUDArray.cast(UPGR_COST[upgradeID]).get(resourceType);
				cost += EUDArray.cast(UPGR_COST_INCREASE[upgradeID]).get(resourceType) * upgradeLevel;
				if (cost != 0) {
					const have = GetPlayerResourceAmount(playerID, resourceType);
					if (have >= cost) sprintf(upgradeTooltipString, "{:s}\x02- {} {:s} ({}/{})\n", upgradeTooltipString, cost, RES_NAME[resourceType], have, cost);
					else sprintf(upgradeTooltipString, "{:s}\x02- {} {:s} (\x11{}\x02/{})\n", upgradeTooltipString, cost, RES_NAME[resourceType], have, cost);
				}				
			}
			settblf(CONST_UPGR_STRING_START_INDEX + upgradeID, 0, "{:s}", upgradeTooltipString);
		}
	}

	const conversionTooltipString = Db(512);
	//foreach(conversionID : py_range(0, CONV_COUNT)) { // TODO switch to this when building for release
	for (var conversionID = 0; conversionID < CONV_COUNT; conversionID++) {
		if (CONV_TOOLTIP[conversionID] != 0) {
			sprintf(conversionTooltipString, "{:s}\nRequires:\n", CONV_TOOLTIP[conversionID]);
			for (var resourceType = 0; resourceType < RES_COUNT; resourceType++) {
				const cost = EUDArray.cast(CONV_RES_INPUTS[conversionID]).get(resourceType);
				if (cost != 0) {
					const have = GetPlayerResourceAmount(playerID, resourceType);
					if (have >= cost) sprintf(conversionTooltipString, "{:s}\x02- {} {:s} ({}/{})\n", conversionTooltipString, cost, RES_NAME[resourceType], have, cost);
					else sprintf(conversionTooltipString, "{:s}\x02- {} {:s} (\x11{}\x02/{})\n", conversionTooltipString, cost, RES_NAME[resourceType], have, cost);
				}				 
			}
			sprintf(conversionTooltipString, "{:s}\nProduces:\n", conversionTooltipString);
			for (var resourceType = 0; resourceType < RES_COUNT; resourceType++) {
				const qty = EUDArray.cast(CONV_RES_OUTPUTS[conversionID]).get(resourceType);
				const have = GetPlayerResourceAmount(playerID, resourceType);
				if (qty != 0) sprintf(conversionTooltipString, "{:s}\x02- {} {:s} ({})\n", conversionTooltipString, qty, RES_NAME[resourceType], have);
			}
			settblf(CONST_CONV_STRING_START_INDEX + conversionID, 0, "{:s}", conversionTooltipString);
		}
	}

	const structureTooltipString = Db(512);
	//foreach(structureType : py_range(0, STRU_COUNT)) { // TODO switch to this when building for release
	for (var structureType = 0; structureType < STRU_COUNT; structureType++) {
		if (STRU_TOOLTIP[structureType] != 0) {
			sprintf(structureTooltipString, "{:s}\nRequires:\n", STRU_TOOLTIP[structureType]);
			for (var resourceType = 0; resourceType < RES_COUNT; resourceType++) {
				const cost = EUDArray.cast(STRU_COST[structureType]).get(resourceType);
				if (cost != 0) {
					const have = GetPlayerResourceAmount(playerID, resourceType);
					if (have >= cost) sprintf(structureTooltipString, "{:s}\x02- {} {:s} ({}/{})\n", structureTooltipString, cost, RES_NAME[resourceType], have, cost);
					else sprintf(structureTooltipString, "{:s}\x02- {} {:s} (\x11{}\x02/{})\n", structureTooltipString, cost, RES_NAME[resourceType], have, cost);
				}
			}
			settblf(STRU_BUTTON_STRING[structureType], 0, "{:s}", structureTooltipString);
		}
	}

	const abilityTooltipString = Db(512);
	//foreach(abilityID : py_range(0, ABLT_COUNT)) { // TODO switch to this when building for release
	for (var abilityID = 0; abilityID < ABLT_COUNT; abilityID++) {
		if (ABLT_RESEARCH_TOOLTIP[abilityID] != 0) {
			sprintf(abilityTooltipString, "{:s}\nRequires:\n", ABLT_RESEARCH_TOOLTIP[abilityID]);
			for (var resourceType = 0; resourceType < RES_COUNT; resourceType++) {
				const cost = EUDArray.cast(ABLT_COST[abilityID]).get(resourceType);
				if (cost != 0) {
					const have = GetPlayerResourceAmount(playerID, resourceType);
					if (have >= cost) sprintf(abilityTooltipString, "{:s}\x02- {} {:s} ({}/{})\n", abilityTooltipString, cost, RES_NAME[resourceType], have, cost);
					else sprintf(abilityTooltipString, "{:s}\x02- {} {:s} (\x11{}\x02/{})\n", abilityTooltipString, cost, RES_NAME[resourceType], have, cost);
				}
			}
			settblf(CONST_ALBT_STRING_START_INDEX + abilityID, 0, "{:s}", abilityTooltipString);
		}
	}


	// TODO: Update Reignite tooltip
	{
		const restoreEnergyTooltipString = Db(512);
		const resourceType = RES_BERRIES;
		const cost = 1;
		const have = GetPlayerResourceAmount(playerID, RES_BERRIES);
		const energy = (RES_ENERGY_REGEN[RES_BERRIES] + RES_ENERGY_REGEN[RES_BERRIES] * GetUpgrade(playerID, UPGR_ENERGY)) / 256;
		if (have >= cost) sprintf(restoreEnergyTooltipString, "\x02- {} {:s} ({}/{})\n", cost, RES_NAME[resourceType], have, cost);
		else sprintf(restoreEnergyTooltipString, "\x02- {} {:s} (\x11{}\x02/{})\n", cost, RES_NAME[resourceType], have, cost);
		settblf(RESTORE_ENERGY_STRING_INDEX, 0, "q\x01(\x03Q\x01) Restore {} energy\nHealth regenerates slowly when you are Rested (>200 energy), and drains when you are Starving (0 energy)\nRequires:\n{:s}", energy, restoreEnergyTooltipString);
	}

	// Inventory & Storage
	const selectedUnit = CUnit(PlayerSelectedUnit[playerID]);
	const selectedUnitID = selectedUnit.unitID;
	if (selectedUnit.unitID == UNIT_HERO || selectedUnit.unitID == STRU_STORAGE) {
		const isInventory = selectedUnitID == UNIT_HERO ? true : false;
		const tooltipString = isInventory ? CONST_INV_TOOLTIP_STRING : CONST_STORAGE_TOOLTIP_STRING;
		if (selectedUnit.playerID == playerID) {
			const inventoryPlayerID = isInventory ? playerID : PLAYER_STORAGE;
			const inventoryPage = isInventory ? PlayerInventoryPage[playerID] : PlayerStoragePage[playerID];
			var inventoryLineCount = 0;
			if (isInventory) sprintf(INV_TOOLTIP_STRING, "\x04Inventory       pg. {}/{}\n", inventoryPage+1, CONST_INV_PAGES+1);
			else sprintf(INV_TOOLTIP_STRING, "\x04Storage       pg. {}/{}\n", inventoryPage+1, CONST_INV_PAGES+1);
			for (var resourceType = inventoryPage*INV_TOOLTIP_LINES; resourceType < RES_COUNT; resourceType++) {
				const resourceTypeCount = GetPlayerResourceAmount(inventoryPlayerID, resourceType);
				sprintf(INV_TOOLTIP_STRING, "{:s}\x02- {} {:s}\n", INV_TOOLTIP_STRING, resourceTypeCount, RES_NAME[resourceType]);
				inventoryLineCount++;
				if (inventoryLineCount >= INV_TOOLTIP_LINES) break;
			}
			settblf(tooltipString, 0, "{:s} \x03LClick \x04↓ \x03RClick \x04↑\x0C", INV_TOOLTIP_STRING);	
		} else {
			settblf(tooltipString, 0, "You cannot view other players' inventory.\x0C");
		}	
	}
}

function PlaySound(soundArray :EUDArray, playerID) {
	if (soundArray == 0) return;
	var index = PlayerSoundCycleCounter[playerID];
	StringBuffer.cast(soundArray[index]).Play();
	index++;
	if (index > 3) index = 0;
	PlayerSoundCycleCounter[playerID] = index;
}

function GiveUnit(unit : CUnit, playerID) {
	unit.setloc(LOC_REPLACE);
	GiveUnits(1, unit.unitID, unit.playerID, LOC_REPLACE, playerID);
}

function CreateCUnit(unitType, playerID, location) : CUnit {
	const newUnit = CUnit.from_read(EPD(0x628438));
	CreateUnit(1, unitType, location, playerID);
	return newUnit;
}

function CreateImageSpriteAtLocation(imageID, location) {
	SetMemoryX(0x00666458, SetTo, imageID, 0x0000ffff);
	CreateUnit(1, 33, location, $P8);
	RemoveUnit(33, AllPlayers);
	SetMemoryX(0x00666458, SetTo, 546, 0x0000ffff);
}

function CreateImageSpriteAtUnitLocalPlayer(imageID, unit: CUnit, playerID) {
	const prevPlayerID = getcurpl();
	setcurpl(playerID);
	unit.setloc(LOC_FX);
	SetMemoryX(0x00666458, SetTo, 503, 0x0000ffff);
	if (IsUserCP()) SetMemoryX(0x00666458, SetTo, imageID, 0x0000ffff);
	CreateUnit(1, 33, LOC_FX, $P8);
	RemoveUnit(33, AllPlayers);
	SetMemoryX(0x00666458, SetTo, 546, 0x0000ffff);
	setcurpl(prevPlayerID);
}

function CreateImageSpriteAtUnit(imageID, unit: CUnit) {
	unit.setloc(LOC_FX);
	CreateImageSpriteAtLocation(imageID, LOC_FX);
}

function DamageUnit(unit:CUnit, damage) {
	if (unit.hp < damage) unit.hp = 0;
	if (unit.hp == 0) unit.die();
	else unit.hp -= damage;
}

function HealUnit(unit:CUnit, heal, maxHP) {
	if (unit.hp + heal > maxHP) unit.hp = maxHP;
	else unit.hp += heal;
}

function HealUnitEnergy(unit:CUnit, heal, maxHP) {
	if (unit.energy + heal > maxHP) unit.energy = maxHP;
	else unit.energy += heal;
}

function ReplaceUnit(unit:CUnit, unitType) : CUnit {
	return ReplaceUnitWithOffset(unit, unitType, 0);
}
function ReplaceUnitWithOffset(unit:CUnit, unitType, yOffset) : CUnit {
	unit.setloc(LOC_REPLACE);
	const playerID = unit.playerID;
	RemoveUnitAt(1, unit.unitType, LOC_REPLACE, playerID);
	const newUnit = CUnit.from_read(EPD(0x628438));
	if (yOffset != 0) addloc(LOC_REPLACE, 0, yOffset);
	CreateUnit(1, unitType, LOC_REPLACE, playerID);
	return newUnit;
}

function CreateOverlayUnitWithRemoveTimer(unit:CUnit, imageID, playerID, removeTimer) : CUnit {
	if (unit.connectedUnit) unit.connectedUnit.remove();
	unit.setloc(LOC_REPLACE);
	const newUnit = CUnit.from_read(EPD(0x628438));
	wwrite(0x665AC0 + 1696 + SPRITE_OVERLAY * 2, imageID);
	CreateUnit(1, UNIT_OVERLAY, LOC_REPLACE, playerID);
	if (removeTimer != 0) newUnit.removeTimer = removeTimer;
	newUnit.set_noclip();
	newUnit.remove_collision();
	newUnit.connectedUnit = unit;
	unit.connectedUnit = newUnit;
	return newUnit;
}

function CreateOverlayUnit(unit:CUnit, imageID, playerID) : CUnit {
	return CreateOverlayUnitWithRemoveTimer(unit, imageID, playerID, 0);
}

function UpdateBrightness(playerID) {
	MoveLocation(LOC_SCREEN, UNIT_HERO, playerID, LOC_ANYWHERE);
	var lightSources = 0;
	var targetBrightness = DEFAULT_DAY_LIGHT;
	if (Night) {		
		if (Bring(AllPlayers, AtLeast, 4, UNIT_LIGHT_OVERLAY, LOC_SCREEN)) targetBrightness = DEFAULT_NIGHT_LIGHT_L4;
		else if (Bring(AllPlayers, AtLeast, 3, UNIT_LIGHT_OVERLAY, LOC_SCREEN)) targetBrightness = DEFAULT_NIGHT_LIGHT_L3;
		else if (Bring(AllPlayers, AtLeast, 2, UNIT_LIGHT_OVERLAY, LOC_SCREEN)) targetBrightness = DEFAULT_NIGHT_LIGHT_L2;
		else if (Bring(AllPlayers, AtLeast, 1, UNIT_LIGHT_OVERLAY, LOC_SCREEN)) targetBrightness = DEFAULT_NIGHT_LIGHT_L1;
		else if (Bring(AllPlayers, Exactly, 0, UNIT_LIGHT_OVERLAY, LOC_SCREEN)) targetBrightness = DEFAULT_NIGHT_LIGHT_MIN;
	}
	if (PlayerLight[playerID] > targetBrightness) PlayerLight[playerID]--;
	else if (PlayerLight[playerID] < targetBrightness) PlayerLight[playerID]++;
	if (IsUserCP()) SetMemoryEPD(EPD(0x657A9C), SetTo, PlayerLight[playerID]);
}

function UpdateHints(realHours) {
	once(realHours >= 8) {
		printAllAt(0,"\x13\x07HINT:\x02 Keep track of your energy. If it drops to 0 you will start starving.\n\x13Consume Berries to regenerate energy.");
		PlayWAVAll("sound\\Misc\\Transmission.wav");
	}

	once(realHours >= 10) {
		printAllAt(0,"\x13\x07HINT:\x02 The clock at the top of the screen displays the current time.\n\x13The sun sets at 10PM");
		PlayWAVAll("sound\\Misc\\Transmission.wav");
	}

	once(realHours >= 12) {
		printAllAt(0,"\x13\x07HINT:\x02 Click the Help icon in the bottom right corner for help");
		PlayWAVAll("sound\\Misc\\Transmission.wav");
	}

	once(realHours >= 16) {
		printAllAt(0,"\x13\x07HINT:\x02 The sun will set at 10PM - Make sure you plan\n\x13for how you will shelter during night.");
		PlayWAVAll("sound\\Misc\\Transmission.wav");
	}

	once(realHours >= 21) {
		printAllAt(0,"\x13\x07HINT:\x02 Nightfall is upon us. Take shelter if you haven't already.");
		PlayWAVAll("sound\\Misc\\Transmission.wav");
	}

	once(Day >= 2 && realHours >= 7) {
		printAllAt(0,"\x13\x07HINT:\x02 Explore far and wide during the day to find new resources and technology.");
		PlayWAVAll("sound\\Misc\\Transmission.wav");
	}

	once (Command(AllPlayers, AtLeast, 1, STRU_FURNACE)) {
		printAllAt(0,"\x13\x07HINT:\x02 The Furnace rejuvenates energy for all allied survivors around it.");
		PlayWAVAll("sound\\Misc\\Transmission.wav");
	}

	once (Command(AllPlayers, AtLeast, 1, STRU_WALL)) {
		printAllAt(0,"\x13\x07HINT:\x02 Structures are shared between players.\n\x13The player that's closest to a structure controls it.");
		PlayWAVAll("sound\\Misc\\Transmission.wav");
	}
}

function UpdateTime() {
	if (Time >= CONST_CYCLE_LENGTH_FRAMES) Time = 0;
	else Time += 1;

	var realHours, frameMinutes = div(Time,CONST_CYCLE_LENGTH_FRAMES/24);
	var clockMinutes = frameMinutes * 60 / (CONST_CYCLE_LENGTH_FRAMES/24);
	var clockHours;
	
	AM = realHours < 12 ? true : false;
	// Check for Midnight/Noon
	if (realHours % 12 == 0) {
		clockHours = 12;
	} else {
		clockHours = realHours % 12;
	}

	var dayNightCycleDidChange = false;	
	//Screen.printfAt(4, "IsNight: {} IsAM: {} Time: {}/{} clockTime: ({}){}:{} ", Night, AM, Time, CONST_CYCLE_LENGTH_FRAMES, realHours, clockHours, clockMinutes);
	if (!Night && realHours >= CONST_DAY_NIGHT_START) {
		Night = true;
		dayNightCycleDidChange = true;
	} else if (Night && AM && realHours >= CONST_DAY_HOUR_START) {
		Night = false;
		dayNightCycleDidChange = true;
		Day++;
		MobSpawnLimit++;
		MobAggroRange = (CONST_MOB_AGGRO_RANGE_MIN_TILES + Day) * TILE;
	}

	// Set Clock
	SetCountdownTimer(SetTo, (clockHours * 60) + clockMinutes);
	// Hero vision range
	if (Night && bread(0x65FD00 + 13624 + UNIT_HERO) != 2) bwrite(0x65FD00 + 13624 + UNIT_HERO, 2);
	else if (!Night && bread(0x65FD00 + 13624 + UNIT_HERO) != 11) bwrite(0x65FD00 + 13624 + UNIT_HERO, 11);

	if (dwread(0x51CE98) == 0) dwwrite(0x51CE98, 1);
	else dwwrite(0x51CE98, 1);
	UpdateHints(realHours);
	return dayNightCycleDidChange;
}

function GetStructureResourceCost(structureType, resourceType) {
	return EUDArray.cast(STRU_COST[structureType]).get(resourceType);
}

function GetPlayerResourceAmount(playerID, resourceType) {
	return EUDArray.cast(PlayerResources[playerID]).get(resourceType);
}

function SetPlayerResourceAmount(playerID, resourceType, amount) {
	EUDArray.cast(PlayerResources[playerID]).set(resourceType, amount);
}

function AddPlayerResourceAmountMulti(playerID, resourceType, amount, resourceType2, amount2, display) {
	EUDArray.cast(PlayerResources[playerID]).iadditem(resourceType, amount);
	if (amount2 > 0) EUDArray.cast(PlayerResources[playerID]).iadditem(resourceType2, amount2);
	
	if (display) {
		const prevplayer = getcurpl();
		setcurpl(playerID);		
		if (amount2 > 0) eprintf("\x04+ {} {:s} ({}), {} {:s} ({})", amount, RES_NAME[resourceType], GetPlayerResourceAmount(playerID, resourceType), amount2, RES_NAME[resourceType2], GetPlayerResourceAmount(playerID, resourceType2));
		else eprintf("\x04+ {} {:s} ({})", amount, RES_NAME[resourceType], GetPlayerResourceAmount(playerID, resourceType));
		PlayWAV("staredit\\wav\\pop.ogg");
		setcurpl(prevplayer);
	}
	UpdatePlayerTooltips(playerID);
}

function AddPlayerResourceAmount(playerID, resourceType, amount, display) {
	AddPlayerResourceAmountMulti(playerID, resourceType, amount, RES_COUNT, 0, display);
}

function AddPlayerMobLoot(playerID, mobID) {
	if (playerID > 7) return;
	for (var resourceType = 0; resourceType < RES_COUNT; resourceType++) {
		const resource1Amount = EUDArray.cast(MOB_LOOT_1[mobID]).get(resourceType);
		if (resource1Amount != 0) {
			AddPlayerResourceAmount(playerID, resourceType, resource1Amount, true);
		}
		const resource2Amount = EUDArray.cast(MOB_LOOT_2[mobID]).get(resourceType);
		if (resource2Amount != 0 && Rand(MOB_LOOT_2_CHANCE[mobID])) {
			AddPlayerResourceAmount(playerID, resourceType, resource2Amount, true);
		}
	}
}

function PlayerHasTechnology(playerID, technologyType) {
	return EUDArray.cast(PlayerTechnology[playerID]).get(technologyType) == 1 ? true : false;
}

function AddPlayerTechnology(playerID, technologyType, display) {	
	if (EUDArray.cast(PlayerTechnology[playerID]).get(technologyType) != 1) {
		EUDArray.cast(PlayerTechnology[playerID]).set(technologyType, 1);
		bwrite(0x58CF44 + 0x21FC * ((technologyType) / 24) + (playerID) * (24 - 4 * ((technologyType) / 24)) + ((technologyType) % 24), 1);
		if (display) {
			const prevplayer = getcurpl();
			setcurpl(playerID);
			Screen.printf("Blueprint acquired: \x03{:s}\x01 - {:s}", TECH_STRING[technologyType], TECH_DESCRIPTION[technologyType]);
			PlayWAV("sound\\Misc\\TRescue.wav");
			setcurpl(prevplayer);
		}
	} else {
		if (display) {
			const prevplayer = getcurpl();
			setcurpl(playerID);
			Screen.printf("You already have blueprint for: \x03{:s}", TECH_STRING[technologyType]);
			//PlayWAV
			setcurpl(prevplayer);
		}
	}
}

function SubtractPlayerResourceAmount(playerID, resourceType, amount) {
	if (amount == 0) return;
	EUDArray.cast(PlayerResources[playerID]).isubitem(resourceType, amount);
	//Screen.printf("subtr {} {:s}", amount, RES_NAME[resourceType]);
	UpdatePlayerTooltips(playerID);
}

function ValidatePlayerResourceAmount(playerID, resourceType, amount) {
	if (amount == 0) return true;
	if (EUDArray.cast(PlayerResources[playerID]).get(resourceType) >= amount) return true;
	else return false;
}

function TransferResourceAmount(sendingPlayerID, receivingPlayerID, resourceType, amount, display) {
	if (amount == 0) return;
	if (ValidatePlayerResourceAmount(sendingPlayerID, resourceType, amount)) {		
		EUDArray.cast(PlayerResources[sendingPlayerID]).isubitem(resourceType, amount);
		AddPlayerResourceAmount(receivingPlayerID, resourceType, amount, display);
	}
}


function ValidateCostMulti(playerID, costArray:EUDArray, display, multiples) {
	var valid = true;
	for (var resourceType = 0; resourceType < RES_COUNT; resourceType++) {
		const amount = EUDArray.cast(costArray).get(resourceType);
		if (amount > 0 && ValidatePlayerResourceAmount(playerID, resourceType, amount*multiples) == false) {
			valid = false;
			break;
		}
	}
	if (!valid && display) eprintln("\x04Not enough resources");
	return valid;
}

function ValidateCostIncreaseMulti(playerID, baseCostArray:EUDArray, increaseCostArray:EUDArray, display, multiples) {
	var valid = true;
	for (var resourceType = 0; resourceType < RES_COUNT; resourceType++) {
		var amount = EUDArray.cast(baseCostArray).get(resourceType);
		amount += EUDArray.cast(increaseCostArray).get(resourceType) * multiples;
		if (amount > 0) {
			if (ValidatePlayerResourceAmount(playerID, resourceType, amount) == false) {
				valid = false;
				break;
			}
		}
	}
	if (!valid && display) eprintln("\x04Not enough resources");
	return valid;
}

function ValidateCost(playerID, costArray:EUDArray, display) {
	return ValidateCostMulti(playerID, costArray, display, 1);
}

function ProcessCostMulti(playerID, costArray:EUDArray, multiples) {
	for (var resourceType = 0; resourceType < RES_COUNT; resourceType++) {
		SubtractPlayerResourceAmount(playerID, resourceType, EUDArray.cast(costArray).get(resourceType) * multiples);
	}
}

function ProcessCost(playerID, costArray:EUDArray) {
	return ProcessCostMulti(playerID, costArray, 1);
}

function ProcessResourceConversion(playerID, conversionID) {
	if (ValidateCost(playerID, CONV_RES_INPUTS[conversionID], true)) {		
		ProcessCost(playerID, CONV_RES_INPUTS[conversionID]);
		for (var resourceType = 0; resourceType < RES_COUNT; resourceType++) {
			const qty = EUDArray.cast(CONV_RES_OUTPUTS[conversionID]).get(resourceType);
			if (qty != 0) AddPlayerResourceAmount(playerID, resourceType, qty, true);
		}
		PlayWAV("sound\\Terran\\SCV\\TScTra00.wav");
		eprintln("\x04Resource conversion complete");
	}
}

function ProcessUpgrade(playerID, upgradeID, buttonSet, buttonIndex) {
	const upgradeLevel = GetUpgrade(playerID, upgradeID);
	const rawUpgradeID = UPGR_UPGRADE[upgradeID];
	const amount = 1;
	if (upgradeLevel+1 < UPGR_MAX_LEVEL[upgradeID]) {
		if (ValidateCostIncreaseMulti(playerID, UPGR_COST[upgradeID], UPGR_COST_INCREASE[upgradeID], true, upgradeLevel)) {
			SetMemoryEPD(EPD(0x58D2B0 + 0x207C * (rawUpgradeID / 46) + playerID * (46 - 31 * (rawUpgradeID / 46)) + (rawUpgradeID % 46)), (8), bitlshift(amount, 8 * ((playerID * (46 - 31 * (rawUpgradeID / 46)) + (rawUpgradeID % 46)) % 4)));
			ProcessCost(playerID, UPGR_COST[upgradeID]);	
			ProcessCostMulti(playerID, UPGR_COST_INCREASE[upgradeID], upgradeLevel);
			PlayWAV("sound\\Terran\\SCV\\TScTra00.wav");
			eprintln("\x04Upgrade complete");
			if (upgradeLevel+2 >= UPGR_MAX_LEVEL[upgradeID]) SetButtonIcon(buttonSet, buttonIndex, 0, BTN_HIDDEN);
		}
	} else {
		eprintln("\x04Upgrade at max level");
	}
}

function AddResourceToConsume(playerID, structureType) {
	for (var resourceType = 0; resourceType < RES_COUNT; resourceType++) {
		EUDArray.cast(PlayerResourcesToConsume[playerID]).set(resourceType, GetStructureResourceCost(structureType, resourceType));
	}
}

function SettleResourceToConsume(playerID) {
	for (var resourceType = 0; resourceType < RES_COUNT; resourceType++) {
		SubtractPlayerResourceAmount(playerID, resourceType, EUDArray.cast(PlayerResourcesToConsume[playerID]).get(resourceType));
	}
}

function EnableAbility(playerID, abilityID, display) {
	if (display) Screen.printf("Suit ability enabled \x02{:s}", ABLT_TOOLTIP[abilityID]);
	if (ABLT_TYPE[abilityID] == ABLT_TYPE_SELFCAST) EUDArray.cast(PlayerSelfAbilitiesAvailable[playerID]).set(abilityID, 1);
	else EUDArray.cast(PlayerTargetAbilitiesAvailable[playerID]).set(abilityID, 1);
	SelectAbility(playerID, abilityID);
}

function SelectAbility(playerID, abilityID) {
	if (abilityID >= ABLT_COUNT) return;
	
	//if (ABLT_TYPE[abilityID] == ABLT_TYPE_SELFCAST) Screen.printf("Self {} -> {}", PlayerSelfAbilityID[playerID], abilityID);
	//else Screen.printf("Target {} -> {}", PlayerTargetAbilityID[playerID], abilityID);

	if (ABLT_TYPE[abilityID] == ABLT_TYPE_SELFCAST) PlayerSelfAbilityID[playerID] = abilityID;
	else PlayerTargetAbilityID[playerID] = abilityID;
}

function ValidateAbilityEnergy(playerID, abilityID) {
	if (PlayerEnergy[playerID] >= ABLT_ENERGY_COST[abilityID]) return true;
	else {
		eprintln("\x04Not enough energy");
		return false;
	}
}

function CastSelfAbility(playerID) {
	const abilityID = PlayerSelfAbilityID[playerID];
	if (abilityID >= ABLT_COUNT) return;
	const heroUnit = CUnit(PlayerHeroUnit[playerID]);
	//Screen.printf("CastSelfAbility id {} playerID {}", abilityID, playerID);
	var abilityCasted = false;
	switch(abilityID) {
		case ABLT_SELF_HEAL:		
			heroUnit.hp = CONST_HERO_HP_MAX;
			CreateImageSpriteAtUnit(967, heroUnit);
			abilityCasted = true;
			break;
		case ABLT_SELF_SHIELD:
			CreateOverlayUnitWithRemoveTimer(heroUnit, 371, $P8, ABLT_TIMER[abilityID]);
			abilityCasted = true;
			break;
		case ABLT_SELF_MINESPEED:
			heroUnit.order = CONST_ORDER_MINE_NEARBY;
			abilityCasted = true;
			break;
		case ABLT_SELF_VISION:
			CreateOverlayUnitWithRemoveTimer(heroUnit, 546, playerID, ABLT_TIMER[abilityID]);
			abilityCasted = true;
			break;
		case ABLT_SELF_RECALL:
			CreateImageSpriteAtUnit(391, heroUnit);
			MoveUnit(1, UNIT_HERO, playerID, LOC_ANYWHERE, playerID+1);
			CreateImageSpriteAtUnit(391, heroUnit);
			abilityCasted = true;
			break;
		case ABLT_SELF_DROIDS:
			for (var i = 0; i < 3; i++) {
				heroUnit.setloc(LOC_REPLACE);
				const droidUnit = CreateCUnit(UNIT_DROID, playerID, LOC_REPLACE);
				droidUnit.remove_collision();
				droidUnit.removeTimer = ABLT_TIMER[abilityID];
				droidUnit.parent = heroUnit;
			}
			abilityCasted = true;
			break;
	}
	if (abilityCasted) {		
		PlayerEnergy[playerID] -= ABLT_ENERGY_COST[abilityID];
		PlayerSelfAbilityTimer[playerID] = ABLT_TIMER[abilityID];
		PlayerSelfAbilityCooldown[playerID] = ABLT_COOLDOWN[abilityID];
		if (ABLT_ACTIVATE_SOUND[abilityID] != 0) StringBuffer.cast(ABLT_ACTIVATE_SOUND[abilityID]).Play();
	}
}

function CastTargetAbility(playerID, targetUnit: CUnit, x, y) {	
	const abilityID = PlayerTargetAbilityID[playerID];
	//Screen.printf("CastTargetAbility {}", abilityID);
	if (abilityID >= ABLT_COUNT) return;
	const heroUnit = CUnit(PlayerHeroUnit[playerID]);
	var abilityCasted = false;
	switch(abilityID) {
		case ABLT_TARGET_STUN:
			if (targetUnit.playerID >= $P6 && targetUnit.unitID != UNIT_RESOURCE) {
				targetUnit.lockdownTimer = ABLT_TIMER[abilityID]/8;
				CreateOverlayUnitWithRemoveTimer(targetUnit, 361, $P8, ABLT_TIMER[abilityID]);
				abilityCasted = true;
			} else eprintln("\x04Invalid target. Must target enemy or neutral units.");
			break;
		case ABLT_TARGET_DAMAGE:
			if (targetUnit.playerID >= $P6) {
				DamageUnit(targetUnit, 50*256);
				abilityCasted = true;
				CreateImageSpriteAtUnit(281, targetUnit);
			} else eprintln("\x04Invalid target. Must target enemy or neutral units.");
			break;
		case ABLT_TARGET_REGROW:
			if (targetUnit.unitID == UNIT_RESOURCE && (targetUnit.unknown0x106 == RES_LEAVES || targetUnit.unknown0x106 == RES_WOOD)) {
				targetUnit.resourceAmount = RES_TOTAL_AMOUNT[targetUnit.unknown0x106];
				abilityCasted = true;
				CreateImageSpriteAtUnit(368, targetUnit);
			} else eprintln("\x04Invalid target. Must target a tree or bush resource node.");
			break;
		case ABLT_TARGET_SLOW:
			if (targetUnit.playerID >= $P6 && targetUnit.unitID != UNIT_RESOURCE) {
				targetUnit.ensnareTimer = ABLT_TIMER[abilityID]/8;				
				abilityCasted = true;
				CreateOverlayUnitWithRemoveTimer(targetUnit, 385, $P8, ABLT_TIMER[abilityID]);
			} else eprintln("\x04Invalid target. Must target enemy or neutral units.");
			break;
		case ABLT_TARGET_BLINK:
			CreateImageSpriteAtUnit(545, heroUnit);
			setloc(LOC_FX, x, y);
			MoveUnit(1, UNIT_HERO, playerID, LOC_ANYWHERE, LOC_FX);
			Order(UNIT_HERO, playerID, LOC_ANYWHERE, Move, LOC_FX);
			CreateImageSpriteAtUnit(545, heroUnit);
			abilityCasted = true;
			break;
	}
	if (abilityCasted) {
		PlayerEnergy[playerID] -= ABLT_ENERGY_COST[abilityID];
		PlayerTargetAbilityTimer[playerID] = ABLT_TIMER[abilityID];
		PlayerTargetAbilityCooldown[playerID] = ABLT_COOLDOWN[abilityID];
		if (ABLT_ACTIVATE_SOUND[abilityID] != 0) StringBuffer.cast(ABLT_ACTIVATE_SOUND[abilityID]).Play();
	}
}

function HandleSelfAbility(playerID) {
	if (PlayerSelfAbilityCooldown[playerID] > 0) PlayerSelfAbilityCooldown[playerID]--;
	const unit = CUnit(PlayerHeroUnit[playerID]);
	const abilityID = PlayerSelfAbilityID[playerID];
	const abilityTimer = PlayerSelfAbilityTimer[playerID];
	if (PlayerSelfAbilityTimer[playerID] == 1 && ABLT_DEACTIVATE_SOUND[abilityID] != 0) StringBuffer.cast(ABLT_DEACTIVATE_SOUND[abilityID]).Play();
	switch(abilityID) {
		case ABLT_SELF_SPEED:
			if (PlayerSelfAbilityTimer[playerID] > 1) unit.topSpeed = CONST_ABLT_SELF_SPEED_FAST;
			else if (PlayerSelfAbilityTimer[playerID] == 1) unit.topSpeed = CONST_ABLT_SELF_SPEED_DEFAULT;
			if (PlayerSelfAbilityTimer[playerID] > 0 && unit.currentSpeed1 > 0) CreateImageSpriteAtUnit(441, unit);
			break;
		case ABLT_SELF_SHIELD:
			if (PlayerSelfAbilityTimer[playerID] > 1) {
				unit.defensiveMatrixHp = CONST_HERO_HP_MAX;
				unit.defensiveMatrixTimer = 10;
			}
			else if (PlayerSelfAbilityTimer[playerID] == 1) {
				unit.defensiveMatrixHp = 0;
				unit.defensiveMatrixTimer = 0;
			}
			break;
		case ABLT_SELF_MINESPEED:			
			if (PlayerSelfAbilityTimer[playerID] > 1
				&& unit.targetResourceUnit != 0
				&& (unit.order == CONST_ORDER_MINE || unit.order == CONST_ORDER_MINE_NEARBY)
				&& unit.orderTimer > CONST_MINESPEED_TIMER) {
				unit.orderTimer = CONST_MINESPEED_TIMER;
				CreateImageSpriteAtUnit(520, unit.targetResourceUnit);
			}
			break;
		case ABLT_SELF_VISION:
			// Set brighter light
			break;
	}

	// Cleanup
	if (abilityID != ABLT_SELF_SPEED && unit.topSpeed != CONST_ABLT_SELF_SPEED_DEFAULT) unit.topSpeed = CONST_ABLT_SELF_SPEED_DEFAULT;

	if (PlayerSelfAbilityTimer[playerID] > 0) PlayerSelfAbilityTimer[playerID]--;
}

function HandleTargetAbility(playerID) {
	if (PlayerTargetAbilityCooldown[playerID] > 0) PlayerTargetAbilityCooldown[playerID]--;
	const unit = CUnit(PlayerHeroUnit[playerID]);
	const abilityID = PlayerTargetAbilityID[playerID];
	const abilityTimer = PlayerTargetAbilityTimer[playerID];
	//if (PlayerTargetAbilityTimer[playerID] == 1 && ABLT_DEACTIVATE_SOUND[abilityID] != 0) StringBuffer.cast(ABLT_DEACTIVATE_SOUND[abilityID]).Play();
	switch(abilityID) {

	}
	if (PlayerTargetAbilityTimer[playerID] > 0) PlayerTargetAbilityTimer[playerID]--;
}

function ProcessAbilityResearch(playerID, abilityID, buttonSet, buttonIndex) {
	if (ValidateCost(playerID, ABLT_COST[abilityID], true)) {		
		ProcessCost(playerID, ABLT_COST[abilityID]);
		SetButtonIcon(buttonSet, buttonIndex, ABLT_ICON[abilityID], BTN_HIDDEN);
		EnableAbility(playerID, abilityID, true);
		PlayWAV("sound\\Terran\\SCV\\TScTra00.wav");
		eprintln("\x04Research complete");
	}
}

function ProcessStorageTransfer(insert, playerID, resourceType, amount) {
	if (insert) {
		if (ValidatePlayerResourceAmount(playerID, resourceType, amount)) {
			TransferResourceAmount(playerID, PLAYER_STORAGE, resourceType, amount, false);
			eprintf("\x04Transferred {} {:s} to storage. ({} in total)", amount, RES_NAME[resourceType], GetPlayerResourceAmount(PLAYER_STORAGE, resourceType));
		} else {
			eprintln("\x04Not enough resources");
		}
	} else {
		if (ValidatePlayerResourceAmount(PLAYER_STORAGE, resourceType, amount)) {
			TransferResourceAmount(PLAYER_STORAGE, playerID, resourceType, amount, false);
			eprintf("\x04Retreived {} {:s} from storage. ({} left)", amount, RES_NAME[resourceType], GetPlayerResourceAmount(PLAYER_STORAGE, resourceType));
		} else {
			eprintf("\x04No {:s} left in storage", RES_NAME[resourceType]);
		}
	}
	UpdatePlayerTooltips(playerID);
}

function HandleDevCommands(playerID) {
	if (PlayerFKeyDown[playerID] && PlayerCtrlKeyPress[playerID]) {
		PlayerScreenFollowDisabled[playerID] = !PlayerScreenFollowDisabled[playerID];
	}
	if (PlayerF7KeyDown[playerID]) {
		for (var i = 0; i < RES_COUNT; i++) {
			EUDArray.cast(PlayerResources[playerID]).iadditem(i, 100);
			eprintln("\x04Cheat enabled");
		}
		if (PlayerShiftKeyPress[playerID]) {
			for (var technologyType = 0; technologyType < TECH_COUNT; technologyType++) {
				AddPlayerTechnology(playerID, technologyType, false);
			}
			if (PlayerCtrlKeyPress[playerID]) {
				for (var abilityID = 0; abilityID < ABLT_COUNT; abilityID++) {
					EnableAbility(playerID, abilityID, false);
				}
			}
		}
	} else if (PlayerF8KeyDown[playerID]) {
		PlayerDebugMode[playerID] = !PlayerDebugMode[playerID];
	} else if (PlayerF9KeyDown[playerID]) {
		if (PlayerF9KeyDown[playerID]) {
			if (PlayerShiftKeyPress[playerID]) {
				MoveUnit(1, UNIT_HERO, playerID, LOC_ANYWHERE, LOC_DEV_AREA);
			} else {
				Time += CONST_CYCLE_LENGTH_FRAMES/24;
			}
		}
	} else if (PlayerF12KeyDown[playerID]) {
		for (var i = 0; i < SPAWNER_TIERS.length; i++) {
			CreateUnit(4, SPAWNER_TIERS[i], $L("SpawnArea"), playerID);
		}
	}
}

function UpdatePlayerInterface(playerID, selectedUnit:CUnit, updateButtons) {
	if (!IsUserCP()) return;

	if (updateButtons) {		
		const selfAbilityID = PlayerSelfAbilityID[playerID];
		if (selfAbilityID < ABLT_COUNT) {
			if (PlayerSelfAbilityCooldown[playerID] == 0) {
				if (ABLT_TOOLTIP[selfAbilityID] != 0) settblf(1000, 0, "{:s}{:s}\nEnergy: {}\n{:s}", ABLT_SELF_TOOLTIP_PREFIX, ABLT_TOOLTIP[selfAbilityID], ABLT_ENERGY_COST[selfAbilityID]/256, ABLT_TOOLTIP_SUFFIX);
				SetButtonIcon(UNIT_HERO, CONST_SELF_ABILITY_BTN_INDEX, ABLT_ICON[selfAbilityID], BTN_ENABLED);
			} else {
				if (ABLT_TOOLTIP[selfAbilityID] != 0) settblf(1001, 0, "{:s}{:s}\nEnergy: {}\n{:s}{}", ABLT_SELF_TOOLTIP_CD_PREFIX, ABLT_TOOLTIP[selfAbilityID], ABLT_ENERGY_COST[selfAbilityID]/256, ABLT_TOOLTIP_CD_SUFFIX, PlayerSelfAbilityCooldown[playerID]/24);
				SetButtonIcon(UNIT_HERO, CONST_SELF_ABILITY_BTN_INDEX, ABLT_ICON[selfAbilityID], BTN_DISABLED);
			}
		} else {
			SetButtonIcon(UNIT_HERO, CONST_SELF_ABILITY_BTN_INDEX, 0, BTN_HIDDEN);
		}
		const targetAbilityID = PlayerTargetAbilityID[playerID];
		if (targetAbilityID < ABLT_COUNT) {
			if (PlayerTargetAbilityCooldown[playerID] == 0) {
				if (ABLT_TOOLTIP[targetAbilityID] != 0) settblf(1002, 0, "{:s}{:s}\nEnergy: {}\n{:s}", ABLT_TARGET_TOOLTIP_PREFIX, ABLT_TOOLTIP[targetAbilityID], ABLT_ENERGY_COST[targetAbilityID]/256, ABLT_TOOLTIP_SUFFIX);
				SetButtonIcon(UNIT_HERO, CONST_TARGET_ABILITY_BTN_INDEX, ABLT_ICON[targetAbilityID], BTN_ENABLED);
			} else {
				if (ABLT_TOOLTIP[targetAbilityID] != 0) settblf(1003, 0, "{:s}{:s}\nEnergy: {}\n{:s}{}", ABLT_TARGET_TOOLTIP_CD_PREFIX, ABLT_TOOLTIP[targetAbilityID], ABLT_ENERGY_COST[targetAbilityID]/256, ABLT_TOOLTIP_CD_SUFFIX, PlayerTargetAbilityCooldown[playerID]/24);
				SetButtonIcon(UNIT_HERO, CONST_TARGET_ABILITY_BTN_INDEX, ABLT_ICON[targetAbilityID], BTN_DISABLED);
			}
		} else {
			SetButtonIcon(UNIT_HERO, CONST_TARGET_ABILITY_BTN_INDEX, 0, BTN_HIDDEN);
		}
	}

	// Player status
	settblf(STRING_HERO_DESCRIPTION_LABEL, 0, "{:s}", STATUS_STRINGS[PlayerStatus[playerID]]);

	if (selectedUnit.unitID == UNIT_HERO && selectedUnit.playerID == playerID) {
		const mouseX = dwread(0x6CDDC4);
		const mouseY = dwread(0x6CDDC8);
		const mid = PlayerScreenWidth[playerID] / 2;
		if ((mouseX >= mid && mouseX <= mid+36) && (mouseY >= 438 && mouseY <= 438+36)) {
			if (PlayerLMouseDown[playerID]) {
				PlayWAV("sound\\Misc\\Button.wav");
				if (PlayerInventoryPage[playerID] >= CONST_INV_PAGES) PlayerInventoryPage[playerID] = 0;
				else PlayerInventoryPage[playerID]++;
				UpdatePlayerTooltips(playerID);
			}
			if (PlayerRMouseDown[playerID]) {
				PlayWAV("sound\\Misc\\Button.wav");
				if (PlayerInventoryPage[playerID] <= 0) PlayerInventoryPage[playerID] = CONST_INV_PAGES-1;
				else PlayerInventoryPage[playerID]--;
				UpdatePlayerTooltips(playerID);
			}
		}
	} else if (selectedUnit.unitID == STRU_STORAGE && selectedUnit.playerID == playerID) {
		const mouseX = dwread(0x6CDDC4);
		const mouseY = dwread(0x6CDDC8);
		const mid = PlayerScreenWidth[playerID] / 2;
		if ((mouseX >= mid-36 && mouseX <= mid) && (mouseY >= 438 && mouseY <= 438+36)) {
			if (PlayerLMouseDown[playerID]) {
				PlayWAV("sound\\Misc\\Button.wav");
				if (PlayerStoragePage[playerID] >= CONST_INV_PAGES) PlayerStoragePage[playerID] = 0;
				else PlayerStoragePage[playerID]++;
				UpdatePlayerTooltips(playerID);
			}
			if (PlayerRMouseDown[playerID]) {
				PlayWAV("sound\\Misc\\Button.wav");
				if (PlayerStoragePage[playerID] <= 0) PlayerStoragePage[playerID] = CONST_INV_PAGES-1;
				else PlayerStoragePage[playerID]--;
				UpdatePlayerTooltips(playerID);
			}
		}		
	}	
}

function SelectUnit(unit: CUnit, playerID) {
	if (unit.ptr == 0) return;
	if (IsUserCP()) {
		dwwrite(0x6284B8, unit.ptr);
		dwwrite(0x597208, unit.ptr);
		bwrite(0x59723C, 1);
	}	
	dwwrite(SelectionAddresses[playerID], unit.ptr);
}

function ClearBringCache() {
	RemoveUnitAt(1, 0, 0, 0);
}

function ReplaceResources() {
	if (ReplacedInitialResources) return;
	if (   Command($P7, Exactly, 0, UNIT_RESOURCE_PLACEHOLDER1)
		&& Command($P8, Exactly, 0, UNIT_RESOURCE_PLACEHOLDER1)
		&& Command($P9, Exactly, 0, UNIT_RESOURCE_PLACEHOLDER1)
		&& Command($P10, Exactly, 0, UNIT_RESOURCE_PLACEHOLDER1)
		&& Command($P11, Exactly, 0, UNIT_RESOURCE_PLACEHOLDER1)
		&& Command($P12, Exactly, 0, UNIT_RESOURCE_PLACEHOLDER1)) {
		ReplacedInitialResources = true;
		/*
		setcurpl($P1);
		Screen.printf("Resource gen done: {}/{} {}/{} {}/{} {}/{} {}/{} {}/{} {}/{} {}/{} {}/{}",
			BIOME_TYPE_SPAWN_COUNT[0], BIOME_TYPE_MIN_SPAWN_COUNT[0],
			BIOME_TYPE_SPAWN_COUNT[1], BIOME_TYPE_MIN_SPAWN_COUNT[1],
			BIOME_TYPE_SPAWN_COUNT[2], BIOME_TYPE_MIN_SPAWN_COUNT[2],
			BIOME_TYPE_SPAWN_COUNT[3], BIOME_TYPE_MIN_SPAWN_COUNT[3],
			BIOME_TYPE_SPAWN_COUNT[4], BIOME_TYPE_MIN_SPAWN_COUNT[4],
			BIOME_TYPE_SPAWN_COUNT[5], BIOME_TYPE_MIN_SPAWN_COUNT[5],
			BIOME_TYPE_SPAWN_COUNT[6], BIOME_TYPE_MIN_SPAWN_COUNT[6],
			BIOME_TYPE_SPAWN_COUNT[7], BIOME_TYPE_MIN_SPAWN_COUNT[7],
			BIOME_TYPE_SPAWN_COUNT[8], BIOME_TYPE_MIN_SPAWN_COUNT[8],
		);
		*/
		return;
	}
	var count = 0;
	var i = 0;
	foreach(unit : EUDLoopCUnit()) {
		if (unit.unitID != UNIT_RESOURCE_PLACEHOLDER1) continue;
		if (unit.playerID < $P7) continue;
		const index = unit.playerID - $P7;
		var biomeID = unit.hp / 255;
		if (biomeID >= BIOME_COUNT) biomeID = 0;
		const biomeType = EUDArray.cast(BIOME_ID_TYPE_MAP[biomeID]);
		const resourceType = biomeType[index];
		unit.setloc(LOC_REPLACE);
		unit.remove();
		if (resourceType == RES_NULL) continue;
		if (!RES_SPAWNABLE[resourceType]) continue;
		const image = EUDArray.cast(RES_IMAGES[resourceType]).get(i);
		const resourceAmount = RES_TOTAL_AMOUNT[resourceType];
		wwrite(0x665AC0 + 1696 + 279 * 2, image); // Set image
		bwrite(0x666778 + 23000 + image * 1, 1); // Clickable
		const resourceUnit = CUnit.from_read(EPD(0x628438));
		CreateUnit(1, UNIT_RESOURCE, LOC_REPLACE, PLAYER_NEUTRAL);
		resourceUnit.unknown0x106 = resourceType;
		resourceUnit.resourceAmount = resourceAmount;
		if (RES_INITIALLY_BLOCKED[resourceType]) {
			addloc(LOC_REPLACE, 0, RES_BLOCKADE_OFFSET[resourceType]);			
			const blockade = CreateCUnit((resourceType < RES_OBSIDIAN ? UNIT_RESOURCE_BLOCKADE_SMALL : UNIT_RESOURCE_BLOCKADE_LARGE), LOC_REPLACE, PLAYER_NEUTRAL);
			GiveUnit(blockade, PLAYER_BLOCKADE);
			resourceUnit.connectedUnit = blockade;
		}
		if (i < 3) i++;
		else i = 0;
		count++;
		if (count > 90) break;
	}
}

function UpdatePlayerScreenDimensions(playerID) {
	if (PlayerScreenFollowDisabled[playerID]) return;
	if (IsUserCP()) {		
		if (Multiplayer) CenterView($L("_DetectDimensions"));
		PlayerScreenWidth[playerID] = 256*32 - dwread(0x628448);
		PlayerScreenHeight[playerID] = 256*32 - dwread(0x628448);
	}
}

function onPluginStart() {
	if (CONST_CAN_EXPIRE && dwread(0x6D0F38) > CONST_EXPIRY) {
		Expired = true;
		return;
	}
	Multiplayer = dwread(0x57F0B4);
	if (!CONST_DEV_MODE && !Multiplayer) {
		printAllAt(4, "\x13Play in multiplayer:\n\x13 This map is only playable in Multiplayer Mode");
		Defeat();
		return;
	}
	if (!Multiplayer) StructureControlRange = CONST_STRU_CONTROL_RANGE_SP;

	randomize();
	Setup();
	if (Multiplayer) {
		for (var i = 0; i < 49; i++) bwrite(0x513B68+i, 0);
	}
	
	EUDPlayerLoop()();
	const playerID = getcurpl();
	UpdatePlayerScreenDimensions(playerID);
	Screen.printAt(0, "\x13\x04~ Welcome to Nightfall Survivors ~");
	Screen.printfAt(1, "\x13\x04Day {}", Day);
	EUDEndPlayerLoop();
}


function beforeTriggerExec() {
	var buttonSet;
	if (!Memory(0x68C14C, Exactly, buttonSet)) {
		buttonSet = dwread(0x68C14C);
		DoActions(PlayerButtonSetChanged.Set());
	}
	ReplaceResources();
}

function afterTriggerExec() {
	if (CONST_CAN_EXPIRE && Expired) {
		printAllAt(4, "\x13Map Expired:\n\x13 There is a newer version of this map with significant improvements to bugs and balance.\n\x13Please get the latest version by joining the StarEdit.net Discord\n\x13https://discord.gg/TqShZ66QnV");
		return;
	}

	PlayerButtonSetChanged.Clear();
	SetMemory(0x6509A0, SetTo, 0);
	CreateUnit(1, "Zerg Zergling", LOC_OFFSCREEN, $P8);
	RemoveUnit("Zerg Zergling", $P8);
	const dayNightCycleDidChange = UpdateTime();

	if (AggroTimer == 0) AggroTimer = CONST_AGGRO_TIMER_MAX;
	else AggroTimer--;

	EUDPlayerLoop()();
	const playerID = getcurpl();
	const heroUnit = CUnit(PlayerHeroUnit[playerID]);

	const selectedUnit = CUnit.cast(PlayerSelectedUnit[playerID]);

	if (UpdatePlayerScreenDimensionsTimer > 42*5) UpdatePlayerScreenDimensionsTimer = 0;
	else UpdatePlayerScreenDimensionsTimer++;

	if (PlayerHarvestSoundTimer[playerID] > 0) PlayerHarvestSoundTimer[playerID]--;
	else PlayerHarvestSoundTimer[playerID] = PLAYER_HARVEST_SOUND_TIMER_MAX;

	if (playerID < $P6) {
		if (Multiplayer && UpdatePlayerScreenDimensionsTimer == 0) UpdatePlayerScreenDimensions(playerID);
		//heroUnit.setloc(LOC_RANGE);
		//dilateloc(LOC_RANGE, CONST_FURNACE_REGEN_RANGE, CONST_FURNACE_REGEN_RANGE);
		

		// Global updates
		if (dayNightCycleDidChange) {
			if (Night) {
				Screen.printAt(0, "\x13\x04~ Nightfall ~");
				PlayWAV("sound\\Misc\\ZRescue.wav");
			} else {
				Screen.printAt(0, "\x13\x04~ Daybreak ~");
				Screen.printfAt(1, "\x13\x04Day {}", Day);
				PlayWAV("sound\\Misc\\PRescue.wav");
			} 
		}
		
		HandleDevCommands(playerID);
		HandleSelfAbility(playerID);
		HandleTargetAbility(playerID);
		UpdateSelectedUnit(playerID);

		if (Command(playerID, Exactly, 0, UNIT_HERO)) PlayerScreenFollowDisabled[playerID] = true;

		// HP, Energy Vitals and Status	

		heroUnit.setloc(LOC_RANGE);
		dilateloc(LOC_RANGE, CONST_FURNACE_REGEN_RANGE, CONST_FURNACE_REGEN_RANGE);
		heroUnit.setloc(PlayerRangeLocations[playerID]);
		dilateloc(PlayerRangeLocations[playerID], MobAggroRange, MobAggroRange);
		heroUnit.setloc(PlayerSpecificLocations[playerID]);
		dilateloc(PlayerSpecificLocations[playerID], CONST_FURNACE_REGEN_RANGE, CONST_FURNACE_REGEN_RANGE);
		if (Multiplayer && PlayerScreenFollowDisabled[playerID] == 0 && IsUserCP()) CenterView(LOC_RANGE);
		ClearBringCache();
		var nearbyFurnace = Bring(AllPlayers, AtLeast, 1, STRU_FURNACE, PlayerSpecificLocations[playerID]) && Bring(AllPlayers, AtLeast, 1, UNIT_LIGHT_OVERLAY, PlayerSpecificLocations[playerID]) ? true : false;
		var nearbyLightPost = Bring(AllPlayers, AtLeast, 1, STRU_LIGHTPOST, PlayerSpecificLocations[playerID]) && Bring(AllPlayers, AtLeast, 1, UNIT_LIGHT_OVERLAY, PlayerSpecificLocations[playerID]) ? true : false;
		if (PlayerEnergy[playerID] >= CONST_HERO_ENERGY_RESTED_LEVEL) PlayerStatus[playerID] = STATUS_RESTED;
		else if (PlayerEnergy[playerID] == 0) PlayerStatus[playerID] = STATUS_STARVING;
		else if (PlayerEnergy[playerID] < CONST_STATUS_HUNGRY_LEVEL) PlayerStatus[playerID] = STATUS_HUNGRY;
		else PlayerStatus[playerID] = STATUS_NORMAL;

		if (AggroTimer == 0) {
			heroUnit.setloc(PlayerRangeLocations[playerID]);
			dilateloc(PlayerRangeLocations[playerID], MobAggroRange, MobAggroRange);
			ClearBringCache();			
			GiveUnits(100, $U("Men"), $P7, PlayerRangeLocations[playerID], $P6);
			setcurpl($P6);
			RunAIScriptAt("Send All Units on Random Suicide Missions", PlayerRangeLocations[playerID]);
			setcurpl(playerID);
		}
		
		if (heroUnit.cycleCounter == 0) {
			if (nearbyFurnace) {
				if (PlayerEnergy[playerID] + CONST_HERO_ENERGY_REGEN_FURNACE >= CONST_HERO_ENERGY_MAX) PlayerEnergy[playerID] = CONST_HERO_ENERGY_MAX;
				else PlayerEnergy[playerID] += CONST_HERO_ENERGY_REGEN_FURNACE;
			} else {
				if (!nearbyLightPost) {
					if (PlayerEnergy[playerID] >= CONST_HERO_ENERGY_DRAIN) PlayerEnergy[playerID] -= CONST_HERO_ENERGY_DRAIN;
					else PlayerEnergy[playerID] = 0;
				}
			}
			if (PlayerStatus[playerID] == STATUS_RESTED) {
				HealUnit(heroUnit, CONST_HERO_HP_REGEN_HIGH_ENERGY, CONST_HERO_HP_MAX);
			} else if (PlayerStatus[playerID] == STATUS_STARVING) {
				DamageUnit(heroUnit, CONST_HERO_HP_DRAIN_EMPTY_ENERGY);
			}
		}
		heroUnit.energy = PlayerEnergy[playerID];

		//Debug selection
		if (PlayerDebugMode[playerID] && selectedUnit != 0) {
			Screen.printfAt(0, "Time {} AM {} Night {} SA {} TA {} light {} pbs {} PlayerEnergy {}",
				Time,
				AM,
				Night,
				PlayerSelfAbilityID[playerID],
				PlayerTargetAbilityID[playerID],
				PlayerLight[playerID],
				PlayerButtonSet[playerID],
				PlayerEnergy[playerID]
			);
			Screen.printfAt(1, "u {} playerID {} order {} orderState {} orderSignal {} secondaryOrder {} secondaryOrderState {} movementState {} orderTargetUnit {} moveTargetUnit {}",
				selectedUnit,
				selectedUnit.playerID,
				selectedUnit.order,
				selectedUnit.orderState,
				selectedUnit.orderSignal,
				selectedUnit.secondaryOrder,
				selectedUnit.secondaryOrderState,
				selectedUnit.movementState,
				selectedUnit.orderTargetUnit,
				selectedUnit.moveTargetUnit,
			);
			Screen.printfAt(2, "uid {} hp {} energy {} cu {} - u106 {} - u26 {} - killCount {} - rankIncrease {} - lastAttackingPlayer {} - unusedTimer {} - orderTimer {}",
				selectedUnit.unitID,
				selectedUnit.hp,
				selectedUnit.energy,
				selectedUnit.connectedUnit,
				selectedUnit.unknown0x106,
				selectedUnit.unknown0x26,
				selectedUnit.killCount,
				selectedUnit.rankIncrease,
				selectedUnit.lastAttackingPlayer,
				selectedUnit.unusedTimer,
				selectedUnit.orderTimer,
			);
		}

		UpdateBrightness(playerID);

		switch(heroUnit.order) {
			case 30:
				const structureType = heroUnit.buildQueue1;
				if (structureType != 228) {
					var valid = true;
					for (var resourceType = 0; resourceType < RES_COUNT; resourceType++) {
						if (!ValidatePlayerResourceAmount(playerID, resourceType, GetStructureResourceCost(structureType, resourceType))) {
							valid = false;
						}
					}
					if (valid) {
						if (PlayerHasResourcesToConsume[playerID] == false) {
							AddResourceToConsume(playerID, structureType);
							PlayerHasResourcesToConsume[playerID] = true;
						}
					} else {
						heroUnit.order = 1;
						PlayerHasResourcesToConsume[playerID] = false;
						eprintln("\x04Not enough resources");
					}
				}
			break;
			case 33:
				if (PlayerHasResourcesToConsume[playerID]) {
					SettleResourceToConsume(playerID);
					PlayerHasResourcesToConsume[playerID] = false;
				}
			break;
			case 87:
				if (heroUnit.targetResourceUnit != 0) {
					if (heroUnit.targetResourceUnit.connectedUnit == 0) {
						const resourceType = heroUnit.targetResourceUnit.unknown0x106;
						const orderTimeReduction = (RES_HARVESTING_TIMER[resourceType]*GetUpgrade(playerID, UPGR_MINING)/8);
						if (PlayerHarvestSoundTimer[playerID] == 0) PlaySound(RES_HARVEST_SOUND[resourceType], playerID);
						if (heroUnit.orderTimer > RES_HARVESTING_TIMER[resourceType]) {
							heroUnit.orderTimer = RES_HARVESTING_TIMER[resourceType] - orderTimeReduction;
						} else if (heroUnit.orderTimer > 0 && heroUnit.orderTimer <= 3) {
							heroUnit.orderTimer = RES_HARVESTING_TIMER[resourceType] - orderTimeReduction;
							var resMiningAmount = RES_HARVESTING_QUANTITY[resourceType];
							if (resMiningAmount > heroUnit.targetResourceUnit.resourceAmount) resMiningAmount = heroUnit.targetResourceUnit.resourceAmount;
							if (heroUnit.targetResourceUnit.resourceAmount >= resMiningAmount) {
								heroUnit.targetResourceUnit.resourceAmount -= resMiningAmount;
								PlayerHarvestingItemCount[playerID]++;
								if (RES_SECONDARY_RES[resourceType] < RES_COUNT && RES_SECONDARY_RES_FREQUENCY[resourceType] <= PlayerHarvestingItemCount[playerID]) {
									PlayerHarvestingItemCount[playerID] = 0;
									AddPlayerResourceAmountMulti(playerID, resourceType, resMiningAmount, RES_SECONDARY_RES[resourceType], 1, true);
								} else {
									AddPlayerResourceAmount(playerID, resourceType, resMiningAmount, true);
								}
							}
							if (heroUnit.targetResourceUnit.resourceAmount < 1) {
								heroUnit.targetResourceUnit.setloc(LOC_REPLACE);
								heroUnit.targetResourceUnit.remove();
								heroUnit.order = CONST_ORDER_MINE_NEARBY;
								//heroUnit.order = 151;
							}
						}
					} else {
						heroUnit.order = 3;
						eprintln("\x04Resource is blocked");
					}
				}
			break;
		}
		// Reset harvesting order when not harvesting
		if (heroUnit.order != CONST_ORDER_MINE && PlayerHarvestingItemCount[playerID] != 0) PlayerHarvestingItemCount[playerID] = 0;
		
		heroUnit.setloc(PlayerSpecificLocations[playerID]);
		dilateloc(PlayerSpecificLocations[playerID], CONST_TECH_ACQUISITION_RANGE, CONST_TECH_ACQUISITION_RANGE);
		ClearBringCache();
		const nearbyTech = Bring(AllPlayers, AtLeast, 1, UNIT_TECH, PlayerSpecificLocations[playerID]) ? true : false;
		if (nearbyTech && heroUnit.moveTargetUnit != 0 && heroUnit.movementState == 10 && heroUnit.moveTargetUnit.unitID == UNIT_TECH) {
			const technologyType = heroUnit.moveTargetUnit.unknown0x106;
			if (!PlayerHasTechnology(playerID, technologyType)) {
				heroUnit.moveTargetUnit.setloc(LOC_REPLACE);
				RemoveUnitAt(1, UNIT_TECH, PlayerSpecificLocations[playerID], AllPlayers);
				heroUnit.moveTargetUnit = 0;
				AddPlayerTechnology(playerID, technologyType, true);
			} else {
				heroUnit.moveTargetUnit = 0;
				Screen.printf("You already have blueprint for: \x03{:s}", TECH_STRING[technologyType]);
			}
		}

		// Primary self cast ability 
		if (heroUnit.check_buildq(OPT_1)) {
			if (PlayerAltKeyPress[playerID] && PlayerSelfAbilityID[playerID] != ABLT_COUNT) {
				var found = false;
				var abilityID = PlayerSelfAbilityID[playerID] + 1;
				while(true) {
					if (EUDArray.cast(PlayerSelfAbilitiesAvailable[playerID]).get(abilityID) == 1) {
						SelectAbility(playerID, abilityID);
						break;
					}
					abilityID++;
					if (abilityID >= ABLT_COUNT) abilityID = 0;
				}
			} else {
				if (ValidateAbilityEnergy(playerID, PlayerSelfAbilityID[playerID])) {
					CastSelfAbility(playerID);
				}
			}
		}

		// Restore energy ability
		if (heroUnit.check_buildq(OPT_2)) {
			if (PlayerEnergy[playerID] < CONST_HERO_ENERGY_MAX) {
				var energy = 0;
				if (ValidatePlayerResourceAmount(playerID, RES_BERRIES, 1)) {
					SubtractPlayerResourceAmount(playerID, RES_BERRIES, 1);
					energy = RES_ENERGY_REGEN[RES_BERRIES] + RES_ENERGY_REGEN[RES_BERRIES] * GetUpgrade(playerID, UPGR_ENERGY);
					eprintln("\x04Energy restored");
				}

				if (energy != 0) {
					if (PlayerEnergy[playerID] + energy > CONST_HERO_ENERGY_MAX) PlayerEnergy[playerID] = CONST_HERO_ENERGY_MAX;
					else PlayerEnergy[playerID] += energy;
					CreateImageSpriteAtUnit(368, heroUnit);
					PlaySound(SOUND_EAT, playerID);
				} else {
					eprintln("\x04No consumable items available");
				}
			} else {
				eprintln("\x04You are already at maxmium energy");				
			}
		}

		// Switch portrait
		if (heroUnit.check_buildq(OPT_3)) {
			SwitchToNextHeroPortrait(playerID);
		}


		if (heroUnit.check_buildq(OPT_1) || heroUnit.check_buildq(OPT_2) || heroUnit.check_buildq(OPT_3)) {
			heroUnit.reset_buildq();
			heroUnit.currentBuildUnit.remove();
			heroUnit.currentBuildUnit = 0;
			heroUnit.orderSignal = 10;
			// TODO: Revisit if needed?
			// Only decollide in certain situations.
			//if (heroUnit.order != CONST_ORDER_MINE_NEARBY && heroUnit.order != CONST_ORDER_MINE) heroUnit.order = CONST_ORDER_DECOLLIDE;
			heroUnit.secondaryOrder = 23;
		}
		// Target Ability		
		if (heroUnit.order == CONST_ORDER_TARGET_ABILITY) {
			heroUnit.order = 1;
			heroUnit.secondaryOrder = 1;
			if (ValidateAbilityEnergy(playerID, PlayerTargetAbilityID[playerID])) {
				CastTargetAbility(playerID, heroUnit.orderTargetUnit, heroUnit.orderTargetX, heroUnit.orderTargetY);
			}
		}
		if (selectedUnit == heroUnit
			&&PlayerButtonSet[playerID] == 229
			&& selectedUnit.lockdownTimer == 0
			&& PlayerAltKeyPress[playerID]
			&& PlayerTargetAbilityID[playerID] != ABLT_COUNT) {
			selectedUnit.lockdownTimer = 1;
			var found = false;
			var abilityID = PlayerTargetAbilityID[playerID] + 1;
			while(true) {
				if (EUDArray.cast(PlayerTargetAbilitiesAvailable[playerID]).get(abilityID) == 1) {
					SelectAbility(playerID, abilityID);
					break;
				}
				abilityID++;
				if (abilityID >= ABLT_COUNT) abilityID = 0;
			}
		}

		// Finally update interface
		UpdatePlayerInterface(playerID, selectedUnit, true);	

		// Buildings
		foreach(unit : EUDLoopPlayerCUnit(playerID)) {

			// All buildings that can build a marine = destruct
			if (unit.check_buildq(OPT_DESTROY)) {
				// Refund?
				if (PlayerAltKeyPress[playerID]) {					
					unit.setloc(LOC_REPLACE);
					CreateImageSpriteAtLocation(332, LOC_REPLACE);
					unit.remove();
				}
			}

			switch(unit.unitID) {
				case STRU_WALL:
				case STRU_OWALL:				
					// Is being repaired
					if (unit.defensiveMatrixHp > CONST_WALL_REPAIR_REGEN) {
						unit.hp += CONST_WALL_REPAIR_REGEN;
						unit.defensiveMatrixHp -= CONST_WALL_REPAIR_REGEN;
						if (unit.cycleCounter == 0) CreateImageSpriteAtUnit(368, unit);
						if (unit.hp >= CONST_WALL_HP) {
							unit.hp = CONST_WALL_HP;
							unit.defensiveMatrixHp = 0;
						}
					}
					// Lower & Raise
					if (unit.check_buildq(OPT_1)) {
						unit.setloc(LOC_REPLACE);
						dilateloc(LOC_REPLACE, 16,16);
						ClearBringCache();
						if (Bring(AllPlayers, AtLeast, 1, $U("Men"), LOC_REPLACE)) {
							eprintln("\x04Structure blocked");
							PlayWAV("sound\\Misc\\Buzz.wav");
						} else {
							if (unit.unitID == STRU_WALL) {
								PlayWAV("sound\\Misc\\Door\\Door2Opn.wav");
								CreateImageSpriteAtUnit(423, unit);
							} else {
								PlayWAV("sound\\Misc\\Door\\Door2Cls.wav");
								CreateImageSpriteAtUnit(499, unit);
							}
							const replacedUnit = ReplaceUnit(unit, unit.unitID == STRU_WALL ? STRU_OWALL : STRU_WALL);
							if (unit.unitID == STRU_WALL) replacedUnit.remove_collision();
							replacedUnit.hp = unit.hp;
							replacedUnit.defensiveMatrixHp = unit.defensiveMatrixHp;
							SelectUnit(replacedUnit, playerID);
						}
					} else if (unit.check_buildq(OPT_2)) {
						if (unit.hp < CONST_WALL_HP) {
							if (ValidatePlayerResourceAmount(playerID, RES_STONE, CONST_WALL_REPAIR_COST)) {
								unit.defensiveMatrixHp = CONST_WALL_HP;
								SubtractPlayerResourceAmount(playerID, RES_STONE, CONST_WALL_REPAIR_COST);
								eprintln("\x04Repairing wall");
							} else {
								eprintln("\x04Not enough resources");
							}
						} else {
							eprintln("\x04Wall already at maximum HP");
						}
					}
					break;					
				case STRU_FURNACE:
				case STRU_LIGHTPOST:
					if (unit.is_dying() && unit.connectedUnit != 0) unit.connectedUnit.remove();
					if (unit.is_completed()) {
						if (unit.hp > 256*10 && unit.cycleCounter == 0) {
							var drainUpg = GetUpgrade(playerID, UPGR_LIGHT);
							var drain = drainUpg > CONST_LIGHT_SOURCE_HP_DRAIN ? 1 : CONST_LIGHT_SOURCE_HP_DRAIN - drainUpg;
							unit.hp -= unit.hp < drain ? unit.hp : drain;
						}
						// Add fuel
						if (unit.check_buildq(OPT_1)) {
							if (ValidatePlayerResourceAmount(playerID, RES_LEAVES, CONST_LIGHT_SOURCE_RESTORE_COST)) {
								if (unit.unitID == STRU_FURNACE) unit.hp = CONST_FURNACE_HP;
								else unit.hp = CONST_LIGHTPOST_HP;
								SubtractPlayerResourceAmount(playerID, RES_LEAVES, CONST_LIGHT_SOURCE_RESTORE_COST);
								PlayWAV("sound\\Misc\\OnFirSml.wav");
							} else {
								eprintln("\x04Not enough resources");
							}
						}
						// Extinguish
						if (unit.check_buildq(OPT_2)) {
							PlayWAV("sound\\Misc\\OutOfGas.wav");
							unit.hp = CONST_LIGHT_SOURCE_HP_MIN;
						}
						if (unit.unitID == STRU_FURNACE) {					
							if (unit.hp == CONST_LIGHT_SOURCE_HP_MIN && unit.connectedUnit != 0) {
								unit.connectedUnit.remove();
								unit.setloc(LOC_REPLACE);
								CreateImageSpriteAtLocation(497, LOC_REPLACE);
							} else if (unit.hp > CONST_LIGHT_SOURCE_HP_MIN && unit.connectedUnit == 0) {
								unit.setloc(LOC_REPLACE);
								wwrite(0x665AC0 + 1696 + SPRITE_OVERLAY * 2, 452);
								const overlayUnit = CreateCUnit(UNIT_LIGHT_OVERLAY, playerID, LOC_REPLACE);
								overlayUnit.playerID = playerID;
								overlayUnit.remove_collision();
								overlayUnit.set_noclip();
								overlayUnit.connectedUnit = unit;
								unit.connectedUnit = overlayUnit;
							}
						} else if (unit.unitID == STRU_LIGHTPOST) {
							if (unit.hp == CONST_LIGHT_SOURCE_HP_MIN && unit.connectedUnit != 0) {
								unit.connectedUnit.setloc(LOC_REPLACE);
								unit.connectedUnit.remove();
								CreateImageSpriteAtLocation(497, LOC_REPLACE);
							} else if (unit.hp > CONST_LIGHT_SOURCE_HP_MIN && unit.connectedUnit == 0) {
								unit.setloc(LOC_REPLACE);
								wwrite(0x665AC0 + 1696 + SPRITE_OVERLAY * 2, 982);
								addloc(LOC_REPLACE,0,-54);
								const overlayUnit = CreateCUnit(UNIT_LIGHT_OVERLAY, playerID, LOC_REPLACE);
								overlayUnit.playerID = playerID;
								overlayUnit.remove_collision();
								overlayUnit.set_noclip();
								overlayUnit.connectedUnit = unit;								
								unit.connectedUnit = overlayUnit;
							}
						}
					}
					break;
				case STRU_WORKSTATION:
					// Upgrade
					if (unit.check_buildq(OPT_1)) ProcessUpgrade(playerID, UPGR_ARMOR, STRU_WORKSTATION, 0);
					else if (unit.check_buildq(OPT_2)) ProcessUpgrade(playerID, UPGR_WEAPON, STRU_WORKSTATION, 1);
					else if (unit.check_buildq(OPT_3)) ProcessUpgrade(playerID, UPGR_MINING, STRU_WORKSTATION, 3);
					else if (unit.check_buildq(OPT_4)) ProcessUpgrade(playerID, UPGR_LIGHT, STRU_WORKSTATION, 4);
					else if (unit.check_buildq(OPT_5)) ProcessUpgrade(playerID, UPGR_STRU_ARMOR, STRU_WORKSTATION, 6);
					else if (unit.check_buildq(OPT_6)) ProcessUpgrade(playerID, UPGR_ENERGY, STRU_WORKSTATION, 7);
					break;
				case STRU_LAB:
					// Research
					if (unit.check_buildq(OPT_1)) ProcessAbilityResearch(playerID, ABLT_SELF_HEAL, STRU_LAB, 0);
					else if (unit.check_buildq(OPT_2)) ProcessAbilityResearch(playerID, ABLT_SELF_SPEED, STRU_LAB, 1);
					else if (unit.check_buildq(OPT_3)) ProcessAbilityResearch(playerID, ABLT_SELF_SHIELD, STRU_LAB, 3);
					else if (unit.check_buildq(OPT_4)) ProcessAbilityResearch(playerID, ABLT_SELF_MINESPEED, STRU_LAB, 4);
					else if (unit.check_buildq(OPT_5)) ProcessAbilityResearch(playerID, ABLT_SELF_VISION, STRU_LAB, 6);
					else if (unit.check_buildq(OPT_6)) ProcessAbilityResearch(playerID, ABLT_SELF_RECALL, STRU_LAB, 7);
					else if (unit.check_buildq(OPT_7)) ProcessAbilityResearch(playerID, ABLT_SELF_DROIDS, 220, 0);
					else if (unit.check_buildq(OPT_8)) ProcessAbilityResearch(playerID, ABLT_TARGET_STUN, 220, 1);
					else if (unit.check_buildq(OPT_9)) ProcessAbilityResearch(playerID, ABLT_TARGET_DAMAGE, 220, 3);
					else if (unit.check_buildq(OPT_10)) ProcessAbilityResearch(playerID, ABLT_TARGET_REGROW, 220, 4);
					else if (unit.check_buildq(OPT_11)) ProcessAbilityResearch(playerID, ABLT_TARGET_SLOW, 220, 6);
					else if (unit.check_buildq(OPT_12)) ProcessAbilityResearch(playerID, ABLT_TARGET_BLINK, 220, 7);
					break;
				case STRU_CONVERTER:
					// Conversion
					if (unit.check_buildq(OPT_1)) ProcessResourceConversion(playerID, CONV_LIMESTONE_LIMENITE);
					else if (unit.check_buildq(OPT_2)) ProcessResourceConversion(playerID, CONV_WOOD_BOARDS);
					else if (unit.check_buildq(OPT_3)) ProcessResourceConversion(playerID, CONV_2);
					else if (unit.check_buildq(OPT_4)) ProcessResourceConversion(playerID, CONV_3);
					else if (unit.check_buildq(OPT_5)) ProcessResourceConversion(playerID, CONV_4);
					else if (unit.check_buildq(OPT_6)) ProcessResourceConversion(playerID, CONV_5);
					else if (unit.check_buildq(OPT_7)) ProcessResourceConversion(playerID, CONV_6);
					else if (unit.check_buildq(OPT_8)) ProcessResourceConversion(playerID, CONV_7);
					break;
				case STRU_TOWER:
					// Enable Tower
					unit.setloc(LOC_REPLACE);
					ClearBringCache();
					if (Bring(playerID, AtLeast, 1, UNIT_HERO, LOC_REPLACE)) {				
						unit.blindFlags = 0;
					} else {
						unit.blindFlags = 1;
					}
					break;
				case STRU_GROWBED:
					// Plant Bush
					if (unit.check_buildq(OPT_1)) {
						const resourceType = RES_LEAVES;
						const image = EUDArray.cast(RES_IMAGES[resourceType]).get(0);
						const resourceAmount = RES_TOTAL_AMOUNT[resourceType];
						wwrite(0x665AC0 + 1696 + 279 * 2, image); // Set image
						const resourceUnit = ReplaceUnitWithOffset(unit, UNIT_RESOURCE, 16);
						resourceUnit.playerID = $P12;
						resourceUnit.unknown0x106 = resourceType;
						resourceUnit.resourceAmount = resourceAmount;
					} else if (unit.check_buildq(OPT_2)) {
						const resourceType = RES_WOOD;
						const image = EUDArray.cast(RES_IMAGES[resourceType]).get(0);
						const resourceAmount = RES_TOTAL_AMOUNT[resourceType];
						wwrite(0x665AC0 + 1696 + 279 * 2, image); // Set image
						const resourceUnit = ReplaceUnitWithOffset(unit, UNIT_RESOURCE, 16);
						resourceUnit.playerID = $P12;
						resourceUnit.unknown0x106 = resourceType;
						resourceUnit.resourceAmount = resourceAmount;
					}	
					break;
				case STRU_INCUBATOR:
					// Incubator
					if (!unit.are_buildq_empty()) {
						unit.remove_collision();
						unit.setloc(LOC_REPLACE);
						unit.die();
						if (unit.check_buildq(OPT_1)) CreateUnit(1, MOB_GRAZER, LOC_REPLACE, PLAYER_NEUTRAL);
						else if (unit.check_buildq(OPT_2)) CreateUnit(1, MOB_STALKER, LOC_REPLACE, PLAYER_NEUTRAL);
						else if (unit.check_buildq(OPT_3)) CreateUnit(1, MOB_CRAWLER, LOC_REPLACE, PLAYER_NEUTRAL);
						else if (unit.check_buildq(OPT_4)) CreateUnit(1, MOB_STINGER, LOC_REPLACE, PLAYER_NEUTRAL);
					}
					break;
				case STRU_STORAGE:
					const amount = PlayerShiftKeyPress[playerID] ? 10 : 1;
					if (unit.check_buildq(OPT_1)) ProcessStorageTransfer(true, playerID, RES_BERRIES, amount);
					else if (unit.check_buildq(OPT_2)) ProcessStorageTransfer(false, playerID, RES_BERRIES, amount);
					break;
				case UNIT_OVERLAY:
					if (unit.connectedUnit != 0) unit.pos = unit.connectedUnit.pos;
					else unit.remove();
				case UNIT_LIGHT_OVERLAY:
					if (unit.connectedUnit == 0) unit.remove();
					break;
				case UNIT_DROID:
					// TODO finish implementing order loop
					if (unit.order == 3) unit.order = CONST_ORDER_MINE_NEARBY;
					if (unit.order == CONST_ORDER_MINE) {
						unit.orderTargetUnit = heroUnit;
						unit.order = 49;
					}
					break;
			}
			if (unit.unitID != UNIT_HERO) {
				if (!unit.are_buildq_empty() || unit.currentBuildUnit != 0)  {
					unit.reset_buildq();
					unit.currentBuildUnit.remove();
					unit.currentBuildUnit = 0;
				}

			}
			if (UnitIsStructure(unit.unitID)) {
				const heroUnit = CUnit(PlayerHeroUnit[playerID]);
				if (abs(unit.posX - heroUnit.posX) > StructureControlRange || abs(unit.posY - heroUnit.posY) > StructureControlRange) {
					GiveUnit(unit, PLAYER_SHARED_STRUCTURE);
				}
			}
		}	
	}

	EUDEndPlayerLoop();

	var shouldFixMobAggro = false;
	foreach(unit : EUDLoopPlayerCUnit($P6)) {
		if (unit.order == 10 && unit.movementState == 26) {
			shouldFixMobAggro = true;
			unit.orderTargetUnit = 0;
			unit.moveTargetUnit = 0;
			unit.order = 3;			
		}
	}
	if (shouldFixMobAggro) {
		setcurpl($P6);
		RunAIScriptAt("Send All Units on Random Suicide Missions", LOC_ANYWHERE);
		setcurpl(playerID);
	}

	for (var enemyPlayerID = $P6; enemyPlayerID < $P8; enemyPlayerID++) {		
		foreach(unit : EUDLoopPlayerCUnit(enemyPlayerID)) {
			if (unit.unitID == UNIT_RESOURCE_PLACEHOLDER1) continue;
			switch(unit.unitID) {
				case MOB_T8_SCOURGE:
					if (unit.order == 10 && unit.movementState == 9) {
						CreateImageSpriteAtUnit(4, unit);
						unit.orderTargetUnit.hp -= 1*256;
						unit.unitID = 227;
						RemoveUnitAt(1, unit.unitID, LOC_ANYWHERE, unit.playerID);
					}
					break;
				case UNIT_MOB_SPAWNER:
					if (!Night) {
						// No spawns allowed at day
						unit.unknown0x106 = 0;
					} else {					
						if (unit.killCount >= CONST_SPAWNER_TIER_LEVELUP && unit.rankIncrease < SPAWNER_TIERS.length-1) {
							unit.killCount = 0;
							unit.rankIncrease++;
						} 
						if (unit.hp > 0) unit.hp -= (unit.hp < CONST_DEFAULT_MOB_SPAWN_SPEED ? unit.hp : CONST_DEFAULT_MOB_SPAWN_SPEED);
						if (unit.hp == 0 && unit.unknown0x106 < MobSpawnLimit) {
							unit.setloc(LOC_REPLACE);
							dilateloc(LOC_REPLACE, CONST_SPAWNER_RANGE_CHECK, CONST_SPAWNER_RANGE_CHECK);
							if (Bring(AllPlayers, Exactly, 0, $U("Men"), LOC_REPLACE)) {
								unit.unknown0x106++;
								unit.setloc(LOC_REPLACE);
								const spawnedUnit = CreateCUnit(SPAWNER_TIERS[unit.rankIncrease], unit.playerID, LOC_REPLACE);
								spawnedUnit.order = CONST_ORDER_ROAM;
								spawnedUnit.unknown0x26 = 0;
								unit.hp = CONST_DEFAULT_SPAWNER_MAX_HP;
								spawnedUnit.connectedUnit = unit;
								CreateImageSpriteAtUnit(559, unit);
							}
						}
					}
					break;
				case UNIT_OVERLAY:
					if (unit.connectedUnit != 0) unit.pos = unit.connectedUnit.pos;
					else unit.remove();
					break;
			}

			// Unit roam
			if (unit.order == 2) unit.order = CONST_ORDER_ROAM;

			// Unit despawn
			if (!Night && unit.unitID != UNIT_MOB_SPAWNER) {
				unit.connectedUnit = 0;
				unit.setloc(LOC_REPLACE);
				CreateImageSpriteAtUnit(559, unit);
				RemoveUnitAt(1, unit.unitType, LOC_REPLACE, unit.playerID);
			}

			// Unit deaths
			if (unit.is_dying()) {
				// Manage spawner count 
				if (unit.connectedUnit != 0 && unit.connectedUnit.unitID == UNIT_MOB_SPAWNER) {
					if (unit.connectedUnit.unknown0x106 > 0) unit.connectedUnit.unknown0x106--;
					unit.connectedUnit.killCount++;
					unit.connectedUnit = 0;
				}
				// Reward kills
				if (unit.unknown0x26 == 0) {
					unit.unknown0x26 = 1;
					if (unit.lastAttackingPlayer < 8) {
						unit.setloc(LOC_REPLACE);
						dilateloc(LOC_REPLACE, 5*TILE, 5*TILE);
						if (Bring(unit.lastAttackingPlayer, AtLeast, 1, UNIT_HERO, LOC_REPLACE)) AddPlayerMobLoot(unit.lastAttackingPlayer, unit.unitID);
					}					
				}
			}
		}
	}

	foreach (unit: EUDLoopPlayerCUnit(PLAYER_SHARED_STRUCTURE)) {
		if (unit.unitID == UNIT_RESOURCE_PLACEHOLDER1) continue;
		switch(unit.unitID) {
			case UNIT_CRITTER_SPAWNER:				
				if (unit.hp > 0) unit.hp -= (unit.hp < CONST_DEFAULT_CRITTER_SPAWN_SPEED ? unit.hp : CONST_DEFAULT_CRITTER_SPAWN_SPEED);
				if (!Night && unit.hp == 0 && unit.unknown0x106 < CONST_DEFAULT_CRITTER_SPAWN_LIMIT && unit.unknown0x26 < MOB_CRITTER_TYPES.length) {
					unit.setloc(LOC_REPLACE);
					dilateloc(LOC_REPLACE, CONST_SPAWNER_RANGE_CHECK, CONST_SPAWNER_RANGE_CHECK);
					if (Bring(AllPlayers, Exactly, 0, $U("Men"), LOC_REPLACE)) {
						unit.unknown0x106++;
						unit.setloc(LOC_REPLACE);
						const spawnedUnit = CreateCUnit(MOB_CRITTER_TYPES[unit.unknown0x26], unit.playerID, LOC_REPLACE);
						spawnedUnit.order = CONST_ORDER_ROAM;
						spawnedUnit.unknown0x26 = 0;
						spawnedUnit.ensnareTimer = 100;
						unit.hp = CONST_DEFAULT_SPAWNER_MAX_HP;
						spawnedUnit.connectedUnit = unit;							
					}
				}
				break;
			case MOB_GRAZER:
			case MOB_STALKER:
			case MOB_STINGER:
			case MOB_CHIRPER:
			case MOB_CRAWLER:
			case MOB_ROAMER:
				GiveUnit(unit, PLAYER_CRITTERS);
				break;
			case UNIT_OVERLAY:
				if (unit.connectedUnit != 0) unit.pos = unit.connectedUnit.pos;
					else unit.remove();
					break;
		}
		if (UnitIsStructure(unit.unitID)) {
			var nearbyPlayerID = PLAYER_SHARED_STRUCTURE;
			for (var i = $P1; i < $P6; i++) {
				const heroUnit = CUnit(PlayerHeroUnit[i]);
				if (heroUnit && abs(unit.posX - heroUnit.posX) < StructureControlRange && abs(unit.posY - heroUnit.posY) < StructureControlRange) {				
					nearbyPlayerID = heroUnit.playerID;
				}
			}
			if (nearbyPlayerID != PLAYER_SHARED_STRUCTURE) {
				GiveUnit(unit, nearbyPlayerID);
				if (Multiplayer) CreateImageSpriteAtUnitLocalPlayer(974, unit, nearbyPlayerID);
			}
		}
	}

	foreach (unit: EUDLoopPlayerCUnit(PLAYER_CRITTERS)) {
		if (unit.unitID == UNIT_RESOURCE_PLACEHOLDER1) continue;
		switch(unit.unitID) {
			case MOB_GRAZER:
			case MOB_STALKER:
			case MOB_STINGER:
			case MOB_CHIRPER:
			case MOB_CRAWLER:
			case MOB_ROAMER:
				if (unit.lastAttackingPlayer != 8) unit.ensnareTimer = 0;
				else unit.ensnareTimer = 24;
				break;
		}

		// Unit deaths
		if (unit.is_dying()) {
			// Manage spawner count 
			if (unit.connectedUnit != 0 && unit.connectedUnit.unitID == UNIT_CRITTER_SPAWNER) {
				if (unit.connectedUnit.unknown0x106 > 0) unit.connectedUnit.unknown0x106--;
				unit.connectedUnit = 0;
			}
			// Reward kills
			if (unit.unknown0x26 == 0) {
				unit.unknown0x26 = 1;
				AddPlayerMobLoot(unit.lastAttackingPlayer, unit.unitID);
			}
		}
	}
}