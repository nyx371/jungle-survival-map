	EUDArray.cast(UPGR_COST_INCREASE[UPGR_LIGHT]).set(RES_MAGMA, 5);

	UPGR_TOOLTIP[UPGR_STRU_ARMOR] = Db("z\x01(\x03Z\x01) Upgrade Structure Armor");
	UPGR_UPGRADE[UPGR_STRU_ARMOR] = 1;	
	UPGR_MAX_LEVEL[UPGR_STRU_ARMOR] = 5;
	EUDArray.cast(UPGR_COST[UPGR_STRU_ARMOR]).set(RES_TITANIUM, 10);
	EUDArray.cast(UPGR_COST[UPGR_STRU_ARMOR]).set(RES_OBSIDIAN, 5);
	EUDArray.cast(UPGR_COST_INCREASE[UPGR_STRU_ARMOR]).set(RES_TITANIUM, 0);
	EUDArray.cast(UPGR_COST_INCREASE[UPGR_STRU_ARMOR]).set(RES_OBSIDIAN, 5);


	UPGR_TOOLTIP[UPGR_ENERGY] = Db("x\x01(\x03X\x01) Upgrade Energy Recovery");
	UPGR_UPGRADE[UPGR_ENERGY] = 9;
	UPGR_MAX_LEVEL[UPGR_ENERGY] = 5;
	EUDArray.cast(UPGR_COST[UPGR_ENERGY]).set(RES_TITANIUM, 5);
	EUDArray.cast(UPGR_COST[UPGR_ENERGY]).set(RES_BIOMASS, 5);
	EUDArray.cast(UPGR_COST_INCREASE[UPGR_ENERGY]).set(RES_TITANIUM, 0);
	EUDArray.cast(UPGR_COST_INCREASE[UPGR_ENERGY]).set(RES_BIOMASS, 15);


	// Resource conversion

	foreach(i : py_range(0, CONV_COUNT)) {
		CONV_RES_INPUTS[i] = EUDArray(RES_COUNT);
		CONV_RES_OUTPUTS[i] = EUDArray(RES_COUNT);
	}

	CONV_TOOLTIP[CONV_LIMESTONE_LIMENITE] = Db("q\x01(\x03Q\x01) Convert Stone to Concrete");
	EUDArray.cast(CONV_RES_INPUTS[CONV_LIMESTONE_LIMENITE]).set(RES_STONE, 1);
	EUDArray.cast(CONV_RES_OUTPUTS[CONV_LIMESTONE_LIMENITE]).set(RES_CONCRETE, 2);

	CONV_TOOLTIP[CONV_WOOD_BOARDS] = Db("w\x01(\x03W\x01) Convert Wood to Boards");
	EUDArray.cast(CONV_RES_INPUTS[CONV_WOOD_BOARDS]).set(RES_WOOD, 1);
	EUDArray.cast(CONV_RES_OUTPUTS[CONV_WOOD_BOARDS]).set(RES_BOARDS, 2);

	CONV_TOOLTIP[CONV_2] = Db("e\x01(\x03E\x01) Convert Resource to Resource");
	CONV_TOOLTIP[CONV_3] = Db("a\x01(\x03A\x01) Convert Resource to Resource");
	CONV_TOOLTIP[CONV_4] = Db("s\x01(\x03S\x01) Convert Resource to Resource");
	CONV_TOOLTIP[CONV_5] = Db("d\x01(\x03D\x01) Convert Resource to Resource");
	CONV_TOOLTIP[CONV_6] = Db("z\x01(\x03Z\x01) Convert Resource to Resource");
	CONV_TOOLTIP[CONV_7] = Db("x\x01(\x03X\x01) Convert Resource to Resource");

	// Structures
	STRU_TOOLTIP[STRU_WALL] = Db("q\x01(\x03Q\x01) Build Stone Wall\nBlocking structure that can be lowered.");
	STRU_DESCRIPTION[STRU_WALL] = Db("Can be lowered");
	STRU_BUTTON_STRING[STRU_WALL] = 647;
	EUDArray.cast(STRU_COST[STRU_WALL]).set(RES_STONE, 5);

	STRU_DESCRIPTION[STRU_OWALL] = Db("Can be raised");

	STRU_TOOLTIP[STRU_FURNACE] = Db("a\x01(\x03A\x01) Build Furnace\nProvides light. Slowly rejuvenates energy drain when nearby.");
	STRU_DESCRIPTION[STRU_FURNACE] = Db("Rejuvenates energy");
	STRU_BUTTON_STRING[STRU_FURNACE] = 652;
	EUDArray.cast(STRU_COST[STRU_FURNACE]).set(RES_LEAVES, 15);
	EUDArray.cast(STRU_COST[STRU_FURNACE]).set(RES_WOOD, 10);
	EUDArray.cast(STRU_COST[STRU_FURNACE]).set(RES_STONE, 5);

	STRU_TOOLTIP[STRU_LIGHTPOST] = Db("w\x01(\x03W\x01) Build Light Post\nProvides light. Reduces energy drain when nearby.");
