	RES_NAME[RES_RESIDUE] = Db("Dim Residue");
	RES_NAME[RES_EPIDERMIS] = Db("Epidermis");
	RES_NAME[RES_FRAGMENT] = Db("Ebon Fragment");
	RES_NAME[RES_SHARD] = Db("Achromatium");
	RES_NAME[RES_CORE] = Db("Tenebritium");	
	
	RES_NAME[RES_BOARDS] = Db("Boards");
	RES_NAME[RES_CONCRETE] = Db("Concrete");
	RES_NAME[RES_BIOMASS] = Db("Biomass");	
	RES_NAME[RES_UNUSED20] = Db("Unknown #21");
	RES_NAME[RES_UNUSED21] = Db("Unknown #21");
	RES_NAME[RES_UNUSED22] = Db("Unknown #22");
	RES_NAME[RES_UNUSED23] = Db("Unknown #23");
	RES_NAME[RES_UNUSED24] = Db("Unknown #24");
	RES_NAME[RES_UNUSED25] = Db("Unknown #25");
	RES_NAME[RES_UNUSED26] = Db("Unknown #26");
	RES_NAME[RES_UNUSED27] = Db("Unknown #27");

	//Add players
	foreach(playerID : py_range($P1, $P6)) {
		PlayerResources[playerID] = EUDArray(RES_COUNT);
		PlayerResourcesToConsume[playerID] = EUDArray(RES_COUNT);
		PlayerTechnology[playerID] = EUDArray(TECH_COUNT);
		PlayerSelfAbilitiesAvailable[playerID] = EUDArray(ABLT_COUNT);
		PlayerTargetAbilitiesAvailable[playerID] = EUDArray(ABLT_COUNT);
		PlayerSelfAbilityID[playerID] = ABLT_COUNT;
		PlayerTargetAbilityID[playerID] = ABLT_COUNT;
		PlayerSelectedResourceType[playerID] = RES_COUNT;
	}
	PlayerResources[PLAYER_STORAGE] = EUDArray(RES_COUNT);

	foreach(i : py_range(0, STRU_COUNT)) {
		STRU_COST[i] = EUDArray(RES_COUNT);		
		MOB_LOOT_1[i] = EUDArray(RES_COUNT);
		MOB_LOOT_2[i] = EUDArray(RES_COUNT);
	}

	foreach(i : py_range(0, ABLT_COUNT)) {
		ABLT_COST[i] = EUDArray(RES_COUNT);
	}

	foreach(i : py_range(0, UPGR_COUNT)) {
		UPGR_COST[i] = EUDArray(RES_COUNT);
		UPGR_COST_INCREASE[i] = EUDArray(RES_COUNT);
	}

	// Upgrades
	UPGR_TOOLTIP[UPGR_ARMOR] = Db("q\x01(\x03Q\x01) Upgrade Armor");
	UPGR_UPGRADE[UPGR_ARMOR] = 0;	
	UPGR_MAX_LEVEL[UPGR_ARMOR] = 10;
	EUDArray.cast(UPGR_COST[UPGR_ARMOR]).set(RES_TITANIUM, 5);
	EUDArray.cast(UPGR_COST[UPGR_ARMOR]).set(RES_HIDE, 5);
	EUDArray.cast(UPGR_COST_INCREASE[UPGR_ARMOR]).set(RES_TITANIUM, 0);
	EUDArray.cast(UPGR_COST_INCREASE[UPGR_ARMOR]).set(RES_HIDE, 15);

	UPGR_TOOLTIP[UPGR_WEAPON] = Db("w\x01(\x03W\x01) Upgrade Weapon");
	UPGR_UPGRADE[UPGR_WEAPON] = 7;
	UPGR_MAX_LEVEL[UPGR_WEAPON] = 10;
	EUDArray.cast(UPGR_COST[UPGR_WEAPON]).set(RES_TITANIUM, 5);
	EUDArray.cast(UPGR_COST[UPGR_WEAPON]).set(RES_ANDESITE, 5);
	EUDArray.cast(UPGR_COST_INCREASE[UPGR_WEAPON]).set(RES_TITANIUM, 0);
	EUDArray.cast(UPGR_COST_INCREASE[UPGR_WEAPON]).set(RES_ANDESITE, 15);
		
	UPGR_TOOLTIP[UPGR_MINING] = Db("a\x01(\x03A\x01) Upgrade Mining Efficiency");
	UPGR_UPGRADE[UPGR_MINING] = 8;
	UPGR_MAX_LEVEL[UPGR_MINING] = 7;
	EUDArray.cast(UPGR_COST[UPGR_MINING]).set(RES_TITANIUM, 10);
	EUDArray.cast(UPGR_COST[UPGR_MINING]).set(RES_HIDE, 5);
	EUDArray.cast(UPGR_COST_INCREASE[UPGR_MINING]).set(RES_HIDE, 5);
	EUDArray.cast(UPGR_COST_INCREASE[UPGR_MINING]).set(RES_OBSIDIAN, 1);

	UPGR_TOOLTIP[UPGR_LIGHT] = Db("s\x01(\x03S\x01) Upgrade Fire Endurance");
	UPGR_UPGRADE[UPGR_LIGHT] = 2;
	UPGR_MAX_LEVEL[UPGR_LIGHT] = 5;
	EUDArray.cast(UPGR_COST[UPGR_LIGHT]).set(RES_TITANIUM, 5);
