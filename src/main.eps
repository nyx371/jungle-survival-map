// Jungle Commandos Map — main epScript entrypoint.
// Keep this file orchestration-only. Gameplay logic belongs in systems/*.

import core.constants;
import core.dat_registry;
import systems.day_night;
import systems.players;
import systems.resources;
import systems.critters;
import systems.companions;
import systems.weapons;
import systems.upgrades;
import systems.abilities;
import systems.structures;
import systems.lights;
import systems.mobs;
import systems.mob_evolution;
import systems.menus;
import systems.transfers;
import systems.audio;
import systems.camera;
import systems.victory;

const Screen = StringBuffer(256);

function onPluginStart() {
    constants.initConstants();
    dat_registry.initDatRegistry();
    players.initPlayers();
    day_night.initDayNight();
    resources.initResources();
    critters.initCritters();
    companions.initCompanions();
    upgrades.initUpgrades();
    weapons.initWeapons();
    abilities.initAbilities();
    structures.initStructures();
    lights.initLights();
    mobs.initMobs();
    mob_evolution.initMobEvolution();
    menus.initMenus();
    transfers.initTransfers();
    audio.initAudio();
    camera.initCamera();
    victory.initVictory();

    DisplayTextAll("Jungle Commandos systems loaded");
}

function beforeTriggerExec() {
    const savedCp = getcurpl();
    const localPlayer = getuserplayerid();
    setcurpl(localPlayer);
    var b : CUnit = CUnit(players.PlayerHeroCUnit[localPlayer]);
    Screen.printfAt(1, "{}", b.orderID);
    setcurpl(savedCp);

    day_night.updateDayNight();
    players.updatePlayers();
    resources.updateResources();
    critters.updateCritters();
    companions.updateCompanions();
    weapons.updateWeapons();
    upgrades.updateUpgrades();
    abilities.updateAbilities();
    structures.updateStructures();
    lights.updateLights();
    mob_evolution.updateMobEvolution();
    mobs.updateMobs();
    transfers.updateTransfers();
    audio.updateAudio();
    camera.updateCamera();
    menus.updateMenus();
    victory.updateVictory();
}

function afterTriggerExec() {
}
