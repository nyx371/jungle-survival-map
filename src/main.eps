// Jungle Commandos Map — main epScript entrypoint.
// Keep this file orchestration-only. Gameplay logic belongs in systems/*.

import core.constants;
import core.dat_registry;
import systems.day_night;
import systems.players;
import systems.resources;
import systems.critters;
import systems.companions;
import systems.weapons;
import systems.upgrades;
import systems.abilities;
import systems.structures;
import systems.lights;
import systems.mobs;
import systems.mob_evolution;
import systems.menus;
import systems.transfers;
import systems.audio;
import systems.camera;
import systems.victory;

function onPluginStart() {
    initConstants();
    initDatRegistry();
    initPlayers();
    initDayNight();
    initResources();
    initCritters();
    initCompanions();
    initUpgrades();
    initWeapons();
    initAbilities();
    initStructures();
    initLights();
    initMobs();
    initMobEvolution();
    initMenus();
    initTransfers();
    initAudio();
    initCamera();
    initVictory();

    DisplayTextAll("Jungle Commandos systems loaded");
}

function beforeTriggerExec() {
    updateDayNight();
    updatePlayers();
    updateResources();
    updateCritters();
    updateCompanions();
    updateWeapons();
    updateUpgrades();
    updateAbilities();
    updateStructures();
    updateLights();
    updateMobEvolution();
    updateMobs();
    updateTransfers();
    updateAudio();
    updateCamera();
    updateMenus();
    updateVictory();
}

function afterTriggerExec() {
}
