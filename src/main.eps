// Jungle Commandos Map — main epScript entrypoint.
// Keep this file orchestration-only. Gameplay logic belongs in systems/*.

import constants;
import dat_registry;
import day_night;
import players;
import resources;
import critters;
import companions;
import weapons;
import upgrades;
import abilities;
import structures;
import lights;
import mobs;
import mob_evolution;
import menus;
import transfers;
import audio;
import camera;
import victory;

function onPluginStart() {
    initConstants();
    initDatRegistry();
    initPlayers();
    initDayNight();
    initResources();
    initCritters();
    initCompanions();
    initUpgrades();
    initWeapons();
    initAbilities();
    initStructures();
    initLights();
    initMobs();
    initMobEvolution();
    initMenus();
    initTransfers();
    initAudio();
    initCamera();
    initVictory();

    DisplayTextAll("Jungle Commandos systems loaded");
}

function beforeTriggerExec() {
    updateDayNight();
    updatePlayers();
    updateResources();
    updateCritters();
    updateCompanions();
    updateWeapons();
    updateUpgrades();
    updateAbilities();
    updateStructures();
    updateLights();
    updateMobEvolution();
    updateMobs();
    updateTransfers();
    updateAudio();
    updateCamera();
    updateMenus();
    updateVictory();
}

function afterTriggerExec() {
}
