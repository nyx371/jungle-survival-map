// Central DAT allocation registry. Final safe IDs are TBD and must be tested.

import core.constants;

const PlayerHeroUnits = list(
    TrgUnit("Terran Ghost"),
    TrgUnit("Sarah Kerrigan"),
    TrgUnit("Samir Duran"),
    TrgUnit("Infested Duran"),
    TrgUnit("Alexei Stukov")
);

const PlayerPrimaryWeapons = list(
    Weapon("C-10 Concussion Rifle"),
    Weapon("Gauss Rifle"),
    Weapon("Fragmentation Grenade"),
    Weapon("Gemini Missiles"),
    Weapon("Hellfire Missile Pack")
);

function initDatRegistry() {
    foreach (i : py_range(constants.MAX_PLAYERS)) {
        const hero = PlayerHeroUnits[i];
        const weapon = PlayerPrimaryWeapons[i];
        hero.groundWeapon = weapon;
        hero.airWeapon = weapon;
        hero.maxHp = 80 * 256;
        hero.armor = 0;
        weapon.damage = 10;
        weapon.cooldown = 15;
        weapon.maxRange = 5 * 32;
    }
}
