// Shared low-level EUD helpers used across systems.

function createUnitAndGetEpd(count, unitType, location, player) {
    // Captures the EPD of the unit CreateUnit is about to produce. This read
    // must stay immediately before the CreateUnit call in source order: it
    // reads the "last created unit" slot at the well-known address 0x628438,
    // which CreateUnit populates as a side effect.
    const epd = f_cunitepdread_epd(EPD(0x628438))[[1]];
    CreateUnit(count, unitType, location, player);
    return epd;
}

function createImageSpriteAtLocation(image, location) {
    SetMemoryX(0x00666458, SetTo, image, 0x0000ffff);
    CreateUnit(1, "Scanner Sweep", location, $P8);
    RemoveUnit("Scanner Sweep", AllPlayers);    
    SetMemoryX(0x00666458, SetTo, 546, 0x0000ffff);
}

function createImageSpriteOnUnit(image, unit:CUnit) {
    unit.setloc($L("_Place"));
    createImageSpriteAtLocation(image, $L("_Place"));
}

function setPlayerColor(pnum ,color) {
    const pcolor_dst = 0x581D76 + 8 * pnum;
    const mcolor_dst = 0x581DD6 + pnum;
    bwrite(pcolor_dst, color);
    bwrite(mcolor_dst, color);
}

function removeCUnit(unit:CUnit) {
    unit.unitType = 200;
    RemoveUnit(unit.unitType, AllPlayers);
}

function random(n) {
    if (dwrand() % (100) < n) return true;
    return false;
}