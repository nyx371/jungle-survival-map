const MAX_PLAYERS = 5;
const FRAMES_PER_GAME_SECOND = 16;
const DAY_SECONDS = 22 * 60;
const NIGHT_SECONDS = 22 * 60;
const TARGET_NIGHTS_TO_WIN = 5;



// Raw DAT/engine reference constants generated from every file in
// docs/SCRMapDocs/epScript-Reference/Constants-Reference/ (except
// Constants-Reference.md and TrgPlayer.md, whose entries -- SetTo, Add,
// AtLeast, Ore, Gas, P1..P8, AllPlayers, etc. -- are already built-in
// epScript identifiers, and TrgAIScript.md, whose 4-character AI script
// codes aren't plain integers and are looked up via EncodeAIScript(...)/
// b2i4(...) at the call site instead. These are universal engine IDs
// (units.dat/orders/images/etc. slot numbers), the same regardless of
// this map's own DAT customization -- distinct from this project's own
// gameplay enums defined elsewhere (e.g. weapons.WEAPON_RIFLE is a
// player weapon-slot index, not related to WEAPON_* below).

// --- Units (units.dat), from docs/SCRMapDocs/epScript-Reference/Constants-Reference/TrgUnit.md ---
