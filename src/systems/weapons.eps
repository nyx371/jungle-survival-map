// Weapon Crafting and Active Weapon Swapping

import core.constants;
import core.dat_registry;
import systems.upgrades;

const WEAPON_RIFLE = 0;
const WEAPON_SHOTGUN = 1;
const WEAPON_SNIPER = 2;
const WEAPON_EXPLOSIVE = 3;
const WEAPON_ACID = 4;
const WEAPON_COUNT = 5;

const ActiveWeapon = EUDArray(constants.MAX_PLAYERS);
// TODO: represent UnlockedWeapon[player][weapon] with flattened array.
const UnlockedWeapon = EUDArray(constants.MAX_PLAYERS * WEAPON_COUNT);
function weaponIndex(player, weaponType) {
    return player * WEAPON_COUNT + weaponType;
}

function isWeaponUnlocked(player, weaponType) {
    return UnlockedWeapon[weaponIndex(player, weaponType)];
}

function applyActiveWeaponDat(player) {
    const weapon = dat_registry.PlayerPrimaryWeapons[player];
    const active = ActiveWeapon[player];

    if (active == WEAPON_RIFLE) {
        weapon.damage = 12;
        weapon.cooldown = 12;
        weapon.maxRange = 5 * 32;
    } else if (active == WEAPON_SHOTGUN) {
        weapon.damage = 22;
        weapon.cooldown = 20;
        weapon.maxRange = 3 * 32;
        weapon.splashInnerRadius = 16;
    } else if (active == WEAPON_SNIPER) {
        weapon.damage = 45;
        weapon.cooldown = 32;
        weapon.maxRange = 8 * 32;
    } else if (active == WEAPON_EXPLOSIVE) {
        weapon.damage = 30;
        weapon.cooldown = 28;
        weapon.maxRange = 6 * 32;
        weapon.splashInnerRadius = 24;
        weapon.splashMiddleRadius = 48;
    } else if (active == WEAPON_ACID) {
        weapon.damage = 8;
        weapon.cooldown = 6;
        weapon.maxRange = 4 * 32;
        // TODO: choose behavior/explosion type for area denial.
    }

    upgrades.applyWeaponUpgradeDat(player, active);
}

function initWeapons() {
    foreach (p : py_range(constants.MAX_PLAYERS)) {
        ActiveWeapon[p] = WEAPON_RIFLE;
        foreach (w : py_range(WEAPON_COUNT)) {
            UnlockedWeapon[weaponIndex(p, w)] = 0;
        }
        UnlockedWeapon[weaponIndex(p, WEAPON_RIFLE)] = 1;
        applyActiveWeaponDat(p);
    }
}

function switchWeapon(player, weaponType) {
    if (isWeaponUnlocked(player, weaponType)) {
        ActiveWeapon[player] = weaponType;
        applyActiveWeaponDat(player);
    }
}

function craftWeapon(player, weaponType) {
    // TODO: check mineral cost from weapon definition table.
    UnlockedWeapon[weaponIndex(player, weaponType)] = 1;
    switchWeapon(player, weaponType);
}

function updateWeapons() {
    // Mostly event/menu driven.
}
