// Mob Evolution
// Black -> Brown -> Orange -> Red evolution driven by time, kills, and exploration pressure.

const MOB_TIER_BLACK = 0;
const MOB_TIER_BROWN = 1;
const MOB_TIER_ORANGE = 2;
const MOB_TIER_RED = 3;

var GlobalMobTier = MOB_TIER_BLACK;
var EvolutionPressure = 0;

function addEvolutionPressure(amount) {
    EvolutionPressure += amount;
}

function getEvolutionThresholdForNextTier() {
    if (GlobalMobTier == MOB_TIER_BLACK) return 100;
    if (GlobalMobTier == MOB_TIER_BROWN) return 250;
    if (GlobalMobTier == MOB_TIER_ORANGE) return 500;
    return 999999;
}

function applyZerglingTierDat(tier) {
    const unit = TrgUnit("Zerg Zergling");
    const weapon = Weapon("Claws");
    if (tier == MOB_TIER_BLACK) {
        unit.maxHp = 35 * 256;
        weapon.damage = 5;
        weapon.cooldown = 8;
    } else if (tier == MOB_TIER_BROWN) {
        unit.maxHp = 50 * 256;
        weapon.damage = 7;
        weapon.cooldown = 8;
    } else if (tier == MOB_TIER_ORANGE) {
        unit.maxHp = 70 * 256;
        weapon.damage = 10;
        weapon.cooldown = 6;
    } else {
        unit.maxHp = 95 * 256;
        weapon.damage = 14;
        weapon.cooldown = 5;
    }
}

function applyHydraliskTierDat(tier) {
    const unit = TrgUnit("Zerg Hydralisk");
    const weapon = Weapon("Needle Spines");
    if (tier == MOB_TIER_BLACK) {
        unit.maxHp = 70 * 256;
        weapon.damage = 10;
        weapon.maxRange = 4 * 32;
    } else if (tier == MOB_TIER_BROWN) {
        unit.maxHp = 90 * 256;
        weapon.damage = 12;
        weapon.maxRange = 5 * 32;
    } else if (tier == MOB_TIER_ORANGE) {
        unit.maxHp = 120 * 256;
        weapon.damage = 16;
        weapon.cooldown = 12;
        weapon.maxRange = 5 * 32;
    } else {
        unit.maxHp = 160 * 256;
        weapon.damage = 22;
        weapon.cooldown = 10;
        weapon.maxRange = 6 * 32;
    }
}

function applyDroneTierDat(tier) {
    const unit = TrgUnit("Zerg Drone");
    if (tier == MOB_TIER_BLACK) {
        unit.maxHp = 40 * 256;
    } else if (tier == MOB_TIER_BROWN) {
        unit.maxHp = 50 * 256;
    } else if (tier == MOB_TIER_ORANGE) {
        unit.maxHp = 60 * 256;
    } else {
        unit.maxHp = 70 * 256;
    }
}

function applyBroodlingTierDat(tier) {
    // Broodling shares the base Claws weapon slot with Zergling (mutated in
    // applyZerglingTierDat), so only HP is scaled here to avoid clobbering it.
    const unit = TrgUnit("Zerg Broodling");
    if (tier == MOB_TIER_BLACK) {
        unit.maxHp = 30 * 256;
    } else if (tier == MOB_TIER_BROWN) {
        unit.maxHp = 40 * 256;
    } else if (tier == MOB_TIER_ORANGE) {
        unit.maxHp = 50 * 256;
    } else {
        unit.maxHp = 60 * 256;
    }
}

function applyLurkerTierDat(tier) {
    const unit = TrgUnit("Zerg Lurker");
    const weapon = Weapon("Subterranean Spines");
    if (tier == MOB_TIER_BLACK) {
        unit.maxHp = 125 * 256;
        weapon.damage = 20;
        weapon.cooldown = 25;
    } else if (tier == MOB_TIER_BROWN) {
        unit.maxHp = 150 * 256;
        weapon.damage = 24;
        weapon.cooldown = 23;
    } else if (tier == MOB_TIER_ORANGE) {
        unit.maxHp = 180 * 256;
        weapon.damage = 28;
        weapon.cooldown = 20;
    } else {
        unit.maxHp = 220 * 256;
        weapon.damage = 34;
        weapon.cooldown = 18;
    }
}

function applyQueenTierDat(tier) {
    const unit = TrgUnit("Zerg Queen");
    if (tier == MOB_TIER_BLACK) {
        unit.maxHp = 120 * 256;
    } else if (tier == MOB_TIER_BROWN) {
        unit.maxHp = 145 * 256;
    } else if (tier == MOB_TIER_ORANGE) {
        unit.maxHp = 175 * 256;
    } else {
        unit.maxHp = 210 * 256;
    }
}

function applyMutaliskTierDat(tier) {
    const unit = TrgUnit("Zerg Mutalisk");
    const weapon = Weapon("Glave Wurm");
    if (tier == MOB_TIER_BLACK) {
        unit.maxHp = 120 * 256;
        weapon.damage = 9;
        weapon.cooldown = 30;
    } else if (tier == MOB_TIER_BROWN) {
        unit.maxHp = 145 * 256;
        weapon.damage = 12;
        weapon.cooldown = 27;
    } else if (tier == MOB_TIER_ORANGE) {
        unit.maxHp = 175 * 256;
        weapon.damage = 15;
        weapon.cooldown = 24;
    } else {
        unit.maxHp = 210 * 256;
        weapon.damage = 19;
        weapon.cooldown = 20;
    }
}

function applyGuardianTierDat(tier) {
    const unit = TrgUnit("Zerg Guardian");
    const weapon = Weapon("Acid Spore");
    if (tier == MOB_TIER_BLACK) {
        unit.maxHp = 150 * 256;
        weapon.damage = 20;
        weapon.maxRange = 8 * 32;
    } else if (tier == MOB_TIER_BROWN) {
        unit.maxHp = 180 * 256;
        weapon.damage = 24;
        weapon.maxRange = 8 * 32;
    } else if (tier == MOB_TIER_ORANGE) {
        unit.maxHp = 215 * 256;
        weapon.damage = 28;
        weapon.maxRange = 9 * 32;
    } else {
        unit.maxHp = 260 * 256;
        weapon.damage = 34;
        weapon.maxRange = 9 * 32;
    }
}

function applyDefilerTierDat(tier) {
    const unit = TrgUnit("Zerg Defiler");
    if (tier == MOB_TIER_BLACK) {
        unit.maxHp = 80 * 256;
    } else if (tier == MOB_TIER_BROWN) {
        unit.maxHp = 100 * 256;
    } else if (tier == MOB_TIER_ORANGE) {
        unit.maxHp = 120 * 256;
    } else {
        unit.maxHp = 145 * 256;
    }
}

function applyUltraliskTierDat(tier) {
    const unit = TrgUnit("Zerg Ultralisk");
    const weapon = Weapon("Kaiser Blades");
    if (tier == MOB_TIER_BLACK) {
        unit.maxHp = 400 * 256;
        weapon.damage = 20;
        weapon.cooldown = 15;
    } else if (tier == MOB_TIER_BROWN) {
        unit.maxHp = 480 * 256;
        weapon.damage = 25;
        weapon.cooldown = 14;
    } else if (tier == MOB_TIER_ORANGE) {
        unit.maxHp = 570 * 256;
        weapon.damage = 30;
        weapon.cooldown = 12;
    } else {
        unit.maxHp = 680 * 256;
        weapon.damage = 38;
        weapon.cooldown = 10;
    }
}

function applyAllMobTierDat(tier) {
    applyZerglingTierDat(tier);
    applyHydraliskTierDat(tier);
    applyDroneTierDat(tier);
    applyBroodlingTierDat(tier);
    applyLurkerTierDat(tier);
    applyQueenTierDat(tier);
    applyMutaliskTierDat(tier);
    applyGuardianTierDat(tier);
    applyDefilerTierDat(tier);
    applyUltraliskTierDat(tier);
}

function initMobEvolution() {
    GlobalMobTier = MOB_TIER_BLACK;
    EvolutionPressure = 0;
    applyAllMobTierDat(GlobalMobTier);
}

function updateMobEvolution() {
    // Time pressure: slow constant scaling.
    addEvolutionPressure(1);

    if (GlobalMobTier < MOB_TIER_RED && EvolutionPressure >= getEvolutionThresholdForNextTier()) {
        EvolutionPressure = 0;
        GlobalMobTier += 1;
        applyAllMobTierDat(GlobalMobTier);
        DisplayTextAll("The jungle evolves. Watch enemy colors.");
    }
}
