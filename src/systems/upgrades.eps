// Hero and Weapon Upgrade System

import core.constants;
import core.dat_registry;
import systems.players;
import systems.weapons;

const HERO_UPGRADE_HP = 0;
const HERO_UPGRADE_ARMOR = 1;
const HERO_UPGRADE_SHIELDS = 2;
const HERO_UPGRADE_ENERGY = 3;
const HERO_UPGRADE_MOBILITY = 4;
const HERO_UPGRADE_COUNT = 5;

const WEAPON_UPGRADE_DAMAGE = 0;
const WEAPON_UPGRADE_RANGE = 1;
const WEAPON_UPGRADE_COOLDOWN = 2;
const WEAPON_UPGRADE_SPLASH = 3;
const WEAPON_UPGRADE_COUNT = 4;

const HeroUpgradeLevel = EUDArray(constants.MAX_PLAYERS * HERO_UPGRADE_COUNT);
const WeaponUpgradeLevel = EUDArray(constants.MAX_PLAYERS * weapons.WEAPON_COUNT * WEAPON_UPGRADE_COUNT);
function heroUpgradeIndex(player, upgradeId) {
    return player * HERO_UPGRADE_COUNT + upgradeId;
}

function weaponUpgradeIndex(player, weaponType, upgradeId) {
    return (player * weapons.WEAPON_COUNT + weaponType) * WEAPON_UPGRADE_COUNT + upgradeId;
}

function initUpgrades() {
    foreach (p : py_range(constants.MAX_PLAYERS)) {
        foreach (h : py_range(HERO_UPGRADE_COUNT)) {
            HeroUpgradeLevel[heroUpgradeIndex(p, h)] = 0;
        }
        foreach (w : py_range(weapons.WEAPON_COUNT)) {
            foreach (u : py_range(WEAPON_UPGRADE_COUNT)) {
                WeaponUpgradeLevel[weaponUpgradeIndex(p, w, u)] = 0;
            }
        }
    }
}

function applyHeroUpgradeDat(player) {
    // PlayerHeroUnits is a compile-time list; it can only be indexed by a
    // compile-time constant, so dispatch on the runtime player id via switch.
    // Case count must match MAX_PLAYERS in core/constants.eps.
    const hp = HeroUpgradeLevel[heroUpgradeIndex(player, HERO_UPGRADE_HP)];
    const armor = HeroUpgradeLevel[heroUpgradeIndex(player, HERO_UPGRADE_ARMOR)];
    const shields = HeroUpgradeLevel[heroUpgradeIndex(player, HERO_UPGRADE_SHIELDS)];
    const energy = HeroUpgradeLevel[heroUpgradeIndex(player, HERO_UPGRADE_ENERGY)];

    switch (player) {
    case 0: {
        const hero = dat_registry.PlayerHeroUnits[0];
        hero.maxHp = (80 + hp * 20) * 256;
        hero.armor = armor;
        hero.hasShield = 1;
        hero.maxShield = 20 + shields * 10;
        break;
    }
    case 1: {
        const hero = dat_registry.PlayerHeroUnits[1];
        hero.maxHp = (80 + hp * 20) * 256;
        hero.armor = armor;
        hero.hasShield = 1;
        hero.maxShield = 20 + shields * 10;
        break;
    }
    case 2: {
        const hero = dat_registry.PlayerHeroUnits[2];
        hero.maxHp = (80 + hp * 20) * 256;
        hero.armor = armor;
        hero.hasShield = 1;
        hero.maxShield = 20 + shields * 10;
        break;
    }
    case 3: {
        const hero = dat_registry.PlayerHeroUnits[3];
        hero.maxHp = (80 + hp * 20) * 256;
        hero.armor = armor;
        hero.hasShield = 1;
        hero.maxShield = 20 + shields * 10;
        break;
    }
    case 4: {
        const hero = dat_registry.PlayerHeroUnits[4];
        hero.maxHp = (80 + hp * 20) * 256;
        hero.armor = armor;
        hero.hasShield = 1;
        hero.maxShield = 20 + shields * 10;
        break;
    }
    }

    players.PlayerEnergyMax[player] = players.HERO_BASE_ENERGY_MAX + energy * 25 * 256;
    if (players.PlayerEnergy[player] > players.PlayerEnergyMax[player]) players.PlayerEnergy[player] = players.PlayerEnergyMax[player];
}

function purchaseHeroUpgrade(player, upgradeId) {
    // TODO: validate cost and max level.
    HeroUpgradeLevel[heroUpgradeIndex(player, upgradeId)] += 1;
    applyHeroUpgradeDat(player);
}

function applyWeaponUpgradeDat(player, weaponType) {
    // PlayerPrimaryWeapons is a compile-time list; it can only be indexed by a
    // compile-time constant, so dispatch on the runtime player id via switch.
    // Case count must match MAX_PLAYERS in core/constants.eps.
    const damage = WeaponUpgradeLevel[weaponUpgradeIndex(player, weaponType, WEAPON_UPGRADE_DAMAGE)];
    const range = WeaponUpgradeLevel[weaponUpgradeIndex(player, weaponType, WEAPON_UPGRADE_RANGE)];
    const cooldown = WeaponUpgradeLevel[weaponUpgradeIndex(player, weaponType, WEAPON_UPGRADE_COOLDOWN)];

    switch (player) {
    case 0: {
        const weapon = dat_registry.PlayerPrimaryWeapons[0];
        weapon.damage += damage * 3;
        weapon.maxRange += range * 32;
        if (cooldown > 0) {
            weapon.cooldown -= cooldown;
        }
        break;
    }
    case 1: {
        const weapon = dat_registry.PlayerPrimaryWeapons[1];
        weapon.damage += damage * 3;
        weapon.maxRange += range * 32;
        if (cooldown > 0) {
            weapon.cooldown -= cooldown;
        }
        break;
    }
    case 2: {
        const weapon = dat_registry.PlayerPrimaryWeapons[2];
        weapon.damage += damage * 3;
        weapon.maxRange += range * 32;
        if (cooldown > 0) {
            weapon.cooldown -= cooldown;
        }
        break;
    }
    case 3: {
        const weapon = dat_registry.PlayerPrimaryWeapons[3];
        weapon.damage += damage * 3;
        weapon.maxRange += range * 32;
        if (cooldown > 0) {
            weapon.cooldown -= cooldown;
        }
        break;
    }
    case 4: {
        const weapon = dat_registry.PlayerPrimaryWeapons[4];
        weapon.damage += damage * 3;
        weapon.maxRange += range * 32;
        if (cooldown > 0) {
            weapon.cooldown -= cooldown;
        }
        break;
    }
    }
}

function purchaseWeaponUpgrade(player, weaponType, upgradeId) {
    // TODO: validate weapon unlocked, cost, and max level.
    WeaponUpgradeLevel[weaponUpgradeIndex(player, weaponType, upgradeId)] += 1;
    applyWeaponUpgradeDat(player, weaponType);
}

function updateUpgrades() {
    // Menu/event driven.
}
