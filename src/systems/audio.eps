// Audio Feedback: hurt sounds, footsteps, low-HP heartbeat.

import core.constants;
import core.utils;
import systems.players;

const LOW_HP_PERCENT = 30;

// Hurt: randomized between variants, rate-limited so taking damage doesn't
// spam it (a single hit or a burst both trigger at most one per cooldown).
const HURT_SFX = [
    StringBuffer("staredit/wav/player_hurt_01.ogg"),
    StringBuffer("staredit/wav/player_hurt_02.ogg"),
    StringBuffer("staredit/wav/player_hurt_03.ogg"),
    StringBuffer("staredit/wav/player_hurt_04.ogg"),
];
const HURT_SFX_COUNT = 4;
const HURT_SOUND_COOLDOWN = 3 * constants.FRAMES_PER_GAME_SECOND;

// Footsteps: randomized, played on a cadence while the hero has a move or
// attack-move order (i.e. is actually walking).
const STEP_SFX = [
    StringBuffer("staredit/wav/player_step_grass_01.ogg"),
    StringBuffer("staredit/wav/player_step_grass_02.ogg"),
    StringBuffer("staredit/wav/player_step_grass_03.ogg"),
    StringBuffer("staredit/wav/player_step_grass_04.ogg"),
    StringBuffer("staredit/wav/player_step_grass_05.ogg"),
    StringBuffer("staredit/wav/player_step_grass_06.ogg"),
];
const STEP_SFX_COUNT = 6;
const STEP_SOUND_INTERVAL = 8; // frames between footsteps while moving

const ORDER_MOVE = 6;         // Move / Ignore
const ORDER_ATTACK_MOVE = 14; // Attack Move

// Low-HP heartbeat still uses a placeholder WAV (no dedicated asset yet).
const HEARTBEAT_WAV = "sound/terran/marine/tmadth00.wav";
const HEARTBEAT_COOLDOWN = 2 * constants.FRAMES_PER_GAME_SECOND;

const LastHp = EUDArray(constants.MAX_PLAYERS);
const HurtSoundTimer = EUDArray(constants.MAX_PLAYERS);
const StepSoundTimer = EUDArray(constants.MAX_PLAYERS);
const StepCycle = EUDArray(constants.MAX_PLAYERS); // footsteps cycle in order, not random
const HeartbeatTimer = EUDArray(constants.MAX_PLAYERS);

function initAudio() {
    foreach (p : py_range(constants.MAX_PLAYERS)) {
        LastHp[p] = 0;
        HurtSoundTimer[p] = 0;
        StepSoundTimer[p] = 0;
        StepCycle[p] = 0;
        HeartbeatTimer[p] = 0;
    }
}

function clearAudioDangerState(player) {
    HurtSoundTimer[player] = 0;
    StepSoundTimer[player] = 0;
    HeartbeatTimer[player] = 0;
}

function updateAudioForPlayer(player) {
    if (!players.HeroAlive[player]) return;

    const hero = players.getPlayerHeroUnit(player);
    const maxHp = players.getPlayerHeroMaxHp(player);
    const currentHp = hero.hp;

    // Hurt sound: fire once when HP drops, then hold off for the cooldown.
    if (currentHp < LastHp[player] && HurtSoundTimer[player] == 0) {
        utils.playSoundArray(HURT_SFX, player, HURT_SFX_COUNT);
        HurtSoundTimer[player] = HURT_SOUND_COOLDOWN;
    }
    if (HurtSoundTimer[player] > 0) HurtSoundTimer[player] -= 1;

    // Footsteps while moving (Move / Attack Move), on a step cadence.
    if (hero.orderID == ORDER_MOVE || hero.orderID == ORDER_ATTACK_MOVE) {
        if (StepSoundTimer[player] == 0) {
            utils.playSoundArrayAt(STEP_SFX, player, StepCycle[player]);
            StepCycle[player] += 1;
            if (StepCycle[player] >= STEP_SFX_COUNT) StepCycle[player] = 0;
            StepSoundTimer[player] = STEP_SOUND_INTERVAL;
        }
    }
    if (StepSoundTimer[player] > 0) StepSoundTimer[player] -= 1;

    // Low-HP heartbeat.
    if (maxHp > 0 && currentHp * 100 / maxHp <= LOW_HP_PERCENT) {
        if (HeartbeatTimer[player] == 0) {
            const savedCp = getcurpl();
            setcurpl(player);
            PlayWAV(HEARTBEAT_WAV);
            setcurpl(savedCp);
            HeartbeatTimer[player] = HEARTBEAT_COOLDOWN;
        }
    }
    if (HeartbeatTimer[player] > 0) HeartbeatTimer[player] -= 1;

    LastHp[player] = currentHp;
}

function updateAudio() {
    foreach (p : py_range(constants.MAX_PLAYERS)) {
        updateAudioForPlayer(p);
    }
}
