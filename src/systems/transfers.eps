// Team Resource Transfers

import core.constants;
import systems.resources;

const TransferTarget = EUDArray(constants.MAX_PLAYERS);
const TransferAmount = EUDArray(constants.MAX_PLAYERS);

function initTransfers() {
    foreach (p : py_range(constants.MAX_PLAYERS)) {
        TransferTarget[p] = 0;
        TransferAmount[p] = 0;
    }
}

function sendMinerals(fromPlayer, toPlayer, amount) {
    if (amount <= 0) return;

    const sender = TrgPlayer(fromPlayer);
    if (sender.mineral < amount) return;

    sender.mineral -= amount;
    resources.addMinerals(toPlayer, amount);
}

function updateTransfers() {
    // Menu driven.
}
