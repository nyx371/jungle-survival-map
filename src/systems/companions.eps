// Companion Squadron System
// Optional small squads controlled by each Ghost: crafted robotic fighters, tamed Zerg, or resurrected Zerg.
// Companions are owned by the player and are wiped when that player's Ghost dies.

import core.constants;
import core.utils;
import systems.players;

const MAX_COMPANIONS_PER_PLAYER = 6;
const MAX_COMPANIONS = constants.MAX_PLAYERS * MAX_COMPANIONS_PER_PLAYER;

const COMPANION_ROBOTIC = 0;
const COMPANION_TAMED_ZERG = 1;
const COMPANION_RESURRECTED_ZERG = 2;

// Placeholder unit choices; final DAT allocation TBD (see docs/dat-allocation-notes.md).
const ROBOTIC_FIGHTER_UNIT = $U("Terran Vulture");
const ROBOTIC_FIGHTER_MINERAL_COST = 50;
const ROBOTIC_FIGHTER_GAS_COST = 25;
const RESURRECTED_ZERG_UNIT = $U("Zerg Zergling");
const RESURRECT_GAS_COST = 50;
const COMPANION_FOLLOW_DISTANCE = 4 * 32;
const ORDER_MOVE = 6;

const CompanionActive = EUDArray(MAX_COMPANIONS);
const CompanionOwner = EUDArray(MAX_COMPANIONS);
const CompanionType = EUDArray(MAX_COMPANIONS);
const CompanionUnit = EUDArray(MAX_COMPANIONS);
const CompanionControlMode = EUDArray(MAX_COMPANIONS);

function initCompanions() {
    foreach (i : py_range(MAX_COMPANIONS)) {
        CompanionActive[i] = 0;
        CompanionOwner[i] = -1;
        CompanionType[i] = COMPANION_ROBOTIC;
        CompanionUnit[i] = 0;
        CompanionControlMode[i] = 0;
    }
}

function getPlayerCompanionCount(player) {
    var count = 0;
    foreach (i : py_range(MAX_COMPANIONS)) {
        if (CompanionActive[i] && CompanionOwner[i] == player) count += 1;
    }
    return count;
}

function findFreeCompanionSlot(player) {
    if (getPlayerCompanionCount(player) >= MAX_COMPANIONS_PER_PLAYER) return -1;

    foreach (i : py_range(MAX_COMPANIONS)) {
        if (!CompanionActive[i]) return i;
    }
    return -1;
}

function registerCompanion(player, unit, companionType) {
    const slot = findFreeCompanionSlot(player);
    if (slot < 0) return -1;

    CompanionActive[slot] = 1;
    CompanionOwner[slot] = player;
    CompanionType[slot] = companionType;
    CompanionUnit[slot] = unit;
    CompanionControlMode[slot] = 0;
    return slot;
}

function craftRoboticFighter(player) {
    if (getPlayerCompanionCount(player) >= MAX_COMPANIONS_PER_PLAYER) return -1;
    const p = TrgPlayer(player);
    if (p.mineral < ROBOTIC_FIGHTER_MINERAL_COST || p.gas < ROBOTIC_FIGHTER_GAS_COST) return -1;
    p.mineral -= ROBOTIC_FIGHTER_MINERAL_COST;
    p.gas -= ROBOTIC_FIGHTER_GAS_COST;

    const hero = players.getPlayerHeroUnit(player);
    hero.setloc($L("_Place"));
    const unit = utils.createUnitAndGetEpd(1, ROBOTIC_FIGHTER_UNIT, $L("_Place"), player);
    return registerCompanion(player, unit, COMPANION_ROBOTIC);
}

function tameZerg(player, target) {
    // Caller is responsible for confirming the target is stunned/eligible
    // before calling this -- tameZerg only performs the ownership transfer.
    if (getPlayerCompanionCount(player) >= MAX_COMPANIONS_PER_PLAYER) return -1;

    const unit = CUnit(target);
    unit.cgive(TrgPlayer(player));
    return registerCompanion(player, target, COMPANION_TAMED_ZERG);
}

function resurrectZerg(player, corpseOrMarker) {
    if (getPlayerCompanionCount(player) >= MAX_COMPANIONS_PER_PLAYER) return -1;
    const p = TrgPlayer(player);
    if (p.gas < RESURRECT_GAS_COST) return -1;
    p.gas -= RESURRECT_GAS_COST;

    const marker = CUnit(corpseOrMarker);
    marker.setloc($L("_Place"));
    const unit = utils.createUnitAndGetEpd(1, RESURRECTED_ZERG_UNIT, $L("_Place"), player);
    return registerCompanion(player, unit, COMPANION_RESURRECTED_ZERG);
}

function destroyPlayerCompanions(player) {
    foreach (i : py_range(MAX_COMPANIONS)) {
        if (CompanionActive[i] && CompanionOwner[i] == player) {
            utils.removeCUnit(CUnit(CompanionUnit[i]));
            CompanionActive[i] = 0;
            CompanionOwner[i] = -1;
            CompanionUnit[i] = 0;
        }
    }
}

function updateCompanionOrders(player) {
    // Default behavior: keep companions near their commander. Manual
    // attack/move overrides via menu/command hooks are not wired up yet
    // (CompanionControlMode stays 0 for every companion for now).
    const hero = players.getPlayerHeroUnit(player);
    foreach (i : py_range(MAX_COMPANIONS)) {
        if (CompanionActive[i] && CompanionOwner[i] == player && CompanionControlMode[i] == 0) {
            const unit = CUnit(CompanionUnit[i]);
            const dx = unit.posX > hero.posX ? unit.posX - hero.posX : hero.posX - unit.posX;
            const dy = unit.posY > hero.posY ? unit.posY - hero.posY : hero.posY - unit.posY;
            if (dx > COMPANION_FOLLOW_DISTANCE || dy > COMPANION_FOLLOW_DISTANCE) {
                unit.orderID = ORDER_MOVE;
                unit.orderTarget = hero;
            }
        }
    }
}

function updateCompanions() {
    foreach (p : py_range(constants.MAX_PLAYERS)) {
        if (players.HeroAlive[p]) updateCompanionOrders(p);
    }
}
