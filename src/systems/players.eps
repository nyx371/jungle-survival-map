// Player Hero State, Death, and Respawn

import core.constants;
import core.dat_registry;
import core.utils;
import systems.day_night;
import systems.audio;
import systems.companions;
import systems.resources;
import systems.structures;
import systems.upgrades;
import systems.weapons;

const RESPAWN_DELAY_FRAMES = 12 * constants.FRAMES_PER_GAME_SECOND;
const DEATH_RESOURCE_KEEP_PERCENT = 20;

const HeroAlive = EUDArray(constants.MAX_PLAYERS);
const RespawnTimer = EUDArray(constants.MAX_PLAYERS);
const DeathsThisRun = EUDArray(constants.MAX_PLAYERS);
const LastKnownX = EUDArray(constants.MAX_PLAYERS);
const LastKnownY = EUDArray(constants.MAX_PLAYERS);
const PlayerHeroCUnit = EUDArray(constants.MAX_PLAYERS);
const Screen = StringBuffer(256);

const PLAYER_STATUS_RESTED = 0;
const PLAYER_STATUS_OK = 1;
const PLAYER_STATUS_HUNGRY = 2;
const PLAYER_STATUS_STARVING = 3;

const HERO_BASE_ENERGY_MAX = 250 * 256;
const HERO_RESTED_ENERGY_LEVEL = 200 * 256;
const HERO_HUNGRY_ENERGY_LEVEL = 80 * 256;
const HERO_ENERGY_DRAIN_NIGHT = 1 * 256 / 4;
const HERO_ENERGY_REGEN_DAY = 1 * 256 / 8;
const HERO_HP_REGEN_RESTED = 1 * 256 / 2;
const HERO_HP_DRAIN_STARVING = 1 * 256 / 5;

const PlayerEnergy = EUDArray(constants.MAX_PLAYERS);
const PlayerEnergyMax = EUDArray(constants.MAX_PLAYERS);
const PlayerStatus = EUDArray(constants.MAX_PLAYERS);

function createPlayerHero(player) {
    // PlayerHeroUnits is a compile-time list; it can only be indexed by a
    // compile-time constant, so dispatch on the runtime player id via switch.
    // Case count must match MAX_PLAYERS in core/constants.eps.
    // Heroes spawn at the map location named "G".
    switch (player) {
    case 0:
        if (playerexist(player)) { // only for active (non-vacant) player slots
            PlayerHeroCUnit[player] = utils.createUnitAndGetEpd(1, dat_registry.PlayerHeroUnits[0], $L("G"), player);
        }
        break;
    case 1:
        if (playerexist(player)) { // only for active (non-vacant) player slots
            PlayerHeroCUnit[player] = utils.createUnitAndGetEpd(1, dat_registry.PlayerHeroUnits[1], $L("G"), player);
        }
        break;
    case 2:
        if (playerexist(player)) { // only for active (non-vacant) player slots
            PlayerHeroCUnit[player] = utils.createUnitAndGetEpd(1, dat_registry.PlayerHeroUnits[2], $L("G"), player);
        }
        break;
    case 3:
        if (playerexist(player)) { // only for active (non-vacant) player slots
            PlayerHeroCUnit[player] = utils.createUnitAndGetEpd(1, dat_registry.PlayerHeroUnits[3], $L("G"), player);
        }
        break;
    case 4:
        if (playerexist(player)) { // only for active (non-vacant) player slots
            PlayerHeroCUnit[player] = utils.createUnitAndGetEpd(1, dat_registry.PlayerHeroUnits[4], $L("G"), player);
        }
        break;
    }
}

function getPlayerHeroUnit(player) : CUnit {
    return CUnit(PlayerHeroCUnit[player]);
}

function initPlayers() {
    foreach (p : py_range(constants.MAX_PLAYERS)) {
        HeroAlive[p] = 1;
        RespawnTimer[p] = 0;
        DeathsThisRun[p] = 0;
        LastKnownX[p] = 0;
        LastKnownY[p] = 0;
        PlayerEnergyMax[p] = HERO_BASE_ENERGY_MAX;
        PlayerEnergy[p] = PlayerEnergyMax[p];
        PlayerStatus[p] = PLAYER_STATUS_OK;
        createPlayerHero(p);
    }
}

function spendPlayerEnergy(player, amount) {
    if (PlayerEnergy[player] < amount) return 0;
    PlayerEnergy[player] -= amount;
    return 1;
}

function restorePlayerEnergy(player, amount) {
    if (PlayerEnergy[player] + amount > PlayerEnergyMax[player]) PlayerEnergy[player] = PlayerEnergyMax[player];
    else PlayerEnergy[player] += amount;
}

function updatePlayerStatus(player) {
    if (PlayerEnergy[player] >= HERO_RESTED_ENERGY_LEVEL) PlayerStatus[player] = PLAYER_STATUS_RESTED;
    else if (PlayerEnergy[player] == 0) PlayerStatus[player] = PLAYER_STATUS_STARVING;
    else if (PlayerEnergy[player] < HERO_HUNGRY_ENERGY_LEVEL) PlayerStatus[player] = PLAYER_STATUS_HUNGRY;
    else PlayerStatus[player] = PLAYER_STATUS_OK;
}

function healPlayerHero(player, amount) {
    const hero = getPlayerHeroUnit(player);
    var maxHp = 0;
    switch (player) {
    case 0: maxHp = dat_registry.PlayerHeroUnits[0].maxHp; break;
    case 1: maxHp = dat_registry.PlayerHeroUnits[1].maxHp; break;
    case 2: maxHp = dat_registry.PlayerHeroUnits[2].maxHp; break;
    case 3: maxHp = dat_registry.PlayerHeroUnits[3].maxHp; break;
    case 4: maxHp = dat_registry.PlayerHeroUnits[4].maxHp; break;
    }
    if (hero.hp + amount > maxHp) hero.hp = maxHp;
    else hero.hp += amount;
}

function damagePlayerHero(player, amount) {
    const hero = getPlayerHeroUnit(player);
    if (hero.hp <= amount) hero.hp = 0;
    else hero.hp -= amount;
}

function updatePlayerVitals(player) {
    if (!HeroAlive[player]) return;

    if (day_night.IsNight) {
        if (PlayerEnergy[player] > HERO_ENERGY_DRAIN_NIGHT) PlayerEnergy[player] -= HERO_ENERGY_DRAIN_NIGHT;
        else PlayerEnergy[player] = 0;
    } else {
        restorePlayerEnergy(player, HERO_ENERGY_REGEN_DAY);
    }

    updatePlayerStatus(player);

    if (PlayerStatus[player] == PLAYER_STATUS_RESTED) {
        healPlayerHero(player, HERO_HP_REGEN_RESTED);
    } else if (PlayerStatus[player] == PLAYER_STATUS_STARVING) {
        damagePlayerHero(player, HERO_HP_DRAIN_STARVING);
    }

    const hero = getPlayerHeroUnit(player);
    hero.energy = PlayerEnergy[player];
}

function markPlayerDead(player) {
    HeroAlive[player] = 0;
    RespawnTimer[player] = RESPAWN_DELAY_FRAMES;
    DeathsThisRun[player] += 1;

    resources.loseMostMinerals(player, DEATH_RESOURCE_KEEP_PERCENT);
    resources.loseMostGas(player, DEATH_RESOURCE_KEEP_PERCENT);
    companions.destroyPlayerCompanions(player);
    structures.destroyPlayerStructures(player);
    resources.clearHarvestState(player);
    audio.clearAudioDangerState(player);
    PlayerEnergy[player] = PlayerEnergyMax[player] / 2;
    updatePlayerStatus(player);
}

function respawnPlayer(player) {
    // TODO: pick a random valid respawn position away from mob clusters.
    // TODO: remove/clean up any surviving previous hero unit before creating a new one.
    createPlayerHero(player);
    HeroAlive[player] = 1;
    upgrades.applyHeroUpgradeDat(player);
    weapons.applyActiveWeaponDat(player);
    PlayerEnergy[player] = PlayerEnergyMax[player];
    updatePlayerStatus(player);
    DisplayTextAll("A commando has re-entered the jungle.");
}

function updatePlayerDeathState(player) {
    if (HeroAlive[player] == 0) {
        if (RespawnTimer[player] > 0) {
            RespawnTimer[player] -= 1;
        } else {
            respawnPlayer(player);
        }
    } else if (getPlayerHeroUnit(player).orderID == 0) {
        // orderID 0 is the Die order; the tracked hero CUnit has died.
        markPlayerDead(player);
    }
}

const ORDER_PLAYER_GUARD = 3;
const ORDER_HARVEST_MINERALS = 87;
const ORDER_HOLD_POSITION = 107;
const MINING_ORDER_TIMER = 35;

function updatePlayerHeroBehavior(player) {
    if (!HeroAlive[player]) return;
    const hero = getPlayerHeroUnit(player);

    if (hero.orderID == ORDER_PLAYER_GUARD) {
        hero.orderID = ORDER_HOLD_POSITION; // always hold position when idle
    }

    if (hero.orderID == ORDER_HARVEST_MINERALS && hero.orderState == 5) {
        // Prevents the mining-order crash: keep the order timer from running
        // out, granting minerals on each mining tick instead of letting the
        // order complete/reset normally.
        if (hero.orderTimer > MINING_ORDER_TIMER) {
            hero.orderTimer = MINING_ORDER_TIMER;
        } else if (hero.orderTimer < 2) {
            hero.orderTimer = MINING_ORDER_TIMER;
            resources.addMinerals(player, 8);

            const target = hero.orderTarget;
            target.setloc($L("_Place"));
            utils.createImageSpriteAtLocation(368, $L("_Place"));
        }
    }
}

function updatePlayerDebugInfo(player, localPlayer) {
    if (player != localPlayer) return;

    const savedCp = getcurpl();
    setcurpl(localPlayer);
    if (RespawnTimer[player] > 0) {
        Screen.printfAt(0, "{}", RespawnTimer[player]);
    }
    const hero = getPlayerHeroUnit(player);
    Screen.printfAt(1, "{}", hero.orderID);
    setcurpl(savedCp);
}

function updatePlayers() {
    const localPlayer = getuserplayerid();
    foreach (p : py_range(constants.MAX_PLAYERS)) {
        updatePlayerDeathState(p);
        updatePlayerVitals(p);
        updatePlayerHeroBehavior(p);
        updatePlayerDebugInfo(p, localPlayer);
    }
}
