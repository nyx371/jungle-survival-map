// Player Hero State, Death, and Respawn

import core.constants;
import core.dat_registry;
import core.utils;
import systems.day_night;
import systems.companions;
import systems.resources;
import systems.structures;
import systems.upgrades;
import systems.weapons;
import systems.mobs;

const RESPAWN_DELAY_FRAMES = 3 * constants.FRAMES_PER_GAME_SECOND;
const DEATH_RESOURCE_KEEP_PERCENT = 20;
const RESPAWN_SEARCH_RADIUS = 15 * 32;
const RESPAWN_MIN_MOB_DISTANCE = 8 * 32;
const RESPAWN_ATTEMPTS = 5;

// Map authors pre-place Terran Beacon units to mark valid random spawn
// positions, owned neutrally on P7 (matching the resource-node/mob-spawn
// marker convention).
const PLAYER_SPAWN_MARKER_UNIT = $U("Terran Beacon");
const PLAYER_SPAWN_MARKER_OWNER = P7;
const MAX_PLAYER_SPAWN_MARKERS = 64;

const HeroAlive = EUDArray(constants.MAX_PLAYERS);
const RespawnTimer = EUDArray(constants.MAX_PLAYERS);
const DeathsThisRun = EUDArray(constants.MAX_PLAYERS);
const LastKnownX = EUDArray(constants.MAX_PLAYERS);
const LastKnownY = EUDArray(constants.MAX_PLAYERS);
const PlayerHeroCUnit = EUDArray(constants.MAX_PLAYERS);
const PlayerWeaponShots = EUDArray(constants.MAX_PLAYERS);
const Screen = StringBuffer(256);

const PLAYER_STATUS_RESTED = 0;
const PLAYER_STATUS_OK = 1;
const PLAYER_STATUS_HUNGRY = 2;
const PLAYER_STATUS_STARVING = 3;

const HERO_BASE_ENERGY_MAX = 250 * 256;
const HERO_RESTED_ENERGY_LEVEL = 200 * 256;
const HERO_HUNGRY_ENERGY_LEVEL = 80 * 256;
const HERO_ENERGY_DRAIN_NIGHT = 1 * 256 / 4;
const HERO_ENERGY_REGEN_DAY = 1 * 256 / 8;
const HERO_HP_REGEN_RESTED = 1 * 256 / 20;
const HERO_HP_DRAIN_STARVING = 1 * 256 / 5;

const MINING_ORDER_TIMER = 35;

const PlayerEnergy = EUDArray(constants.MAX_PLAYERS);
const PlayerEnergyMax = EUDArray(constants.MAX_PLAYERS);
const PlayerStatus = EUDArray(constants.MAX_PLAYERS);

// Per-player mining state machine. Lives here (not resources.eps) so all
// per-player order handling is in one file; resources.eps still owns the
// resource-node data (yield rates, node type, sounds) that this reads.
const HARVEST_CHOP_FRAMES = 17; // ~0.75s sfx + mining-swing sub-beat; several per cycle (23 fps)
const IsHarvesting = EUDArray(constants.MAX_PLAYERS);
const HarvestTarget = EUDArray(constants.MAX_PLAYERS);
const HarvestTick = EUDArray(constants.MAX_PLAYERS);       // counts down to next payout
const HarvestTimerFrames = EUDArray(constants.MAX_PLAYERS); // per-type payout period (resources.getHarvestTimer)
const HarvestChopTick = EUDArray(constants.MAX_PLAYERS);

const PlayerSpawnMarkerX = EUDArray(MAX_PLAYER_SPAWN_MARKERS);
const PlayerSpawnMarkerY = EUDArray(MAX_PLAYER_SPAWN_MARKERS);
var PlayerSpawnMarkerCount = 0;

function indexPlayerSpawnMarker(markerUnit : CUnit) {
    const markerIndex = PlayerSpawnMarkerCount;
    if (markerIndex >= MAX_PLAYER_SPAWN_MARKERS) return;

    PlayerSpawnMarkerX[markerIndex] = markerUnit.posX;
    PlayerSpawnMarkerY[markerIndex] = markerUnit.posY;
    PlayerSpawnMarkerCount += 1;

    utils.removeCUnit(markerUnit);
}

function indexPlayerSpawnMarkers() {
    PlayerSpawnMarkerCount = 0;

    // Collect first, then index+remove afterward: removing units while
    // iterating EUDLoopPlayerCUnit would disrupt that same iteration.
    const found = EUDQueue(MAX_PLAYER_SPAWN_MARKERS)();
    foreach (unit : EUDLoopPlayerCUnit(PLAYER_SPAWN_MARKER_OWNER)) {
        if (unit.unitType == PLAYER_SPAWN_MARKER_UNIT) {
            found.append(unit);
        }
    }

    while (!found.empty()) {
        indexPlayerSpawnMarker(CUnit(found.popleft()));
    }
}

function pickRandomSpawnPoint() {
    // Prefer a random Terran Beacon marker; fall back to a random point near
    // the map's "G" drop zone if no markers were placed.
    if (PlayerSpawnMarkerCount > 0) {
        const marker = f_rand() % PlayerSpawnMarkerCount;
        return PlayerSpawnMarkerX[marker], PlayerSpawnMarkerY[marker];
    }

    const baseX, baseY = getlocTL($L("G"));
    return baseX + f_rand() % (RESPAWN_SEARCH_RADIUS * 2) - RESPAWN_SEARCH_RADIUS,
           baseY + f_rand() % (RESPAWN_SEARCH_RADIUS * 2) - RESPAWN_SEARCH_RADIUS;
}

function pickRespawnPosition() {
    // Retry a few times to avoid dropping the player directly on top of an
    // active mob cluster.
    foreach (attempt : py_range(RESPAWN_ATTEMPTS)) {
        const x, y = pickRandomSpawnPoint();

        var safe = 1;
        foreach (i : py_range(mobs.MAX_ACTIVE_MOBS)) {
            if (mobs.MobActive[i]) {
                const mob = CUnit(mobs.MobUnit[i]);
                const mdx = x > mob.posX ? x - mob.posX : mob.posX - x;
                const mdy = y > mob.posY ? y - mob.posY : mob.posY - y;
                if (mdx < RESPAWN_MIN_MOB_DISTANCE && mdy < RESPAWN_MIN_MOB_DISTANCE) {
                    safe = 0;
                }
            }
        }
        if (safe) return x, y;
    }
    return pickRandomSpawnPoint();
}

// --- Ghost/hero audio: hurt, footsteps, low-HP heartbeat, spawn breath ---
const LOW_HP_PERCENT = 30;

// Hurt: randomized between variants, rate-limited so damage doesn't spam it.
const HURT_SFX = [
    StringBuffer("staredit/wav/player_hurt_01.ogg"),
    StringBuffer("staredit/wav/player_hurt_02.ogg"),
    StringBuffer("staredit/wav/player_hurt_03.ogg"),
    StringBuffer("staredit/wav/player_hurt_04.ogg"),
];
const HURT_SFX_COUNT = 4;
const HURT_SOUND_COOLDOWN = 3 * constants.FRAMES_PER_GAME_SECOND;

// Footsteps: randomized (never the same twice in a row), on a walk cadence.
const STEP_SFX = [
    StringBuffer("staredit/wav/player_step_grass_01.ogg"),
    StringBuffer("staredit/wav/player_step_grass_02.ogg"),
    StringBuffer("staredit/wav/player_step_grass_03.ogg"),
    StringBuffer("staredit/wav/player_step_grass_04.ogg"),
    StringBuffer("staredit/wav/player_step_grass_05.ogg"),
    StringBuffer("staredit/wav/player_step_grass_06.ogg"),
];
const STEP_SFX_COUNT = 6;
const STEP_SOUND_INTERVAL = 7; // ~0.3s between footsteps while moving (23 fps)

// Low-HP heartbeat. Cooldown matches the heartbeat.ogg clip length (~2.1s).
const HEARTBEAT_WAV = "staredit/wav/heartbeat.ogg";
const HEARTBEAT_COOLDOWN = 48;

// One-shot Ghost breath played when a hero (re)spawns.
const GHOST_SPAWN_WAV = "staredit/wav/breath.ogg";

const LastHp = EUDArray(constants.MAX_PLAYERS);
const HurtSoundTimer = EUDArray(constants.MAX_PLAYERS);
const StepSoundTimer = EUDArray(constants.MAX_PLAYERS);
const StepLastSfx = EUDArray(constants.MAX_PLAYERS); // last footstep index; never repeat it
const HeartbeatTimer = EUDArray(constants.MAX_PLAYERS);

function initPlayerAudio() {
    foreach (p : py_range(constants.MAX_PLAYERS)) {
        LastHp[p] = 0;
        HurtSoundTimer[p] = 0;
        StepSoundTimer[p] = 0;
        StepLastSfx[p] = 0;
        HeartbeatTimer[p] = 0;
    }
}

function clearPlayerAudioDangerState(player) {
    HurtSoundTimer[player] = 0;
    StepSoundTimer[player] = 0;
    HeartbeatTimer[player] = 0;
}

function playGhostSpawnSfx(player) {
    const savedCp = getcurpl();
    setcurpl(player);
    PlayWAV(GHOST_SPAWN_WAV);
    setcurpl(savedCp);
}

function createPlayerHero(player) {
    // PlayerHeroUnits is a compile-time list; it can only be indexed by a
    // compile-time constant, so dispatch on the runtime player id via switch.
    // Case count must match MAX_PLAYERS in core/constants.eps.
    const x, y = pickRespawnPosition();
    setloc($L("_Place"), x, y);

    switch (player) {
    case 0:
        if (playerexist(player)) { // only for active (non-vacant) player slots
            PlayerHeroCUnit[player] = utils.createUnitAndGetEpd(1, dat_registry.PlayerHeroUnits[0], $L("_Place"), player);
        }
        break;
    case 1:
        if (playerexist(player)) { // only for active (non-vacant) player slots
            PlayerHeroCUnit[player] = utils.createUnitAndGetEpd(1, dat_registry.PlayerHeroUnits[1], $L("_Place"), player);
        }
        break;
    case 2:
        if (playerexist(player)) { // only for active (non-vacant) player slots
            PlayerHeroCUnit[player] = utils.createUnitAndGetEpd(1, dat_registry.PlayerHeroUnits[2], $L("_Place"), player);
        }
        break;
    case 3:
        if (playerexist(player)) { // only for active (non-vacant) player slots
            PlayerHeroCUnit[player] = utils.createUnitAndGetEpd(1, dat_registry.PlayerHeroUnits[3], $L("_Place"), player);
        }
        break;
    case 4:
        if (playerexist(player)) { // only for active (non-vacant) player slots
            PlayerHeroCUnit[player] = utils.createUnitAndGetEpd(1, dat_registry.PlayerHeroUnits[4], $L("_Place"), player);
        }
        break;
    }

    if (playerexist(player)) {
        playGhostSpawnSfx(player);
    }
}

function getPlayerHeroUnit(player) : CUnit {
    return CUnit(PlayerHeroCUnit[player]);
}

function clearHarvestState(player) {
    IsHarvesting[player] = 0;
    HarvestTarget[player] = 0;
    HarvestTick[player] = 0;
    HarvestTimerFrames[player] = 0;
    HarvestChopTick[player] = 0;
}

// The ghost's command card repurposes 8 train buttons as ability triggers.
// They map to units in this id range (see updatePlayerCommandCard).
const COMMAND_CARD_UNIT_FIRST = 73;
const COMMAND_CARD_UNIT_LAST = 81;

// Zero out the mineral/gas/supply cost of those units so their command-card
// buttons are always clickable (a real cost would grey them out / block the
// queue). One-time DAT setup.
function initCommandCardUnits() {
    foreach (trainUnit : py_range(COMMAND_CARD_UNIT_FIRST, COMMAND_CARD_UNIT_LAST + 1)) {
        const u = TrgUnit(trainUnit);
        u.mineralCost = 0;
        u.gasCost = 0;
        u.supplyUsed = 0;
    }
}

function initPlayers() {
    indexPlayerSpawnMarkers();
    initPlayerAudio();
    initCommandCardUnits();
    foreach (p : py_range(constants.MAX_PLAYERS)) {
        HeroAlive[p] = 1;
        RespawnTimer[p] = 0;
        DeathsThisRun[p] = 0;
        LastKnownX[p] = 0;
        LastKnownY[p] = 0;
        PlayerWeaponShots[p] = 0;
        PlayerEnergyMax[p] = HERO_BASE_ENERGY_MAX;
        PlayerEnergy[p] = PlayerEnergyMax[p];
        PlayerStatus[p] = PLAYER_STATUS_OK;
        clearHarvestState(p);
        createPlayerHero(p);
    }
}

function spendPlayerEnergy(player, amount) {
    if (PlayerEnergy[player] < amount) return 0;
    PlayerEnergy[player] -= amount;
    return 1;
}

function restorePlayerEnergy(player, amount) {
    if (PlayerEnergy[player] + amount > PlayerEnergyMax[player]) PlayerEnergy[player] = PlayerEnergyMax[player];
    else PlayerEnergy[player] += amount;
}

function updatePlayerStatus(player) {
    if (PlayerEnergy[player] >= HERO_RESTED_ENERGY_LEVEL) PlayerStatus[player] = PLAYER_STATUS_RESTED;
    else if (PlayerEnergy[player] == 0) PlayerStatus[player] = PLAYER_STATUS_STARVING;
    else if (PlayerEnergy[player] < HERO_HUNGRY_ENERGY_LEVEL) PlayerStatus[player] = PLAYER_STATUS_HUNGRY;
    else PlayerStatus[player] = PLAYER_STATUS_OK;
}

function getPlayerHeroMaxHp(player) {
    var maxHp = 0;
    switch (player) {
    case 0: maxHp = dat_registry.PlayerHeroUnits[0].maxHp; break;
    case 1: maxHp = dat_registry.PlayerHeroUnits[1].maxHp; break;
    case 2: maxHp = dat_registry.PlayerHeroUnits[2].maxHp; break;
    case 3: maxHp = dat_registry.PlayerHeroUnits[3].maxHp; break;
    case 4: maxHp = dat_registry.PlayerHeroUnits[4].maxHp; break;
    }
    return maxHp;
}

function healPlayerHero(player, amount) {
    const hero = getPlayerHeroUnit(player);
    const maxHp = getPlayerHeroMaxHp(player);
    if (hero.hp + amount > maxHp) hero.hp = maxHp;
    else hero.hp += amount;
}

function damagePlayerHero(player, amount) {
    const hero = getPlayerHeroUnit(player);
    if (hero.hp <= amount) hero.hp = 0;
    else hero.hp -= amount;
}

function updatePlayerVitals(player) {
    if (!HeroAlive[player]) return;

    if (day_night.IsNight) {
        if (PlayerEnergy[player] > HERO_ENERGY_DRAIN_NIGHT) PlayerEnergy[player] -= HERO_ENERGY_DRAIN_NIGHT;
        else PlayerEnergy[player] = 0;
    } else {
        restorePlayerEnergy(player, HERO_ENERGY_REGEN_DAY);
    }

    updatePlayerStatus(player);

    if (PlayerStatus[player] == PLAYER_STATUS_RESTED) {
        healPlayerHero(player, HERO_HP_REGEN_RESTED);
    } else if (PlayerStatus[player] == PLAYER_STATUS_STARVING) {
        damagePlayerHero(player, HERO_HP_DRAIN_STARVING);
    }

    const hero = getPlayerHeroUnit(player);
    hero.energy = PlayerEnergy[player];
}

function markPlayerDead(player) {
    HeroAlive[player] = 0;
    RespawnTimer[player] = RESPAWN_DELAY_FRAMES;
    DeathsThisRun[player] += 1;

    resources.loseMostMinerals(player, DEATH_RESOURCE_KEEP_PERCENT);
    resources.loseMostGas(player, DEATH_RESOURCE_KEEP_PERCENT);
    companions.destroyPlayerCompanions(player);
    structures.destroyPlayerStructures(player);
    clearHarvestState(player);
    clearPlayerAudioDangerState(player);
    PlayerEnergy[player] = PlayerEnergyMax[player] / 2;
    updatePlayerStatus(player);
}

function respawnPlayer(player) {
    const oldHero = CUnit(PlayerHeroCUnit[player]);
    if (oldHero != 0) {
        utils.removeCUnit(oldHero);
    }

    createPlayerHero(player);
    HeroAlive[player] = 1;
    upgrades.applyHeroUpgradeDat(player);
    weapons.applyActiveWeaponDat(player);
    PlayerEnergy[player] = PlayerEnergyMax[player];
    updatePlayerStatus(player);
    const savedCp = getcurpl();
    setcurpl(player);
    DisplayText("A commando has re-entered the jungle.");
    setcurpl(savedCp);
}

function updatePlayerDeathState(player) {
    if (HeroAlive[player] == 0) {
        if (RespawnTimer[player] > 0) {
            RespawnTimer[player] -= 1;
        } else {
            respawnPlayer(player);
        }
    } else if (getPlayerHeroUnit(player).orderID == constants.ORDER_DIE) {
        // orderID 0 is the Die order; the tracked hero CUnit has died.
        markPlayerDead(player);
    }
}


function startHarvest(player, target) {
    const resourceType = resources.getHarvestTargetResourceType(target);
    IsHarvesting[player] = 1;
    HarvestTarget[player] = target;
    HarvestTimerFrames[player] = resources.getHarvestTimer(resourceType);
    HarvestTick[player] = HarvestTimerFrames[player];
    HarvestChopTick[player] = 0;
}

function finishHarvestTick(player) {
    const resourceType = resources.getHarvestTargetResourceType(HarvestTarget[player]);
    const minerals, gas = resources.getHarvestRates(resourceType);
    resources.addHarvestResources(player, minerals, gas);

    // Deplete the node's own real resourceAmount; remove it once exhausted.
    const node = CUnit(HarvestTarget[player]);
    const drained = minerals + gas;
    if (node.resourceAmount <= drained) {
        utils.removeCUnit(node);
        clearHarvestState(player);
    } else {
        node.resourceAmount -= drained;
    }
}

// One mining swing: plays a resource-type sound and spawns the swing
// visual on the targeted node. Fires several times per resource-yield cycle.
function harvestChop(player) {
    const target = getPlayerHeroUnit(player).orderTarget;
    const resourceType = resources.getHarvestTargetResourceType(HarvestTarget[player]);
    resources.playMiningSfx(player, resourceType);
    resources.playMiningToolSfx(player);
    utils.createImageSpriteOnUnit(526, target);
}

// Drives continuous right-click mining off the hero's harvest order. Owns
// the whole mining loop: the sfx + swing visual (several chops per cycle)
// and the resource payout (once per cycle). The order-timer crash guard in
// updatePlayerHeroBehavior is separate and can be retired once this is proven.
function updatePlayerHarvesting(player) {
    const hero = getPlayerHeroUnit(player);
    const targetingResource = hero.orderID == constants.ORDER_HARVEST_MINERALS_3 && hero.orderTarget != 0;

    if (!IsHarvesting[player]) {
        if (targetingResource) {
            startHarvest(player, hero.orderTarget);
        }
        return;
    }

    // Cancel harvest if the player gave another order or the target is gone.
    if (!targetingResource) {
        clearHarvestState(player);
        return;
    }

    // Sfx + swing visual several times across the cycle.
    if (HarvestChopTick[player] > 0) {
        HarvestChopTick[player] -= 1;
    } else {
        HarvestChopTick[player] = HARVEST_CHOP_FRAMES;
        harvestChop(player);
    }

    // Resource payout once per full cycle.
    if (HarvestTick[player] > 0) {
        HarvestTick[player] -= 1;
    } else {
        HarvestTick[player] = HarvestTimerFrames[player];
        finishHarvestTick(player);
    }
}

function updatePlayerHeroBehavior(player) {
    const savedCp = getcurpl();
    setcurpl(player);    
    if (!HeroAlive[player]) return;
    const hero = getPlayerHeroUnit(player);

    if (hero.orderID == constants.ORDER_IDLE_REAVER) {
        // utils.createImageSpriteOnUnit(constants.IMAGE_VESPENE_GEYSER_SMOKE1, hero);
        PlayWAV("sound\\bullet\\psahit00.wav");
        hero.orderID = constants.ORDER_PLAYER_GUARD;
    }

    if (hero.orderID == constants.ORDER_EMP_SHOCKWAVE) {
        utils.createImageSpriteAtPoint(constants.IMAGE_VESPENE_GEYSER_SMOKE1, hero.orderTargetX, hero.orderTargetY);
        PlayWAV("sound\\bullet\\psahit00.wav");
        hero.orderID = constants.ORDER_PLAYER_GUARD;
    }

    if (hero.orderID == constants.ORDER_PLAYER_GUARD) {
        hero.orderID = constants.ORDER_HOLD_POSITION_2; // always hold position when idle
    }

    if (hero.orderID == constants.ORDER_ATTACK_UNIT) {
        if (hero.groundWeaponCooldown > 10) {
            // PlayWAV("sound\\bullet\\psahit00.wav");
            PlayerWeaponShots[player] += 1;
            hero.groundWeaponCooldown = 10;
            if (TrgUnit(constants.UNIT_TERRAN_GHOST).groundWeapon != constants.WEAPON_C_10_CONCUSSION_RIFLE) {
                TrgUnit(constants.UNIT_TERRAN_GHOST).groundWeapon = constants.WEAPON_C_10_CONCUSSION_RIFLE;
            }

            if (PlayerWeaponShots[player] >= 10) {
                PlayerWeaponShots[player] = 0;
                TrgUnit(constants.UNIT_TERRAN_GHOST).groundWeapon = constants.WEAPON_FLECHETTE_GRENADE;
            }
        }        
    }


    if (hero.orderID == constants.ORDER_HARVEST_MINERALS_3 && hero.orderState == 5) {
        // Prevents the mining-order crash: keep the order timer from running
        // out instead of letting the order complete/reset normally. Actual
        // resource yield is handled by resources.eps (updateHarvesting /
        // finishHarvestTick), which reads this same order/target.
        if (hero.orderTimer == 10) {
            hero.orderTimer = MINING_ORDER_TIMER;
        }
    }
    setcurpl(savedCp);
}

function updatePlayerDebugInfo(player, localPlayer) {
    if (player != localPlayer) return;

    const savedCp = getcurpl();
    setcurpl(localPlayer);
    if (RespawnTimer[player] > 0) {
        Screen.printfAt(0, "{}", RespawnTimer[player]);
    }
    const hero = getPlayerHeroUnit(player);
    Screen.printfAt(1, "{} {} {} {}", hero.orderID, hero.secondaryOrder, hero.orderTimer,  hero.groundWeaponCooldown);
    setcurpl(savedCp);
}

function updatePlayerAudio(player) {
    if (!HeroAlive[player]) return;

    const hero = getPlayerHeroUnit(player);
    const maxHp = getPlayerHeroMaxHp(player);
    const currentHp = hero.hp;

    // Hurt sound: fire once when HP drops, then hold off for the cooldown.
    if (currentHp < LastHp[player] && HurtSoundTimer[player] == 0) {
        utils.playSoundArray(HURT_SFX, player, HURT_SFX_COUNT);
        HurtSoundTimer[player] = HURT_SOUND_COOLDOWN;
    }
    if (HurtSoundTimer[player] > 0) HurtSoundTimer[player] -= 1;

    // Footsteps while moving (Move / Attack Move), on a step cadence.
    if (hero.orderID == constants.ORDER_MOVE || hero.orderID == constants.ORDER_ATTACK_MOVE || hero.orderID == constants.ORDER_HARVEST_MINERALS_1) {
        if (StepSoundTimer[player] == 0) {
            var idx = f_rand() % (STEP_SFX_COUNT - 1);
            if (idx >= StepLastSfx[player]) idx += 1;
            utils.playSoundArrayAt(STEP_SFX, player, idx);
            StepLastSfx[player] = idx;
            StepSoundTimer[player] = STEP_SOUND_INTERVAL;
        }
    }
    if (StepSoundTimer[player] > 0) StepSoundTimer[player] -= 1;

    // Low-HP heartbeat.
    if (maxHp > 0 && currentHp * 100 / maxHp <= LOW_HP_PERCENT) {
        if (HeartbeatTimer[player] == 0) {
            const savedCp = getcurpl();
            setcurpl(player);
            PlayWAV(HEARTBEAT_WAV);
            setcurpl(savedCp);
            HeartbeatTimer[player] = HEARTBEAT_COOLDOWN;
        }
    }
    if (HeartbeatTimer[player] > 0) HeartbeatTimer[player] -= 1;

    LastHp[player] = currentHp;
}

// Ghost command-card train buttons are repurposed as ability triggers.
// check_buildq detects which unit a button queued; for now just report the
// id. Always reset_buildq at the end so nothing actually trains and the next
// press reads fresh. (Options 1-8 map to units ~74..81; checking 73..81
// covers the range so the printout reveals the real option->unit mapping.)
function updatePlayerCommandCard(player) {
    if (!HeroAlive[player]) return;
    const hero = getPlayerHeroUnit(player);

    foreach (trainUnit : py_range(COMMAND_CARD_UNIT_FIRST, COMMAND_CARD_UNIT_LAST + 1)) {
        if (hero.check_buildq(trainUnit)) {
            const savedCp = getcurpl();
            setcurpl(player);
            Screen.printf("Command card: unit {}", trainUnit);
            setcurpl(savedCp);
        }
    }
    hero.reset_buildq();
}

function updatePlayers() {
    const localPlayer = getuserplayerid();
    foreach (p : py_range(constants.MAX_PLAYERS)) {
        updatePlayerDeathState(p);
        updatePlayerVitals(p);
        updatePlayerHeroBehavior(p);
        updatePlayerHarvesting(p);
        updatePlayerAudio(p);
        updatePlayerCommandCard(p);
        updatePlayerDebugInfo(p, localPlayer);
    }
}
