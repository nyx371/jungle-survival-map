// Day/Night Director
// 24-hour AM/PM clock. Day runs DAWN_HOUR (6 AM) through DUSK_HOUR (10 PM);
// night is the rest (10 PM -> 6 AM). Victory after surviving
// TARGET_NIGHTS_TO_WIN nights. Brightness itself lives in systems.lights,
// gated on IsNight (DEFAULT_DAY_LIGHT by day, light-source levels at night).

import core.constants;
import systems.mob_evolution;
import systems.victory;

const HOURS_PER_DAY = 24;
const NOON_HOUR = 12;
const DAWN_HOUR = 6;   // morning begins -> day
const DUSK_HOUR = 22;  // 10 PM -> night

// Real minutes for one full 24h cycle. Tune to taste: day is
// (DUSK_HOUR - DAWN_HOUR)/24 of this, night the rest.
const CYCLE_REAL_MINUTES = 11;
const CYCLE_FRAMES = CYCLE_REAL_MINUTES * 60 * constants.FRAMES_PER_GAME_SECOND;
const FRAMES_PER_HOUR = CYCLE_FRAMES / HOURS_PER_DAY;
const CLOCK_START = DAWN_HOUR * FRAMES_PER_HOUR; // start the map at 6 AM

const TIME_UI_INTERVAL_FRAMES = constants.FRAMES_PER_GAME_SECOND;

// DEBUG: clock frames advanced per real frame. 1 = normal. Bump this (e.g.
// 30) to fast-forward the day/night cycle when testing, then set back to 1.
const DEBUG_TIME_SCALE = 1;

var Clock = 0;          // 0..CYCLE_FRAMES-1, wraps at midnight; a 24h clock
var IsNight = 0;
var CurrentDay = 1;
var CurrentNight = 0;
var NightsSurvived = 0;
var NightIntensity = 0;
var VictoryPending = 0;
var TimeUiFrame = 0;

function initDayNight() {
    Clock = CLOCK_START;
    IsNight = 0;
    CurrentDay = 1;
    CurrentNight = 0;
    NightsSurvived = 0;
    NightIntensity = 0;
    VictoryPending = 0;
    TimeUiFrame = 0;
}

function getClockHour() {
    return Clock / FRAMES_PER_HOUR;
}

function startNight() {
    IsNight = 1;
    CurrentNight += 1;
    NightIntensity = CurrentNight;
    mob_evolution.addEvolutionPressure(25 + CurrentNight * 10);
    DisplayTextAll("Night falls. Stay near light.");
}

function endNight() {
    IsNight = 0;
    NightsSurvived += 1;

    if (NightsSurvived >= constants.TARGET_NIGHTS_TO_WIN) {
        VictoryPending = 1;
        victory.requestVictorySequence();
    } else {
        CurrentDay += 1;
        DisplayTextAll("Dawn breaks. Scavenge while you can.");
    }
}

function printTimeOfDayUi() {
    const hour24 = getClockHour();
    const minute = (Clock % FRAMES_PER_HOUR) * 60 / FRAMES_PER_HOUR;

    // 12-hour clock face.
    var hour12 = hour24 % 12;
    if (hour12 == 0) hour12 = 12;

    // AM/PM + zero-padded minutes; branch since the labels are literal strings.
    if (hour24 < NOON_HOUR) {
        if (minute < 10) eprintAll("\x04Day {}  {}:0{} AM", CurrentDay, hour12, minute);
        else eprintAll("\x04Day {}  {}:{} AM", CurrentDay, hour12, minute);
    } else {
        if (minute < 10) eprintAll("\x04Day {}  {}:0{} PM", CurrentDay, hour12, minute);
        else eprintAll("\x04Day {}  {}:{} PM", CurrentDay, hour12, minute);
    }
}

function updateTimeOfDayUi() {
    TimeUiFrame += 1;
    if (TimeUiFrame >= TIME_UI_INTERVAL_FRAMES) {
        TimeUiFrame = 0;
        printTimeOfDayUi();
    }
}

function updateDayNight() {
    Clock += DEBUG_TIME_SCALE;
    if (Clock >= CYCLE_FRAMES) Clock -= CYCLE_FRAMES;

    const hour24 = getClockHour();
    const shouldBeNight = (hour24 >= DUSK_HOUR || hour24 < DAWN_HOUR) ? 1 : 0;

    if (IsNight == 0 && shouldBeNight == 1) {
        startNight();
    } else if (IsNight == 1 && shouldBeNight == 0) {
        endNight();
    }

    updateTimeOfDayUi();
}

function getNightSpawnMultiplier() {
    if (IsNight) {
        return 100 + NightIntensity * 25;
    }
    return 60 + CurrentDay * 10;
}

function getSpawnIntervalFrames() {
    // Prototype pacing: enemies still appear during the day, but nights ramp
    // noticeably harder with each survived cycle.
    if (IsNight) {
        const seconds = 28 - CurrentNight * 3;
        if (seconds < 10) return 10 * constants.FRAMES_PER_GAME_SECOND;
        return seconds * constants.FRAMES_PER_GAME_SECOND;
    }

    const seconds = 75 - CurrentDay * 5;
    if (seconds < 45) return 45 * constants.FRAMES_PER_GAME_SECOND;
    return seconds * constants.FRAMES_PER_GAME_SECOND;
}
