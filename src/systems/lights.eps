// Light System
// Structures of type STRUCTURE_LIGHT (systems.structures.UNIT_LIGHT_STRUCTURE,
// a Terran Supply Depot placeholder) are the only light sources. Mob spawn
// suppression checks distance to those live structure units directly. Each
// player's local screen brightness is read the way it always has been for
// this mechanic: move a location onto the hero and Bring() count light
// structures inside it.

import core.constants;
import systems.day_night;
import systems.mobs;
import systems.structures;
import systems.players;

const DEFAULT_LIGHT_RADIUS = 9 * 32;
const DEFAULT_NO_SPAWN_RADIUS = 12 * 32;
const LIGHT_AREA_TILE_SIZE = 16;
const LIGHT_TILE_SIZE = 32;

// StarCraft brightness memory accepts a small 0-31-ish range. Keep day maxed and
// night readable only around lights, with smooth one-step transitions per frame.
const DAY_BRIGHTNESS = 31;
const NIGHT_BRIGHTNESS_MIN = 20;
const NIGHT_BRIGHTNESS_L1 = 23;
const NIGHT_BRIGHTNESS_L2 = 26;
const NIGHT_BRIGHTNESS_L3 = 29;
const NIGHT_BRIGHTNESS_L4 = 31;

const PlayerBrightness = EUDArray(constants.MAX_PLAYERS);

function initLights() {
    foreach (p : py_range(constants.MAX_PLAYERS)) {
        PlayerBrightness[p] = DAY_BRIGHTNESS;
    }
}

function distanceSquared(ax, ay, bx, by) {
    const dx = ax > bx ? ax - bx : bx - ax;
    const dy = ay > by ? ay - by : by - ay;
    return dx * dx + dy * dy;
}

function isWithinRadius(ax, ay, bx, by, radius) {
    if (distanceSquared(ax, ay, bx, by) <= radius * radius) return 1;
    return 0;
}

function isSpawnBlockedAt(x, y) {
    foreach (i : py_range(structures.MAX_STRUCTURES)) {
        if (structures.StructureAlive[i] && structures.StructureType[i] == structures.STRUCTURE_LIGHT) {
            const light = CUnit(structures.StructureUnit[i]);
            if (isWithinRadius(x, y, light.posX, light.posY, DEFAULT_NO_SPAWN_RADIUS)) return 1;
        }
    }
    return 0;
}

function getAreaSpawnBlockLightLevel(area) {
    const areaX = area % mobs.MOB_AREA_COLUMNS;
    const areaY = area / mobs.MOB_AREA_COLUMNS;
    const centerX = (areaX * LIGHT_AREA_TILE_SIZE + LIGHT_AREA_TILE_SIZE / 2) * LIGHT_TILE_SIZE;
    const centerY = (areaY * LIGHT_AREA_TILE_SIZE + LIGHT_AREA_TILE_SIZE / 2) * LIGHT_TILE_SIZE;

    var strongest = 0;
    foreach (i : py_range(structures.MAX_STRUCTURES)) {
        if (structures.StructureAlive[i] && structures.StructureType[i] == structures.STRUCTURE_LIGHT) {
            const light = CUnit(structures.StructureUnit[i]);
            if (isWithinRadius(centerX, centerY, light.posX, light.posY, DEFAULT_NO_SPAWN_RADIUS)) {
                return 100;
            }
            if (isWithinRadius(centerX, centerY, light.posX, light.posY, DEFAULT_LIGHT_RADIUS)) {
                strongest = 60;
            }
        }
    }

    return strongest;
}

function easePlayerBrightness(player, targetBrightness) {
    if (PlayerBrightness[player] > targetBrightness) PlayerBrightness[player] -= 1;
    else if (PlayerBrightness[player] < targetBrightness) PlayerBrightness[player] += 1;
}

function applyLocalBrightness(player) {
    if (IsUserCP()) {
        SetMemoryEPD(EPD(0x657A9C), SetTo, PlayerBrightness[player]);
    }
}

function updateLocalBrightness(player) {
    if (!players.HeroAlive[player]) return;

    const hero = players.getPlayerHeroUnit(player);
    setloc($L("_Screen"), hero.posX, hero.posY);

    var targetBrightness = DAY_BRIGHTNESS;
    if (day_night.IsNight) {
        if (Bring(AllPlayers, AtLeast, 4, structures.UNIT_LIGHT_STRUCTURE, $L("_Screen"))) targetBrightness = NIGHT_BRIGHTNESS_L4;
        else if (Bring(AllPlayers, AtLeast, 3, structures.UNIT_LIGHT_STRUCTURE, $L("_Screen"))) targetBrightness = NIGHT_BRIGHTNESS_L3;
        else if (Bring(AllPlayers, AtLeast, 2, structures.UNIT_LIGHT_STRUCTURE, $L("_Screen"))) targetBrightness = NIGHT_BRIGHTNESS_L2;
        else if (Bring(AllPlayers, AtLeast, 1, structures.UNIT_LIGHT_STRUCTURE, $L("_Screen"))) targetBrightness = NIGHT_BRIGHTNESS_L1;
        else targetBrightness = NIGHT_BRIGHTNESS_MIN;
    }

    easePlayerBrightness(player, targetBrightness);
    applyLocalBrightness(player);
}

function updateLights() {
    foreach (p : py_range(constants.MAX_PLAYERS)) {
        updateLocalBrightness(p);
    }
}
