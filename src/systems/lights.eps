// Light System
// Light sources gradually brighten nearby screen and block mob spawning.

const MAX_LIGHTS = 64;
const DEFAULT_LIGHT_RADIUS = 9 * 32;
const DEFAULT_NO_SPAWN_RADIUS = 12 * 32;

const LightActive = EUDArray(MAX_LIGHTS);
const LightOwner = EUDArray(MAX_LIGHTS);
const LightX = EUDArray(MAX_LIGHTS);
const LightY = EUDArray(MAX_LIGHTS);
const LightRadius = EUDArray(MAX_LIGHTS);
const LightNoSpawnRadius = EUDArray(MAX_LIGHTS);

function initLights() {
    foreach (i : py_range(MAX_LIGHTS)) {
        LightActive[i] = 0;
        LightOwner[i] = -1;
        LightX[i] = 0;
        LightY[i] = 0;
        LightRadius[i] = DEFAULT_LIGHT_RADIUS;
        LightNoSpawnRadius[i] = DEFAULT_NO_SPAWN_RADIUS;
    }
}

