// Resource Harvesting
// Right-click continuous mining. Harvesting locks out firing while mineral/gas trickles arrive.

import core.constants;
import core.utils;
import systems.players;

const TERRAN_COMSAT_STATION = $U("Terran Comsat Station"); // resource node placeholder marker (owned by P7)
const TERRAN_COVERT_OPS = $U("Terran Covert Ops");         // resource node base unit; likely to be swapped later
const MINERAL_FIELD_UNIT_TYPE = 176;                          // Mineral Field (Type 1)
const MAX_RESOURCE_NODE_MARKERS = 64;

const RESOURCE_TREE = 0;
const RESOURCE_BUSH = 1;
const RESOURCE_ROCK = 2;
const RESOURCE_CRYSTAL = 3;
const RESOURCE_ORGANIC_GROWTH = 4;

const HARVEST_TICK_FRAMES = 3 * constants.FRAMES_PER_GAME_SECOND;
const HARVEST_WEAPON_LOCKOUT = 1;

// Baseline trickle profile per harvest tick. Final values should be tuned by map pacing.
const TREE_MINERALS_PER_TICK = 4;
const TREE_GAS_PER_TICK = 1;
const BUSH_MINERALS_PER_TICK = 2;
const BUSH_GAS_PER_TICK = 2;
const ROCK_MINERALS_PER_TICK = 6;
const ROCK_GAS_PER_TICK = 1;
const CRYSTAL_MINERALS_PER_TICK = 2;
const CRYSTAL_GAS_PER_TICK = 5;
const ORGANIC_MINERALS_PER_TICK = 3;
const ORGANIC_GAS_PER_TICK = 3;

const IsHarvesting = EUDArray(constants.MAX_PLAYERS);
const HarvestTarget = EUDArray(constants.MAX_PLAYERS);
const HarvestProgress = EUDArray(constants.MAX_PLAYERS);
const HarvestTick = EUDArray(constants.MAX_PLAYERS);

function addMinerals(player, amount) {
    SetResources(player, Add, amount, Ore);
}

function addGas(player, amount) {
    SetResources(player, Add, amount, Gas);
}

function addHarvestResources(player, minerals, gas) {
    if (minerals > 0) addMinerals(player, minerals);
    if (gas > 0) addGas(player, gas);
}

function loseMostMinerals(player, keepPercent) {
    // Death keeps progression but destroys momentum.
    const p = TrgPlayer(player);
    p.mineral = p.mineral * keepPercent / 100;
}

function loseMostGas(player, keepPercent) {
    const p = TrgPlayer(player);
    p.gas = p.gas * keepPercent / 100;
}

function setPlayerHarvestLockout(player, enabled) {
    if (enabled) {
        // Force weapon cooldown so the Ghost cannot fire while harvesting; naturally
        // expires if harvesting stops without another refresh.
        const hero = players.getPlayerHeroUnit(player);
        hero.groundWeaponCooldown = HARVEST_TICK_FRAMES;
        hero.airWeaponCooldown = HARVEST_TICK_FRAMES;
    }
}

function clearHarvestState(player) {
    IsHarvesting[player] = 0;
    HarvestTarget[player] = 0;
    HarvestProgress[player] = 0;
    HarvestTick[player] = 0;
    setPlayerHarvestLockout(player, 0);
}

function initResourceNodes() {
    const found = EUDQueue(MAX_RESOURCE_NODE_MARKERS)();
    foreach (unit : EUDLoopPlayerCUnit(P7)) {
        if (unit.unitType == TERRAN_COMSAT_STATION) {
            found.append(unit);
        }
    }

    while (!found.empty()) {
        const marker = CUnit(found.popleft());
        const x = marker.posX;
        const y = marker.posY;
        utils.removeCUnit(marker);

        setloc($L("_Place"), x, y);
        const node = CUnit(utils.createUnitAndGetEpd(1, TERRAN_COVERT_OPS, $L("_Place"), P7));
        node.unitType = MINERAL_FIELD_UNIT_TYPE;
    }
}

function initResources() {
    foreach (p : py_range(constants.MAX_PLAYERS)) {
        clearHarvestState(p);
    }
    initResourceNodes();
    // TODO: weighted/randomized candidate selection; this replaces every marker found.
}

function startHarvest(player, target) {
    IsHarvesting[player] = 1;
    HarvestTarget[player] = target;
    HarvestProgress[player] = 0;
    HarvestTick[player] = HARVEST_TICK_FRAMES;
    setPlayerHarvestLockout(player, HARVEST_WEAPON_LOCKOUT);
}

function getHarvestMineralsPerTick(resourceType) {
    if (resourceType == RESOURCE_TREE) return TREE_MINERALS_PER_TICK;
    if (resourceType == RESOURCE_BUSH) return BUSH_MINERALS_PER_TICK;
    if (resourceType == RESOURCE_ROCK) return ROCK_MINERALS_PER_TICK;
    if (resourceType == RESOURCE_CRYSTAL) return CRYSTAL_MINERALS_PER_TICK;
    if (resourceType == RESOURCE_ORGANIC_GROWTH) return ORGANIC_MINERALS_PER_TICK;
    return 1;
}

function getHarvestGasPerTick(resourceType) {
    if (resourceType == RESOURCE_TREE) return TREE_GAS_PER_TICK;
    if (resourceType == RESOURCE_BUSH) return BUSH_GAS_PER_TICK;
    if (resourceType == RESOURCE_ROCK) return ROCK_GAS_PER_TICK;
    if (resourceType == RESOURCE_CRYSTAL) return CRYSTAL_GAS_PER_TICK;
    if (resourceType == RESOURCE_ORGANIC_GROWTH) return ORGANIC_GAS_PER_TICK;
    return 0;
}

function getHarvestTargetResourceType(target) {
    // Only Mineral Field nodes exist for now (see initResourceNodes); everything
    // else defaults to the Tree profile. Extend as more node types are added.
    const unit = CUnit(target);
    if (unit.unitType == MINERAL_FIELD_UNIT_TYPE) return RESOURCE_ROCK;
    return RESOURCE_TREE;
}

function finishHarvestTick(player) {
    const resourceType = getHarvestTargetResourceType(HarvestTarget[player]);
    const minerals = getHarvestMineralsPerTick(resourceType);
    const gas = getHarvestGasPerTick(resourceType);
    addHarvestResources(player, minerals, gas);
    // TODO: reduce remaining node value by minerals + gas, deplete/remove at zero
    // once resource nodes track their own remaining value.
}

function updateHarvesting(player) {
    const hero = players.getPlayerHeroUnit(player);
    const targetingResource = hero.orderID == players.ORDER_HARVEST_MINERALS && hero.orderTarget != 0;

    if (!IsHarvesting[player]) {
        if (targetingResource) {
            startHarvest(player, hero.orderTarget);
        }
        return;
    }

    // Cancel harvest if the player gave another order or the target is gone.
    if (!targetingResource) {
        clearHarvestState(player);
        return;
    }

    // Mining is continuous: every HARVEST_TICK_FRAMES, the active node trickles resources.
    if (HarvestTick[player] > 0) {
        HarvestTick[player] -= 1;
    } else {
        HarvestTick[player] = HARVEST_TICK_FRAMES;
        finishHarvestTick(player);
    }
}

function updateResources() {
    foreach (p : py_range(constants.MAX_PLAYERS)) {
        updateHarvesting(p);
    }
}
