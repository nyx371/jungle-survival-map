// Resource Harvesting
// Right-click continuous mining. Harvesting locks out firing while mineral/gas trickles arrive.

import core.constants;
import core.utils;

const TERRAN_COMSAT_STATION = $U("Terran Comsat Station"); // resource node placeholder marker (owned by P7)
const TERRAN_COVERT_OPS = $U("Terran Covert Ops");         // resource node base unit; likely to be swapped later
const MINERAL_FIELD_UNIT_TYPE = 176;                          // Mineral Field (Type 1)
const MAX_RESOURCE_NODE_MARKERS = 64;
const RESOURCE_NODE_ACTIVATION_PERCENT = 95; // basic run-to-run variance

const RESOURCE_TREE = 0;
const RESOURCE_BUSH = 1;
const RESOURCE_ROCK = 2;
const RESOURCE_CRYSTAL = 3;
const RESOURCE_MAGMA = 4;
const RESOURCE_TYPE_COUNT = 5;
// How many of the RESOURCE_TYPE_COUNT types can spawn as a node. All types
// now have images/config wired up, so all of them are spawnable.
const SPAWNABLE_RESOURCE_TYPE_COUNT = RESOURCE_TYPE_COUNT;

// One config row per resource type, indexed by the RESOURCE_* constants
// above -- add a new resource type by adding one clustered block to
// buildResourceConfig, not by inventing a new set of named constants.
// RESOURCE_CONFIG[type] is a [minerals, gas, startingAmount, yieldFrames]
// row (see RES_CFG_* for column indices) and RESOURCE_IMAGES[type] is a list
// of images.dat variants, so everything about one resource type lives in one
// clustered block. All the resource tables are real EUDArrays of
// bracket-literal sub-arrays so a *runtime* resourceType can index them
// directly: read the row out (RESOURCE_CONFIG[resourceType]) then
// EUDArray.cast(...).get(col) to index the row at runtime -- no more
// literal-dispatch if/else chains. (A py_list only takes compile-time
// literal indices, which is what forced those chains before.)
const RES_CFG_MINERALS = 0;
const RES_CFG_GAS = 1;
const RES_CFG_STARTING_AMOUNT = 2;
const RES_CFG_YIELD_FRAMES = 3; // frames of mining between each resource payout

// Placeholder images.dat entry used for resource types with no real art yet
// (e.g. crystal, organic growth).
const RESOURCE_IMAGE_NONE = 228;

const RESOURCE_CONFIG = EUDArray(RESOURCE_TYPE_COUNT);

const RESOURCE_IMAGE_VARIANTS = 3;
const RESOURCE_IMAGES = EUDArray(RESOURCE_TYPE_COUNT);

// Per-resource-type mining sound sets: each element is a bracket-literal
// EUDArray of StringBuffers, played back with a runtime index via
// playSoundArray (see playMiningSfx). Every type provides MINING_SFX_PER_TYPE.
const MINING_SFX_PER_TYPE = 4;
const RESOURCE_MINING_SFX = EUDArray(RESOURCE_TYPE_COUNT);

// Stock SCV repair sounds, played in order on every mining chop on top of
// the resource-specific sound above -- a complementary tool loop. Not
// resource-specific, so it's a single flat set with one shared cycle per player.
const MINING_TOOL_SFX = [
    StringBuffer("sound/terran/SCV/EDrRep00.wav"),
    StringBuffer("sound/terran/SCV/EDrRep01.wav"),
    StringBuffer("sound/terran/SCV/EDrRep02.wav"),
    StringBuffer("sound/terran/SCV/EDrRep03.wav"),
    StringBuffer("sound/terran/SCV/EDrRep04.wav"),
];
const MINING_TOOL_SFX_COUNT = 5;
const MiningToolCycle = EUDArray(constants.MAX_PLAYERS);

function buildResourceConfig() {
    RESOURCE_CONFIG[RESOURCE_TREE] = [4, 1, 500, 3 * constants.FRAMES_PER_GAME_SECOND];    // 3s per yield
    RESOURCE_IMAGES[RESOURCE_TREE] = [632, 634, 636];
    RESOURCE_MINING_SFX[RESOURCE_TREE] = [StringBuffer("staredit/wav/wood1.ogg"), StringBuffer("staredit/wav/wood2.ogg"), StringBuffer("staredit/wav/wood3.ogg"), StringBuffer("staredit/wav/wood4.ogg")];

    RESOURCE_CONFIG[RESOURCE_BUSH] = [2, 2, 500, 2 * constants.FRAMES_PER_GAME_SECOND];    // 2s -- quick, low yield
    RESOURCE_IMAGES[RESOURCE_BUSH] = [618, 620, 622];
    RESOURCE_MINING_SFX[RESOURCE_BUSH] = [StringBuffer("staredit/wav/grass1.ogg"), StringBuffer("staredit/wav/grass2.ogg"), StringBuffer("staredit/wav/grass3.ogg"), StringBuffer("staredit/wav/grass4.ogg")];

    RESOURCE_CONFIG[RESOURCE_ROCK] = [6, 1, 500, 4 * constants.FRAMES_PER_GAME_SECOND];    // 4s -- slow, high yield
    RESOURCE_IMAGES[RESOURCE_ROCK] = [649, 650, 651];
    RESOURCE_MINING_SFX[RESOURCE_ROCK] = [StringBuffer("staredit/wav/stone1.ogg"), StringBuffer("staredit/wav/stone2.ogg"), StringBuffer("staredit/wav/stone3.ogg"), StringBuffer("staredit/wav/stone4.ogg")];

    RESOURCE_CONFIG[RESOURCE_CRYSTAL] = [2, 5, 500, 5 * constants.FRAMES_PER_GAME_SECOND]; // 5s -- slow, gas-heavy
    RESOURCE_IMAGES[RESOURCE_CRYSTAL] = [607, 607, 607];
    RESOURCE_MINING_SFX[RESOURCE_CRYSTAL] = [StringBuffer("staredit/wav/stone1.ogg"), StringBuffer("staredit/wav/stone2.ogg"), StringBuffer("staredit/wav/stone3.ogg"), StringBuffer("staredit/wav/stone4.ogg")];

    RESOURCE_CONFIG[RESOURCE_MAGMA] = [3, 3, 500, 4 * constants.FRAMES_PER_GAME_SECOND];   // 4s
    RESOURCE_IMAGES[RESOURCE_MAGMA] = [600, 600, 600];
    RESOURCE_MINING_SFX[RESOURCE_MAGMA] = [StringBuffer("staredit/wav/stone1.ogg"), StringBuffer("staredit/wav/stone2.ogg"), StringBuffer("staredit/wav/stone3.ogg"), StringBuffer("staredit/wav/stone4.ogg")];
}

// Terran Covert Ops sprite. Its image field is mutated right before each
// CreateUnit call so the freshly created node sprite bakes in a random
// resource look; later mutations do not retroactively affect earlier nodes.
const RESOURCE_NODE_SPRITE_ID = 504;

function addMinerals(player, amount) {
    SetResources(player, Add, amount, Ore);
}

function addGas(player, amount) {
    SetResources(player, Add, amount, Gas);
}

function addHarvestResources(player, minerals, gas) {
    if (minerals > 0) addMinerals(player, minerals);
    if (gas > 0) addGas(player, gas);
}

function loseMostMinerals(player, keepPercent) {
    // Death keeps progression but destroys momentum.
    const p = TrgPlayer(player);
    p.mineral = p.mineral * keepPercent / 100;
}

function loseMostGas(player, keepPercent) {
    const p = TrgPlayer(player);
    p.gas = p.gas * keepPercent / 100;
}

// Builds the compile-time RESOURCE_IMAGES/RESOURCE_CONFIG tables. Must run
// before anything reads them -- called first thing from initResources().
function initResourceConfig() {
    buildResourceConfig();
}

// Resource node images start non-clickable; players need to be able to
// right-click them to harvest, so flip that on once per image (not per
// node -- it is a shared images.dat property). resourceType here comes from
// a compile-time-unrolled py_range loop, so it is a literal at each unrolled
// step and can index straight into RESOURCE_IMAGES.
function initResourceNodeImages() {
    foreach (resourceType : py_range(SPAWNABLE_RESOURCE_TYPE_COUNT)) {
        foreach (variant : py_range(RESOURCE_IMAGE_VARIANTS)) {
            const image = EUDArray.cast(RESOURCE_IMAGES[resourceType]).get(variant);
            Image(image).isClickable = 1;
        }
    }
}

function chooseResourceNodeType() {
    const roll = f_rand() % SPAWNABLE_RESOURCE_TYPE_COUNT;
    if (roll == 0) return RESOURCE_TREE;
    if (roll == 1) return RESOURCE_BUSH;
    if (roll == 2) return RESOURCE_ROCK;
    if (roll == 3) return RESOURCE_CRYSTAL;
    return RESOURCE_MAGMA;
}

function chooseResourceNodeImage(resourceType) {
    const roll = f_rand() % RESOURCE_IMAGE_VARIANTS;
    // RESOURCE_IMAGES[resourceType] reads out a plain value (the sub-array's
    // pointer); EUDArray.cast reinterprets it as an EUDArray so .get(roll)
    // can index it at runtime. (Chained [a][b] doesn't work on an EUDArray.)
    return EUDArray.cast(RESOURCE_IMAGES[resourceType]).get(roll);
}

// resourceType is a runtime value, so (as in chooseResourceNodeImage above)
// it must be narrowed to a literal via if/else before indexing RESOURCE_CONFIG.
function getHarvestRates(resourceType) {
    const row = EUDArray.cast(RESOURCE_CONFIG[resourceType]);
    return row.get(RES_CFG_MINERALS), row.get(RES_CFG_GAS);
}

function getResourceStartingAmount(resourceType) {
    return EUDArray.cast(RESOURCE_CONFIG[resourceType]).get(RES_CFG_STARTING_AMOUNT);
}

// Frames of mining between each resource payout, per resource type.
function getHarvestTimer(resourceType) {
    return EUDArray.cast(RESOURCE_CONFIG[resourceType]).get(RES_CFG_YIELD_FRAMES);
}

function playMiningSfx(player, resourceType) {
    utils.playSoundArray(RESOURCE_MINING_SFX[resourceType], player, MINING_SFX_PER_TYPE);
}

// Complementary SCV tool sound, cycled in order across mining chops.
function playMiningToolSfx(player) {
    utils.playSoundArrayAt(MINING_TOOL_SFX, player, MiningToolCycle[player]);
    MiningToolCycle[player] += 1;
    if (MiningToolCycle[player] >= MINING_TOOL_SFX_COUNT) MiningToolCycle[player] = 0;
}

function initResourceNodes() {
    const found = EUDQueue(MAX_RESOURCE_NODE_MARKERS)();
    foreach (unit : EUDLoopPlayerCUnit(P7)) {
        if (unit.unitType == TERRAN_COMSAT_STATION) {
            found.append(unit);
        }
    }

    // Only a percentage of candidates actually become nodes, for run-to-run
    // variance. True weighting between resource types needs more marker/node
    // variety than exists today (see getHarvestTargetResourceType).
    while (!found.empty()) {
        const marker = CUnit(found.popleft());
        const x = marker.posX;
        const y = marker.posY;
        utils.removeCUnit(marker);

        if (f_rand() % 100 < RESOURCE_NODE_ACTIVATION_PERCENT) {
            const resourceType = chooseResourceNodeType();
            Sprite(RESOURCE_NODE_SPRITE_ID).image = chooseResourceNodeImage(resourceType);

            setloc($L("_Place"), x, y);
            const node = CUnit(utils.createUnitAndGetEpd(1, TERRAN_COVERT_OPS, $L("_Place"), P7));
            node.unitType = MINERAL_FIELD_UNIT_TYPE;
            node.unknown0x106 = resourceType;
            node.resourceAmount = getResourceStartingAmount(resourceType);
        }
    }
}

function initResources() {
    initResourceConfig();
    initResourceNodeImages();
    initResourceNodes();
    foreach (p : py_range(constants.MAX_PLAYERS)) {
        MiningToolCycle[p] = 0;
    }
}

function getHarvestTargetResourceType(target) {
    // Mineral Field nodes carry their randomly chosen resource type (tree,
    // bush, rock -- see initResourceNodes) tagged on unknown0x106.
    const unit = CUnit(target);
    if (unit.unitType == MINERAL_FIELD_UNIT_TYPE) return unit.unknown0x106;
    return RESOURCE_TREE;
}
