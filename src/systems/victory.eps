// Victory / Final Boss / Endless Mode

import core.utils;

const VICTORY_RUNNING = 0;
const VICTORY_FINAL_BOSS = 1;
const VICTORY_COMPLETE = 2;
const VICTORY_ENDLESS = 3;

var VictoryState = VICTORY_RUNNING;
var FinalBossEnabled = 1;
var FinalBossSpawned = 0;
var EndlessModeEnabled = 0;
var FinalBossUnit = 0;

function initVictory() {
    VictoryState = VICTORY_RUNNING;
    FinalBossSpawned = 0;
}

function spawnFinalBoss() {
    if (!FinalBossSpawned) {
        FinalBossSpawned = 1;
        DisplayTextAll("The jungle alpha has emerged.");
        // Torrasque as a stand-in "jungle alpha"; final boss unit TBD.
        FinalBossUnit = utils.createUnitAndGetEpd(1, $U("Torrasque"), $L("G"), P8);
    }
}

function completeVictory() {
    if (EndlessModeEnabled) {
        VictoryState = VICTORY_ENDLESS;
        DisplayTextAll("You survived. Endless mode begins.");
    } else {
        VictoryState = VICTORY_COMPLETE;
        Victory();
    }
}

function requestVictorySequence() {
    if (FinalBossEnabled) {
        VictoryState = VICTORY_FINAL_BOSS;
        spawnFinalBoss();
    } else {
        completeVictory();
    }
}

function updateVictory() {
    if (VictoryState == VICTORY_FINAL_BOSS && FinalBossSpawned) {
        const boss = CUnit(FinalBossUnit);
        if (boss.orderID == 0) {
            completeVictory();
        }
    }
}
