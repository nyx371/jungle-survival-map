// Area Mob Spawning and Respawn
// 256x256 map tiles divided into 16x16 tile areas = 16x16 spawn areas.
// Map authors pre-place Flag placeholder units to mark valid mob spawn positions.

import core.constants;
import core.utils;
import systems.day_night;
import systems.lights;
import systems.players;

const MAP_TILE_WIDTH = 256;
const MAP_TILE_HEIGHT = 256;
const MOB_AREA_TILE_SIZE = 16;
const MOB_AREA_COLUMNS = MAP_TILE_WIDTH / MOB_AREA_TILE_SIZE;
const MOB_AREA_ROWS = MAP_TILE_HEIGHT / MOB_AREA_TILE_SIZE;
const MAX_MOB_AREAS = MOB_AREA_COLUMNS * MOB_AREA_ROWS;

// Tune after map pass. This is the total number of Flag markers we can index.
const MAX_MOB_SPAWN_MARKERS = 1024;
const MOB_SPAWN_PLACEHOLDER_UNIT = $U("Flag");
// Flag markers are placed neutrally on P7, matching the resource-node marker convention.
const MOB_MARKER_OWNER = P7;
const MOB_OWNER_PLAYER = P8;
const MIN_SPAWN_DISTANCE_TO_PLAYER = 5 * 32;

const MAX_ACTIVE_MOBS = 48; // kept modest: this cap is scanned by both mob despawn logic and player respawn-safety checks
const AREA_SPAWN_CHECKS_PER_FRAME = 3;
const MOB_ROAM_RETARGET_FRAMES = 12 * constants.FRAMES_PER_GAME_SECOND;
const MobUnit = EUDArray(MAX_ACTIVE_MOBS);
const MobArea = EUDArray(MAX_ACTIVE_MOBS);
const MobActive = EUDArray(MAX_ACTIVE_MOBS);
const MobRoamTimer = EUDArray(MAX_ACTIVE_MOBS);
var SpawnAreaCursor = 0;

const AreaTargetDensity = EUDArray(MAX_MOB_AREAS);
const AreaCurrentDensity = EUDArray(MAX_MOB_AREAS);
const AreaSpawnCooldown = EUDArray(MAX_MOB_AREAS);
const AreaThreatBudget = EUDArray(MAX_MOB_AREAS);
const AreaPlayerPresence = EUDArray(MAX_MOB_AREAS);
const AreaLightLevel = EUDArray(MAX_MOB_AREAS);
const AreaSpawnStart = EUDArray(MAX_MOB_AREAS);
const AreaSpawnCount = EUDArray(MAX_MOB_AREAS);

const SpawnMarkerX = EUDArray(MAX_MOB_SPAWN_MARKERS);
const SpawnMarkerY = EUDArray(MAX_MOB_SPAWN_MARKERS);
const SpawnMarkerArea = EUDArray(MAX_MOB_SPAWN_MARKERS);
const SpawnMarkerActive = EUDArray(MAX_MOB_SPAWN_MARKERS);
var SpawnMarkerCount = 0;

function getMobAreaFromTile(tileX, tileY) {
    const areaX = tileX / MOB_AREA_TILE_SIZE;
    const areaY = tileY / MOB_AREA_TILE_SIZE;
    return areaY * MOB_AREA_COLUMNS + areaX;
}

function getMobAreaFromPosition(x, y) {
    // StarCraft positions are pixels; terrain tiles are 32x32 pixels.
    return getMobAreaFromTile(x / 32, y / 32);
}

function getAreaMinTileX(area) { return (area % MOB_AREA_COLUMNS) * MOB_AREA_TILE_SIZE; }
function getAreaMinTileY(area) { return (area / MOB_AREA_COLUMNS) * MOB_AREA_TILE_SIZE; }
function getAreaMaxTileX(area) { return getAreaMinTileX(area) + MOB_AREA_TILE_SIZE - 1; }
function getAreaMaxTileY(area) { return getAreaMinTileY(area) + MOB_AREA_TILE_SIZE - 1; }

function clearMobAreaState(area) {
    AreaTargetDensity[area] = 4;
    AreaCurrentDensity[area] = 0;
    AreaSpawnCooldown[area] = 0;
    AreaThreatBudget[area] = 100;
    AreaPlayerPresence[area] = 0;
    AreaLightLevel[area] = 0;
    AreaSpawnStart[area] = 0;
    AreaSpawnCount[area] = 0;
}

function indexMobSpawnMarker(markerUnit : CUnit) {
    const markerIndex = SpawnMarkerCount;
    if (markerIndex >= MAX_MOB_SPAWN_MARKERS) return;

    const x = markerUnit.posX;
    const y = markerUnit.posY;
    const area = getMobAreaFromPosition(x, y);

    SpawnMarkerX[markerIndex] = x;
    SpawnMarkerY[markerIndex] = y;
    SpawnMarkerArea[markerIndex] = area;
    SpawnMarkerActive[markerIndex] = 1;
    AreaSpawnCount[area] += 1;
    SpawnMarkerCount += 1;

    utils.removeCUnit(markerUnit);
}

function indexMobSpawnMarkers() {
    foreach (area : py_range(MAX_MOB_AREAS)) {
        AreaSpawnStart[area] = 0;
        AreaSpawnCount[area] = 0;
    }
    SpawnMarkerCount = 0;

    // Collect first, then index+remove afterward: removing units while
    // iterating EUDLoopPlayerCUnit would disrupt that same iteration.
    const found = EUDQueue(MAX_MOB_SPAWN_MARKERS)();
    foreach (unit : EUDLoopPlayerCUnit(MOB_MARKER_OWNER)) {
        if (unit.unitType == MOB_SPAWN_PLACEHOLDER_UNIT) {
            found.append(unit);
        }
    }

    while (!found.empty()) {
        indexMobSpawnMarker(CUnit(found.popleft()));
    }
}

function initMobs() {
    foreach (area : py_range(MAX_MOB_AREAS)) {
        clearMobAreaState(area);
    }
    foreach (i : py_range(MAX_ACTIVE_MOBS)) {
        MobActive[i] = 0;
        MobUnit[i] = 0;
        MobArea[i] = 0;
        MobRoamTimer[i] = 0;
    }
    SpawnAreaCursor = 0;
    indexMobSpawnMarkers();
}

function getPlayerCountSpawnScale() {
    var count = 0;
    foreach (p : py_range(constants.MAX_PLAYERS)) {
        if (playerexist(p)) count += 1;
    }
    if (count == 0) return 100;
    return count * 100 / constants.MAX_PLAYERS;
}

function refreshAreaPlayerPresence() {
    foreach (area : py_range(MAX_MOB_AREAS)) {
        AreaPlayerPresence[area] = 0;
    }

    foreach (p : py_range(constants.MAX_PLAYERS)) {
        if (players.HeroAlive[p]) {
            const hero = players.getPlayerHeroUnit(p);
            const area = getMobAreaFromPosition(hero.posX, hero.posY);
            AreaPlayerPresence[area] += 1;
        }
    }
}

function refreshAreaLightLevels() {
    // AreaLightLevel represents spawn suppression, not local screen brightness.
    foreach (area : py_range(MAX_MOB_AREAS)) {
        AreaLightLevel[area] = lights.getAreaSpawnBlockLightLevel(area);
    }
}

function getAreaSpawnBudget(area) {
    const baseBudget = AreaThreatBudget[area] * day_night.getNightSpawnMultiplier() / 100 * getPlayerCountSpawnScale() / 100;
    if (AreaPlayerPresence[area] > 0) return baseBudget;
    return baseBudget / 2;
}

function shouldSpawnInArea(area) {
    if (AreaSpawnCount[area] == 0) return 0;
    if (AreaLightLevel[area] >= 100) return 0;
    if (AreaCurrentDensity[area] >= getAreaSpawnBudget(area)) return 0;

    // Areas containing players get active pressure. Other marked regions still
    // repopulate occasionally during the day, then much more often at night.
    if (AreaPlayerPresence[area] > 0) return 1;
    if (day_night.IsNight) return f_rand() % 100 < 45;
    return f_rand() % 100 < 15;
}

function shouldDespawnAreaMobs(area) {
    // Lit safe pockets should drain pressure instead of endlessly fighting spawn attempts.
    if (AreaLightLevel[area] >= 100) return 1;
    return 0;
}

function canSpawnAt(x, y) {
    if (lights.isSpawnBlockedAt(x, y)) return 0;

    foreach (p : py_range(constants.MAX_PLAYERS)) {
        if (players.HeroAlive[p]) {
            const hero = players.getPlayerHeroUnit(p);
            const dx = x > hero.posX ? x - hero.posX : hero.posX - x;
            const dy = y > hero.posY ? y - hero.posY : hero.posY - y;
            if (dx < MIN_SPAWN_DISTANCE_TO_PLAYER && dy < MIN_SPAWN_DISTANCE_TO_PLAYER) return 0;
        }
    }
    return 1;
}

function chooseSpawnMarkerInArea(area) {
    // Reservoir sampling: uniformly picks one active marker in the area in a
    // single pass, without needing a separate per-area index.
    var chosen = -1;
    var seen = 0;
    foreach (i : py_range(MAX_MOB_SPAWN_MARKERS)) {
        if (SpawnMarkerActive[i] && SpawnMarkerArea[i] == area) {
            seen += 1;
            if (f_rand() % seen == 0) {
                chosen = i;
            }
        }
    }
    return chosen;
}

function findFreeMobSlot() {
    foreach (i : py_range(MAX_ACTIVE_MOBS)) {
        if (!MobActive[i]) return i;
    }
    return -1;
}

function chooseMobFamily(area) {
    // Simple 50/50 between the two currently mob_evolution-tiered families;
    // weighting by budget/tier/day-night/nearby players can refine this later.
    if (f_rand() % 2 == 0) return $U("Zerg Zergling");
    return $U("Zerg Hydralisk");
}

function getRandomRoamX(area) {
    return getAreaMinTileX(area) * 32 + f_rand() % (MOB_AREA_TILE_SIZE * 32);
}

function getRandomRoamY(area) {
    return getAreaMinTileY(area) * 32 + f_rand() % (MOB_AREA_TILE_SIZE * 32);
}

function orderMobJunkyardRoam(unit : CUnit, area) {
    unit.orderID = constants.ORDER_JUNK_YARD_DOG;
    unit.orderTargetX = getRandomRoamX(area);
    unit.orderTargetY = getRandomRoamY(area);
}

function spawnMobInArea(area) {
    const marker = chooseSpawnMarkerInArea(area);
    if (marker < 0) return;

    const x = SpawnMarkerX[marker];
    const y = SpawnMarkerY[marker];
    if (!canSpawnAt(x, y)) return;

    const slot = findFreeMobSlot();
    if (slot < 0) return;

    const family = chooseMobFamily(area);
    // Create in the always-clear _SafeCreate spot, then move the finished
    // unit to its real target -- creating directly on top of terrain/units
    // at the target can fail or get shoved around by collision.
    const unit = CUnit(utils.createUnitAndGetEpd(1, family, $L("_SafeCreate"), MOB_OWNER_PLAYER));
    setloc($L("_Place"), x, y);
    unit.setloc($L("_Place"));
    orderMobJunkyardRoam(unit, area);

    MobUnit[slot] = unit;
    MobArea[slot] = area;
    MobActive[slot] = 1;
    MobRoamTimer[slot] = MOB_ROAM_RETARGET_FRAMES;
    AreaCurrentDensity[area] += 1;
}

function despawnAreaMobs(area) {
    // Only purge idle/unengaged mobs (no current order target); mobs actively
    // fighting a player are left alone even if the area goes fully lit.
    var remaining = AreaCurrentDensity[area];
    foreach (i : py_range(MAX_ACTIVE_MOBS)) {
        if (MobActive[i] && MobArea[i] == area) {
            const unit = CUnit(MobUnit[i]);
            if (unit.orderTargetUnit == 0) {
                utils.removeCUnit(unit);
                MobActive[i] = 0;
                MobUnit[i] = 0;
                remaining -= 1;
            }
        }
    }
    AreaCurrentDensity[area] = remaining;
}

function updateAreaSpawning(area) {
    if (shouldDespawnAreaMobs(area)) {
        despawnAreaMobs(area);
        return;
    }

    if (AreaSpawnCooldown[area] > 0) {
        AreaSpawnCooldown[area] -= 1;
        return;
    }

    if (shouldSpawnInArea(area)) {
        spawnMobInArea(area);
        AreaSpawnCooldown[area] = day_night.getSpawnIntervalFrames();
    }
}

function updateActiveMobRoaming() {
    foreach (i : py_range(MAX_ACTIVE_MOBS)) {
        if (MobActive[i]) {
            const unit = CUnit(MobUnit[i]);
            if (unit.orderID == constants.ORDER_DIE) {
                MobActive[i] = 0;
                MobUnit[i] = 0;
                if (AreaCurrentDensity[MobArea[i]] > 0) AreaCurrentDensity[MobArea[i]] -= 1;
            } else if (unit.orderTargetUnit == 0) {
                if (MobRoamTimer[i] > 0) {
                    MobRoamTimer[i] -= 1;
                } else {
                    orderMobJunkyardRoam(unit, MobArea[i]);
                    MobRoamTimer[i] = MOB_ROAM_RETARGET_FRAMES;
                }
            }
        }
    }
}

function updateMobs() {
    refreshAreaPlayerPresence();
    refreshAreaLightLevels();
    updateActiveMobRoaming();

    foreach (_ : py_range(AREA_SPAWN_CHECKS_PER_FRAME)) {
        updateAreaSpawning(SpawnAreaCursor);
        SpawnAreaCursor += 1;
        if (SpawnAreaCursor >= MAX_MOB_AREAS) SpawnAreaCursor = 0;
    }
}
