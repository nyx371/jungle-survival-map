// Deep Menu Router

import core.constants;
import systems.players;
import systems.weapons;
import systems.upgrades;
import systems.structures;
import systems.transfers;

const TRANSFER_AMOUNT = 50;

const MENU_CLOSED = 0;
const MENU_MAIN = 1;
const MENU_WEAPONS = 2;
const MENU_HERO_UPGRADES = 3;
const MENU_WEAPON_UPGRADES = 4;
const MENU_STRUCTURES = 5;
const MENU_TRANSFER = 6;
const MENU_OPTIONS = 7;

const MenuPage = EUDArray(constants.MAX_PLAYERS);
const MenuCursor = EUDArray(constants.MAX_PLAYERS);
const MenuContext = EUDArray(constants.MAX_PLAYERS);

// Set by whatever concrete input detection (hotkeys/build-queue buttons) gets
// wired up in the map/GUI layer later; this file only consumes these signals.
const MenuNavigateDelta = EUDArray(constants.MAX_PLAYERS);
const MenuConfirmPressed = EUDArray(constants.MAX_PLAYERS);
const MenuBackPressed = EUDArray(constants.MAX_PLAYERS);

function initMenus() {
    foreach (p : py_range(constants.MAX_PLAYERS)) {
        MenuPage[p] = MENU_CLOSED;
        MenuCursor[p] = 0;
        MenuContext[p] = 0;
        MenuNavigateDelta[p] = 0;
        MenuConfirmPressed[p] = 0;
        MenuBackPressed[p] = 0;
    }
}

function openMenu(player, page) {
    MenuPage[player] = page;
    MenuCursor[player] = 0;
}

function closeMenu(player) {
    MenuPage[player] = MENU_CLOSED;
}

function handleMenuInput(player) {
    if (MenuNavigateDelta[player] != 0) {
        MenuCursor[player] += MenuNavigateDelta[player];
        if (MenuCursor[player] < 0) MenuCursor[player] = 0;
        MenuNavigateDelta[player] = 0;
    }

    if (MenuBackPressed[player]) {
        MenuBackPressed[player] = 0;
        if (MenuPage[player] == MENU_MAIN) {
            closeMenu(player);
        } else {
            openMenu(player, MENU_MAIN);
        }
    }

    if (MenuConfirmPressed[player]) {
        MenuConfirmPressed[player] = 0;
        const cursor = MenuCursor[player];

        if (MenuPage[player] == MENU_MAIN) {
            // Cursor 0-5 opens Weapons/Hero Upgrades/Weapon Upgrades/Structures/Transfer/Options.
            openMenu(player, MENU_WEAPONS + cursor);
        } else if (MenuPage[player] == MENU_WEAPONS) {
            weapons.craftWeapon(player, cursor);
        } else if (MenuPage[player] == MENU_HERO_UPGRADES) {
            upgrades.purchaseHeroUpgrade(player, cursor);
        } else if (MenuPage[player] == MENU_WEAPON_UPGRADES) {
            upgrades.purchaseWeaponUpgrade(player, weapons.ActiveWeapon[player], cursor);
        } else if (MenuPage[player] == MENU_STRUCTURES) {
            structures.buildStructure(player, cursor);
        } else if (MenuPage[player] == MENU_TRANSFER) {
            // Cursor selects the target player id directly.
            transfers.sendMinerals(player, cursor, TRANSFER_AMOUNT);
        }
    }
}

function renderMenu(player) {
    const savedCp = getcurpl();
    setcurpl(player);

    if (MenuPage[player] == MENU_MAIN) {
        players.Screen.printfAt(2, "Menu: Main ({})", MenuCursor[player]);
    } else if (MenuPage[player] == MENU_WEAPONS) {
        players.Screen.printfAt(2, "Menu: Weapons ({})", MenuCursor[player]);
    } else if (MenuPage[player] == MENU_HERO_UPGRADES) {
        players.Screen.printfAt(2, "Menu: Hero Upgrades ({})", MenuCursor[player]);
    } else if (MenuPage[player] == MENU_WEAPON_UPGRADES) {
        players.Screen.printfAt(2, "Menu: Weapon Upgrades ({})", MenuCursor[player]);
    } else if (MenuPage[player] == MENU_STRUCTURES) {
        players.Screen.printfAt(2, "Menu: Structures ({})", MenuCursor[player]);
    } else if (MenuPage[player] == MENU_TRANSFER) {
        players.Screen.printfAt(2, "Menu: Transfer ({})", MenuCursor[player]);
    } else if (MenuPage[player] == MENU_OPTIONS) {
        players.Screen.printfAt(2, "Menu: Options ({})", MenuCursor[player]);
    }

    setcurpl(savedCp);
}

function updateMenus() {
    foreach (p : py_range(constants.MAX_PLAYERS)) {
        if (MenuPage[p] != MENU_CLOSED) {
            handleMenuInput(p);
            renderMenu(p);
        }
    }
}
